        "yny_accordion_group_XnwLNx": {
          "type": "yny_accordion_group",
          "settings": {
            "item_1_heading": "Key Benefits",
            "item_1_source": "custom",
            "item_1_content": "<ul><li>Supports healthy joint function</li><li>Reduces joint stiffness and discomfort</li><li>Improves flexibility and mobility</li><li>Maintains healthy cartilage</li><li>Provides natural anti-inflammatory support</li><li>Suitable for active and senior dogs</li></ul>",
            "item_2_heading": "Ingredients",
            "item_2_source": "custom",
            "item_2_content": "<ul><li><strong>Glucosamine HCl 500mg</strong> - Primary building block of cartilage that helps maintain cushioning in joints</li><li><strong>MSM 400mg</strong> - Natural sulfur compound that reduces joint inflammation and supports connective tissue repair</li><li><strong>Green-Lipped Mussel 150mg</strong> - Unique New Zealand shellfish rich in Omega-3s and glycosaminoglycans for joint lubrication</li><li><strong>Chondroitin Sulfate 110mg</strong> - Retains water in cartilage, maintaining joint flexibility and shock absorption</li><li><strong>Turmeric &amp; Boswellia</strong> - Powerful natural anti-inflammatory botanicals that reduce pain and support mobility</li></ul><p><strong>Full ingredient list:</strong> Glucosamine Hydrochloride, MSM, Green-Lipped Mussel Powder, Chondroitin Sulfate, Chicken Liver, Sweet Potato, Brewer's Yeast, Turmeric Root Powder, Boswellia Serrata Extract.</p><p><em>Inactive ingredients:</em> Maltodextrin, Glycerin, Stearic Acid, Natural Flavors.</p>",
            "item_3_heading": "How to Use",
            "item_3_source": "custom",
            "item_3_content": "<p>Give daily based on your dog's weight:</p><ul><li><strong>Up to 15 lbs:</strong> 1 chew per day</li><li><strong>15-45 lbs:</strong> 2 chews per day</li><li><strong>45-75 lbs:</strong> 3 chews per day</li><li><strong>75+ lbs:</strong> 4 chews per day</li></ul><p>Can be given as a treat or crumbled over food. Store in a cool, dry place.</p>",
            "item_4_heading": "Shipping Info",
            "item_4_source": "custom",
            "item_4_content": "<p>Free shipping on all orders. Orders are processed within 1-2 business days and typically arrive within 5-6 business days.</p><ul><li>Tracking details sent by email after dispatch</li><li>Free shipping on every order - no minimum</li></ul>",
            "item_5_heading": "",
            "item_5_source": "custom",
            "item_5_content": "",
            "acc_bg_color": "#ffffff",
            "acc_border_color": "#f0dbd9",
            "summary_color": "#1d1d1b",
            "text_color": "#555555"
          }
