    "faq_hj": {
      "type": "faq-accordion-section",
      "blocks": {
        "cat_hj1": {
          "type": "category",
          "settings": {
            "heading": "Hip & Joint"
          }
        },
        "faq_hj1": {
          "type": "item",
          "settings": {
            "heading": "How long until I see improvement in my dog's mobility?",
            "content": "<p>Many pet parents notice improvements in mobility and comfort within 4-8 weeks of consistent daily use. Senior dogs or those with advanced joint issues may take longer to show significant improvement.</p>"
          }
        },
        "faq_hj2": {
          "type": "item",
          "settings": {
            "heading": "Is this safe for dogs already on joint medication?",
            "content": "<p>Please consult your veterinarian if your dog is taking prescription joint medications. Natural supplements can often complement prescribed treatments safely, but your vet should confirm for your specific dog.</p>"
          }
        },
        "faq_hj3": {
          "type": "item",
          "settings": {
            "heading": "What breeds benefit most?",
            "content": "<p>While any dog can benefit, breeds prone to joint issues - like German Shepherds, Golden Retrievers, Labradors, and large/giant breeds - tend to see the most significant improvements in mobility and comfort.</p>"
          }
        },
        "faq_hj4": {
          "type": "item",
          "settings": {
            "heading": "Can younger dogs take Hip & Joint as prevention?",
            "content": "<p>Yes! Starting joint support early is a great proactive strategy, especially for large breeds. Prevention is always easier than treatment, and our formula is safe for ongoing daily use.</p>"
          }
        },
        "faq_hj5": {
          "type": "item",
          "settings": {
            "heading": "Is this safe for dogs with shellfish sensitivities?",
            "content": "<p>Our Hip &amp; Joint formula contains Green-Lipped Mussel, which is a shellfish. If your dog has a known shellfish sensitivity or allergy, please consult your veterinarian before use. The remaining ingredients are shellfish-free.</p>"
          }
        },
        "faq_hj6": {
          "type": "item",
          "settings": {
            "heading": "How fast does shipping and delivery work?",
            "content": "<p>We offer free shipping on every order with no minimum purchase. Orders are processed within 1-2 business days and typically arrive within 5-6 business days. You will receive a tracking email once your order is dispatched. If your order has not arrived within 8 business days, please contact our support team.</p>"
          }
        },
        "faq_hj7": {
          "type": "item",
          "settings": {
            "heading": "Can I subscribe to save on Hip & Joint?",
            "content": "<p>Yes! Our Subscribe &amp; Save program gives you 15% off every delivery plus free shipping included. You choose the delivery frequency and can skip, pause, or cancel anytime with no penalties. Never run out and never pay full price again.</p>"
          }
        }
      },
