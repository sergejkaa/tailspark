    "faq_hj": {
      "type": "faq-accordion-section",
      "blocks": {
        "cat_hj1": {
          "type": "category",
          "settings": {
            "heading": "Hip & Joint"
          }
        },
        "faq_hj1": {
          "type": "item",
          "settings": {
            "heading": "How long until I see a difference in my dog's mobility?",
            "content": "<p>Every dog is different and individual results may vary. We recommend giving any supplement at least 4 to 6 weeks of consistent daily use to allow the ingredients to build up in your dog's system.</p>"
          }
        },
        "faq_hj2": {
          "type": "item",
          "settings": {
            "heading": "Is this safe for dogs already on joint medication?",
            "content": "<p>If your dog is currently taking prescription medication, we recommend consulting your veterinarian before adding any supplement to their routine.</p>"
          }
        },
        "faq_hj3": {
          "type": "item",
          "settings": {
            "heading": "What breeds benefit most from Hip & Joint?",
            "content": "<p>Hip &amp; Joint is formulated for dogs of all breeds and sizes. Breeds that are naturally more prone to joint concerns — such as German Shepherds, Golden Retrievers, Labradors, and large or giant breeds — may find it particularly beneficial as part of their daily routine.</p>"
          }
        },
        "faq_hj4": {
          "type": "item",
          "settings": {
            "heading": "Can younger dogs take Hip & Joint as prevention?",
            "content": "<p>Yes — starting joint support early is a great proactive approach, especially for large breeds. The formula is designed for dogs of all ages and is suitable for daily ongoing use.</p>"
          }
        },
        "faq_hj5": {
          "type": "item",
          "settings": {
            "heading": "Is this safe for dogs with shellfish sensitivities?",
            "content": "<p>Our Hip &amp; Joint formula contains Green-Lipped Mussel, which is a shellfish. If your dog has a known shellfish sensitivity or allergy, please consult your veterinarian before use. All other ingredients in this formula are shellfish-free.</p>"
          }
        },
        "faq_hj6": {
          "type": "item",
          "settings": {
            "heading": "How long does shipping take?",
            "content": "<p>Standard shipping is free on every order with no minimum. Orders are processed within 1 business day and typically arrive within 3 to 5 business days. You will receive a tracking email once your order ships.</p>"
          }
        },
        "faq_hj7": {
          "type": "item",
          "settings": {
            "heading": "Can I subscribe and save on Hip & Joint?",
            "content": "<p>Yes — our Subscribe &amp; Save program gives you 15% off every delivery plus free standard shipping. You can skip, pause, or cancel anytime from your account with no fees or penalties.</p>"
          }
        }
      },
