        },
        "item_FMVhFe": {
          "type": "item",
          "settings": {
            "heading": "How is it different from traditional brushing?",
            "content": "<p>Traditional brushing only cleans the surface of the teeth. The Doctor X irrigator deeply cleans the interdental and gingival spaces, providing complete oral hygiene, similar to a visit to the dentist.</p>"
          }
        },
        "item_PcQp3t": {
