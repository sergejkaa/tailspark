    "guarantee_section_main": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div style=\"text-align:center;padding:48px 24px;background:#fff8ed;\"><img src=\"{{ 'ts-100-satisfaction.png' | asset_url }}\" alt=\"100% Satisfaction Guarantee\" width=\"96\" height=\"96\" style=\"width:96px;height:auto;margin:0 auto 16px;display:block;\" loading=\"lazy\"><p style=\"font-size:13px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#ff6700;margin-bottom:12px;\">Our Promise</p><h2 style=\"font-size:clamp(24px,4vw,36px);font-weight:700;color:#1d1d1b;margin-bottom:16px;\">100% Satisfaction Guarantee</h2><p style=\"font-size:16px;color:#555;max-width:540px;margin:0 auto;line-height:1.65;\">We stand behind our product with a 100% satisfaction guarantee. If you're not happy with the quality, please reach out and we'll make it right.</p></div>",
        "color_scheme": "scheme-1",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "faq_tailspark_main": {
      "type": "faq-accordion-section",
      "blocks": {
        "faq_item_which": {
          "type": "item",
          "settings": {
            "heading": "Which supplement is right for my dog?",
            "content": "<p>It depends on your dog's needs. Hip & Joint is great for active dogs or those needing extra joint support. Skin & Coat is ideal for dogs with a dull coat, dry skin, or those that need extra skin support. Probiotic helps dogs with sensitive digestion or occasional stomach upset. Daily Multivitamin is the best all-around choice for everyday wellness.</p>"
          }
        },
        "faq_item_multiple": {
          "type": "item",
          "settings": {
            "heading": "Can my dog take more than one supplement at a time?",
            "content": "<p>Yes — Tailspark supplements are designed to work well together. Many customers combine Hip & Joint with Skin & Coat, or Probiotic with Multivitamin. All formulas are carefully developed to complement each other.</p>"
          }
        },
        "faq_item_dose": {
          "type": "item",
          "settings": {
            "heading": "How many chews should I give per day?",
            "content": "<p>It depends on your dog's size and the specific supplement. You'll find exact dosing instructions on each product page and on the label.</p>"
          }
        },
        "faq_item_results": {
          "type": "item",
          "settings": {
            "heading": "How long until I see results?",
            "content": "<p>Every dog is different, so experiences may vary. We recommend giving any supplement at least 4 to 6 weeks of consistent daily use to allow the ingredients to build up in your dog's system. As with any supplement, individual results will vary.</p>"
          }
        },
        "faq_item_natural": {
          "type": "item",
          "settings": {
            "heading": "What's in your supplements?",
            "content": "<p>Every Tailspark formula uses high-quality, functional ingredients with no artificial colors, flavors, or unnecessary additives. Veterinarian formulated and made in a cGMP, FDA-Registered Food Facility in the USA.</p>"
          }
        },
        "faq_item_shipping": {
          "type": "item",
          "settings": {
            "heading": "How long does shipping take? Is it free?",
            "content": "<p>Standard shipping is free on every order — no minimum required. Orders are processed within 1 business day and typically arrive within 3 to 5 business days. You will receive a tracking email as soon as your order ships.</p>"
          }
        },
        "faq_item_sub_cancel": {
          "type": "item",
          "settings": {
            "heading": "Can I cancel my subscription anytime?",
            "content": "<p>Absolutely. No contracts, no cancellation fees. You can skip, pause, or cancel a delivery anytime from your customer account — no need to contact support.</p>"
          }
        },
        "faq_item_guarantee": {
          "type": "item",
          "settings": {
            "heading": "Is there a money-back guarantee?",
            "content": "<p>Yes — we offer a 60-day money-back guarantee on your first order. If you're not happy with the quality, contact us within 60 days and we'll issue a full refund. No hoops, no hassle.</p>"
          }
        }
      },
