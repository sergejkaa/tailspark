    "faq_mv": {
      "type": "faq-accordion-section",
      "blocks": {
        "cat_mv1": {
          "type": "category",
          "settings": {
            "heading": "Daily Multivitamin"
          }
        },
        "faq_mv1": {
          "type": "item",
          "settings": {
            "heading": "Do I still need other supplements if I use the Multivitamin?",
            "content": "<p>Our Daily Multivitamin provides broad daily nutritional support. Some dogs may benefit from additional targeted support — for example, Hip &amp; Joint for joint health or Probiotic for digestive wellness — alongside the Multivitamin.</p>"
          }
        },
        "faq_mv2": {
          "type": "item",
          "settings": {
            "heading": "Can puppies take the Multivitamin?",
            "content": "<p>The Multivitamin is formulated for dogs of all ages. If your puppy has specific nutritional needs or is on a growth formula, we recommend consulting your veterinarian before adding any supplement.</p>"
          }
        },
        "faq_mv3": {
          "type": "item",
          "settings": {
            "heading": "Will it cause any digestive issues?",
            "content": "<p>Our formula is designed for gentle daily use. Some dogs may experience a brief adjustment period when starting a new supplement. Giving the chew with a meal can help minimize any sensitivity.</p>"
          }
        },
        "faq_mv4": {
          "type": "item",
          "settings": {
            "heading": "How long before I see a difference?",
            "content": "<p>Every dog is different and individual results may vary. We recommend consistent daily use for at least 4 to 6 weeks to allow the ingredients to build up in your dog's system.</p>"
          }
        },
        "faq_mv5": {
          "type": "item",
          "settings": {
            "heading": "Can the Multivitamin interact with prescription medications?",
            "content": "<p>If your dog is currently on prescription medication, we recommend consulting your veterinarian before adding any supplement to their routine.</p>"
          }
        },
        "faq_mv6": {
          "type": "item",
          "settings": {
            "heading": "How long does shipping take?",
            "content": "<p>Standard shipping is free on every order with no minimum. Orders are processed within 1 business day and typically arrive within 3 to 5 business days. You will receive a tracking email once your order ships.</p>"
          }
        },
        "faq_mv7": {
          "type": "item",
          "settings": {
            "heading": "Can I subscribe and save on the Multivitamin?",
            "content": "<p>Yes — our Subscribe &amp; Save program gives you 15% off every delivery plus free standard shipping. You can skip, pause, or cancel anytime from your account with no fees or penalties.</p>"
          }
        }
      },
