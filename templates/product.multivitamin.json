    "reviews_mv": {
      "type": "customer-reviews",
      "blocks": {
        "rev_mv1": { "type": "review", "settings": { "rating": 5, "review_text": "Our golden retriever Max has been on the Hip & Joint chews for 2 months and the difference is incredible. He moves like a puppy again - running, jumping, playing fetch. Worth every penny!", "reviewer_name": "Sarah M.", "reviewer_info": "Texas - Mom to Max, 8yr Golden Retriever" } },
        "rev_mv2": { "type": "review", "settings": { "rating": 5, "review_text": "The Probiotic chews completely solved her sensitive stomach issues. No more upset tummy after meals. Love that I can give my dog something healthy that she actually wants to eat!", "reviewer_name": "Jennifer K.", "reviewer_info": "California - Mom to Bella, Labrador Mix" } },
        "rev_mv3": { "type": "review", "settings": { "rating": 5, "review_text": "Three of my dogs take different TailSpark supplements and they all go crazy for the chews. The Multivitamin has given my 11-year-old so much more energy. Clean ingredients, real results.", "reviewer_name": "Mark R.", "reviewer_info": "Florida - Dad to 3 rescue dogs" } },
        "rev_mv4": { "type": "review", "settings": { "rating": 5, "review_text": "My dachshund started limping after a rough play session. Within 3 weeks of the Hip & Joint chews she is back to her zoomie self. Honestly amazed at how fast it worked.", "reviewer_name": "Lisa T.", "reviewer_info": "New York - Mom to Bella, 6yr Dachshund" } },
        "rev_mv5": { "type": "review", "settings": { "rating": 5, "review_text": "My working dog needs real nutrition to stay sharp. The Multivitamin keeps his coat shiny, his energy consistent, and his vet says his bloodwork looks great. Total game changer.", "reviewer_name": "Carlos M.", "reviewer_info": "Texas - Dad to Rex, German Shepherd" } },
        "rev_mv6": { "type": "review", "settings": { "rating": 5, "review_text": "My poodle always had dry, flaky skin and I tried everything. After 6 weeks on the Skin and Coat chews, her coat is silky and the flaking stopped completely. She loves them too!", "reviewer_name": "Amanda W.", "reviewer_info": "Ohio - Mom to Luna, Poodle Mix" } },
        "rev_mv7": { "type": "review", "settings": { "rating": 5, "review_text": "Our 9-year-old Husky was slowing down and struggling on hikes. After 5 weeks of Hip & Joint chews he is back leading the pack on our trails. My vet recommended these - they work!", "reviewer_name": "David H.", "reviewer_info": "Colorado - Dad to Zeus, 9yr Husky" } },
        "rev_mv8": { "type": "review", "settings": { "rating": 5, "review_text": "My beagle had chronic digestive issues for years. The Probiotic chews changed everything. Within 2 weeks his digestion stabilized completely. No more accidents and he is so much happier.", "reviewer_name": "Nicole B.", "reviewer_info": "Georgia - Mom to Biscuit, Beagle" } },
        "rev_mv9": { "type": "review", "settings": { "rating": 5, "review_text": "Border collies are known for shedding and Luna was no exception. Since starting the Skin and Coat chews 2 months ago, the shedding dropped dramatically and her coat looks amazing.", "reviewer_name": "Rachel P.", "reviewer_info": "California - Mom to Luna, Border Collie" } }
      },
