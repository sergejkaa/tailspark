        "yny_accordion_group_XnwLNx": {
          "type": "yny_accordion_group",
          "settings": {
            "item_1_heading": "Key Benefits",
            "item_1_source": "custom",
            "item_1_content": "<ul><li>Helps support daily wellness and balanced nutrition</li><li>Supports healthy skin and a shiny coat</li><li>Helps maintain immune and digestive health</li><li>Supports heart, brain, and overall vitality</li><li>Ideal for everyday wellness and travel support</li></ul>",
            "item_2_heading": "Key Ingredients",
            "item_2_source": "custom",
            "item_2_content": "<p><strong>Per Chew (3.5g):</strong></p><ul><li>Methionine — 10 mg</li><li>Calcium — 112 mg</li><li>Phosphorus — 56 mg</li><li>Potassium — 15 mg</li><li>Magnesium — 5 mg</li><li>Iron — 3 mg</li><li>Copper — 0.3 mg</li><li>Manganese — 1 mg</li><li>Zinc — 3 mg</li><li>Iodine — 0.05 mg</li><li>Vitamin A — 1000 IU</li><li>Vitamin D3 — 100 IU</li><li>Vitamin E — 15 IU</li><li>Thiamine (B1) — 0.2 mg</li><li>Riboflavin (B2) — 1 mg</li><li>Pantothenic Acid — 4 mg</li><li>Niacin — 5 mg</li><li>Pyridoxine (B6) — 0.4 mg</li><li>Folic Acid — 0.08 mg</li><li>Vitamin B12 — 0.008 mg</li><li>Ascorbic Acid (Vitamin C) — 25 mg</li></ul>",
            "item_3_heading": "How to Use",
            "item_3_source": "custom",
            "item_3_content": "<p>Give daily based on your dog's weight:</p><ul><li><strong>Under 25 lbs:</strong> 1/2 chew per day</li><li><strong>25–75 lbs:</strong> 1 chew per day</li><li><strong>75+ lbs:</strong> 2 chews per day</li></ul><p>Can be given as a treat or crumbled over food. If giving more than 1 chew daily, divide between morning and evening. Store in a cool, dry place.</p>",
            "item_4_heading": "Shipping",
            "item_4_source": "custom",
            "item_4_content": "<p>Free standard shipping on every order — no minimum. Orders are processed within 1 business day and typically arrive within 3–5 business days. Tracking details sent by email once your order ships.</p>",
            "item_5_heading": "",
            "item_5_source": "custom",
            "item_5_content": "",
            "acc_bg_color": "#ffffff",
            "acc_border_color": "#ddeaea",
            "summary_color": "#1d1d1b",
            "text_color": "#555555"
