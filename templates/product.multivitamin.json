        "cat_mv1": { "type": "category", "settings": { "heading": "Daily Multivitamin" } },
        "faq_mv1": { "type": "item", "settings": { "heading": "Do I still need other supplements if I use the Multivitamin?", "content": "<p>Our Daily Multivitamin provides comprehensive nutritional support. Dogs with specific conditions may benefit from targeted supplements alongside it - like Hip &amp; Joint for mobility or Probiotic for digestive health.</p>" } },
        "faq_mv2": { "type": "item", "settings": { "heading": "Can puppies take the Multivitamin?", "content": "<p>Suitable for dogs 6 months and older. Young puppies on growth-specific formulas should consult a veterinarian before adding any supplements.</p>" } },
        "faq_mv3": { "type": "item", "settings": { "heading": "Will it cause any digestive issues?", "content": "<p>Our formula is gentle and designed for daily use. Some dogs may experience a brief adjustment period. Giving the chew with a meal helps minimize any sensitivity.</p>" } },
        "faq_mv4": { "type": "item", "settings": { "heading": "How long before I notice a difference?", "content": "<p>Most pet parents notice improvements in energy levels and overall vitality within 4-6 weeks of consistent daily use. Immune benefits build gradually over 8-12 weeks.</p>" } }
