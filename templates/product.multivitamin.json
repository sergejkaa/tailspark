    "faq_mv": {
      "type": "faq-accordion-section",
      "blocks": {
        "cat_mv1": {
          "type": "category",
          "settings": {
            "heading": "Daily Multivitamin"
          }
        },
        "faq_mv1": {
          "type": "item",
          "settings": {
            "heading": "Do I still need other supplements if I use the Multivitamin?",
            "content": "<p>Our Daily Multivitamin provides comprehensive nutritional support. Dogs with specific conditions may benefit from targeted supplements alongside it - like Hip &amp; Joint for mobility or Probiotic for digestive health.</p>"
          }
        },
        "faq_mv2": {
          "type": "item",
          "settings": {
            "heading": "Can puppies take the Multivitamin?",
            "content": "<p>Suitable for dogs 6 months and older. Young puppies on growth-specific formulas should consult a veterinarian before adding any supplements.</p>"
          }
        },
        "faq_mv3": {
          "type": "item",
          "settings": {
            "heading": "Will it cause any digestive issues?",
            "content": "<p>Our formula is gentle and designed for daily use. Some dogs may experience a brief adjustment period. Giving the chew with a meal helps minimize any sensitivity.</p>"
          }
        },
        "faq_mv4": {
          "type": "item",
          "settings": {
            "heading": "How long before I notice a difference?",
            "content": "<p>Most pet parents notice improvements in energy levels and overall vitality within 4-6 weeks of consistent daily use. Immune benefits build gradually over 8-12 weeks.</p>"
          }
        },
        "faq_mv5": {
          "type": "item",
          "settings": {
            "heading": "Can Multivitamin interact with prescription medications?",
            "content": "<p>Our Multivitamin uses natural vitamins and minerals at safe daily doses. It is generally compatible with most medications. However, if your dog is on prescription treatments, we recommend checking with your veterinarian before adding any supplement to the routine.</p>"
          }
        },
        "faq_mv6": {
          "type": "item",
          "settings": {
            "heading": "How does shipping and delivery work?",
            "content": "<p>Free shipping on every order with no minimum. Orders process within 1-2 business days and typically arrive within 5-6 business days. A tracking email is sent once dispatched. If your order has not arrived within 8 business days, reach out to our support team and we will take care of it.</p>"
          }
        },
        "faq_mv7": {
          "type": "item",
          "settings": {
            "heading": "Is there a subscription option to save money?",
            "content": "<p>Yes - Subscribe &amp; Save gives you 15% off every order automatically plus free shipping on every delivery. You can choose your preferred frequency, skip a delivery, pause, or cancel anytime. It is the easiest way to keep your dog's daily nutrition consistent without running out.</p>"
          }
        }
      },
