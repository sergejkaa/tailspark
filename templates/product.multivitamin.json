        "yny_accordion_group_XnwLNx": {
          "type": "yny_accordion_group",
          "settings": {
            "item_1_heading": "Key Benefits",
            "item_1_source": "custom",
            "item_1_content": "<ul><li>Supports overall health and vitality</li><li>Strengthens immune system</li><li>Promotes strong bones and teeth</li><li>Supports healthy metabolism and energy</li><li>Complete vitamin and mineral complex</li><li>Suitable for dogs of all ages and sizes</li></ul>",
            "item_2_heading": "Key Ingredients",
            "item_2_source": "custom",
            "item_2_content": "<ul><li><strong>Vitamins A, C, D3 & E</strong> - Essential antioxidant vitamins that protect cells and support immune function</li><li><strong>B-Complex (B1, B2, B3, B5, B6, B12)</strong> - Full spectrum B vitamins for energy metabolism and nerve health</li><li><strong>Calcium & Phosphorus</strong> - Bone-building minerals for strong teeth and structural health</li><li><strong>Magnesium & Potassium</strong> - Essential for muscle function, nerve health, and fluid balance</li><li><strong>Zinc, Iodine & Selenium</strong> - Trace minerals for immune response and thyroid function</li></ul>",
            "item_3_heading": "Directions",
            "item_3_source": "custom",
            "item_3_content": "<p>Give daily based on your dog's weight:</p><ul><li><strong>Under 25 lbs:</strong> 1/2 chew per day</li><li><strong>25-75 lbs:</strong> 1 chew per day</li><li><strong>75+ lbs:</strong> 2 chews per day</li></ul><p>Can be given as a treat or crumbled over food. Store in a cool, dry place.</p>",
            "item_4_heading": "",
            "item_4_source": "custom",
            "item_4_content": "<p></p>",
            "item_5_heading": "",
            "item_5_source": "custom",
            "item_5_content": "<p></p>",
            "acc_bg_color": "#ffffff",
            "acc_border_color": "#ddeaea",
            "summary_color": "#1d1d1b",
            "text_color": "#555555"
          }
        },
        "collapsible_tab_pCUWk9": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Full Ingredient List",
            "icon": "leaf",
            "content": "<p>Vitamins: A (Vitamin A Acetate), C (Ascorbic Acid), D3 (Cholecalciferol), E (dl-Alpha Tocopheryl Acetate), B1 (Thiamine Mononitrate), B2 (Riboflavin), B3 (Niacinamide), B5 (d-Calcium Pantothenate), B6 (Pyridoxine HCl), B12 (Cyanocobalamin), Folic Acid, Biotin.</p><p>Minerals: Calcium Carbonate, Dicalcium Phosphate, Magnesium Oxide, Potassium Chloride, Zinc Sulfate, Iodine (Kelp), Iron, Manganese Sulfate, Selenium Yeast.</p><p>Base: Chicken Liver, Sweet Potato, Brewer's Yeast, Maltodextrin, Glycerin, Natural Flavors.</p>",
            "page": ""
          }
        },
        "collapsible_tab_AVnp4f": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Shipping Info",
            "icon": "truck",
            "content": "<p>Free shipping on all orders. Orders are processed within 1-2 business days and typically arrive within 5-6 business days.</p><ul><li>Tracking details sent by email after dispatch</li><li>Free shipping on every order - no minimum</li></ul>",
            "page": ""
          }
        },
        "collapsible_tab_LkJYyF": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "F.A.Q.",
            "icon": "check_mark",
            "content": "<p><strong>Do I still need other supplements if I use the Multivitamin?</strong><br/>Our Daily Multivitamin provides comprehensive nutritional support. Dogs with specific conditions may benefit from targeted supplements alongside it - such as Hip &amp; Joint for mobility.</p><p><strong>Can puppies take the Multivitamin?</strong><br/>Suitable for dogs 6 months and older. Young puppies on growth-specific formulas should consult a vet before adding supplements.</p><p><strong>Will it cause any digestive issues?</strong><br/>Our formula is gentle and designed for daily use. Giving the chew with a meal can help minimize any sensitivity during the adjustment period.</p>",
            "page": ""
          }
        },
