        "yny_accordion_group_XnwLNx": {
          "type": "yny_accordion_group",
          "settings": {
            "item_1_heading": "Key Benefits",
            "item_1_source": "custom",
            "item_1_content": "<ul><li>Provides complete daily nutritional support</li><li>Strengthens immune system function</li><li>Supports strong bones and healthy teeth</li><li>Boosts energy levels and overall vitality</li><li>Full spectrum of essential vitamins and minerals</li><li>Suitable for dogs of all ages 6 months and older</li></ul>",
            "item_2_heading": "Ingredients",
            "item_2_source": "custom",
            "item_2_content": "<ul><li><strong>Vitamins A, C, D3 &amp; E</strong> - Essential antioxidant vitamins that protect cells, support immune function, and maintain healthy vision and skin</li><li><strong>Full B-Complex</strong> - B1, B2, B3, B5, B6, B12 vitamins that support energy metabolism, nerve health, and red blood cell production</li><li><strong>Calcium &amp; Phosphorus</strong> - The essential bone-building mineral duo for strong teeth and healthy joints</li><li><strong>Magnesium &amp; Potassium</strong> - Essential minerals for muscle function and nerve signal transmission</li><li><strong>Zinc, Iodine &amp; Selenium</strong> - Vital trace minerals supporting immune response, wound healing, and thyroid function</li></ul><p><strong>Full ingredient list:</strong> Vitamins: A (Vitamin A Acetate), C (Ascorbic Acid), D3 (Cholecalciferol), E (dl-Alpha Tocopheryl Acetate), B1 (Thiamine Mononitrate), B2 (Riboflavin), B3 (Niacinamide), B5 (d-Calcium Pantothenate), B6 (Pyridoxine HCl), B12 (Cyanocobalamin), Folic Acid, Biotin. Minerals: Calcium Carbonate, Dicalcium Phosphate, Magnesium Oxide, Potassium Chloride, Zinc Sulfate, Iodine (Kelp), Iron, Manganese Sulfate, Selenium Yeast.</p><p><em>Inactive ingredients:</em> Chicken Liver, Sweet Potato, Brewer's Yeast, Maltodextrin, Glycerin, Natural Flavors.</p>",
            "item_3_heading": "How to Use",
            "item_3_source": "custom",
            "item_3_content": "<p>Give daily based on your dog's weight:</p><ul><li><strong>Under 25 lbs:</strong> 1/2 chew per day</li><li><strong>25-75 lbs:</strong> 1 chew per day</li><li><strong>75+ lbs:</strong> 2 chews per day</li></ul><p>Can be given as a treat or crumbled over food. Store in a cool, dry place.</p>",
            "item_4_heading": "Shipping Info",
            "item_4_source": "custom",
            "item_4_content": "<p>Free shipping on all orders. Orders are processed within 1-2 business days and typically arrive within 5-6 business days.</p><ul><li>Tracking details sent by email after dispatch</li><li>Free shipping on every order - no minimum</li></ul>",
            "item_5_heading": "",
            "item_5_source": "custom",
            "item_5_content": "",
            "acc_bg_color": "#ffffff", "acc_border_color": "#ddeaea",
            "summary_color": "#1d1d1b", "text_color": "#555555"
          }
        },
