    "faq_pb": {
      "type": "faq-accordion-section",
      "blocks": {
        "cat_pb1": {
          "type": "category",
          "settings": {
            "heading": "Probiotic"
          }
        },
        "faq_pb1": {
          "type": "item",
          "settings": {
            "heading": "How quickly will the Probiotic help my dog's digestion?",
            "content": "<p>Many dogs show improvement in digestive comfort within 1-2 weeks of consistent daily use. For dogs recovering from antibiotics or with chronic digestive issues, allow 3-4 weeks for full benefit.</p>"
          }
        },
        "faq_pb2": {
          "type": "item",
          "settings": {
            "heading": "Should I give Probiotics during antibiotic treatment?",
            "content": "<p>Probiotics are especially beneficial during and after antibiotic use to restore healthy gut flora. Give the probiotic chew at least 2 hours apart from the antibiotic dose for best results.</p>"
          }
        },
        "faq_pb3": {
          "type": "item",
          "settings": {
            "heading": "Can I give Probiotic with other TailSpark supplements?",
            "content": "<p>Yes! Our Probiotic pairs excellently with the Multivitamin for comprehensive daily wellness. All TailSpark supplements are formulated to be safe in combination.</p>"
          }
        },
        "faq_pb4": {
          "type": "item",
          "settings": {
            "heading": "Is this suitable for dogs with sensitive stomachs?",
            "content": "<p>Absolutely. Our Probiotic is specifically designed to be gentle and beneficial for dogs with sensitive stomachs. It's an ideal choice for dogs that experience regular digestive discomfort.</p>"
          }
        },
        "faq_pb5": {
          "type": "item",
          "settings": {
            "heading": "Do I need to refrigerate the Probiotic chews?",
            "content": "<p>No refrigeration needed. Our Probiotic uses Bacillus coagulans, a spore-forming strain that is naturally shelf-stable. Simply store in a cool, dry place out of direct sunlight. The sealed bag keeps freshness for the full shelf life of the product.</p>"
          }
        },
        "faq_pb6": {
          "type": "item",
          "settings": {
            "heading": "How fast does delivery arrive?",
            "content": "<p>We ship free on every order. Orders are processed within 1-2 business days and delivered within 5-6 business days. You will get a tracking email as soon as your package is on its way. If anything goes wrong with delivery, contact us and we will resolve it.</p>"
          }
        },
        "faq_pb7": {
          "type": "item",
          "settings": {
            "heading": "Can I subscribe and save on Probiotic?",
            "content": "<p>Absolutely. Subscribe &amp; Save gets you 15% off every order and free shipping on each delivery. Gut health works best with consistent daily use, so subscribing means your dog never misses a day. Skip, pause, or cancel anytime - no commitment required.</p>"
          }
        }
      },
