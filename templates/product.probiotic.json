        "yny_accordion_group_XnwLNx": {
          "type": "yny_accordion_group",
          "settings": {
            "item_1_heading": "Key Benefits",
            "item_1_source": "custom",
            "item_1_content": "<ul><li>Supports healthy digestion</li><li>Reduces bloating, gas, and diarrhea</li><li>Promotes balanced gut microbiome</li><li>Boosts immune system naturally</li><li>Contains prebiotic FOS for enhanced probiotic activity</li><li>Ideal for sensitive stomachs and post-antibiotic recovery</li></ul>",
            "item_2_heading": "Key Ingredients",
            "item_2_source": "custom",
            "item_2_content": "<ul><li><strong>Bacillus coagulans 120M CFU</strong> - Spore-forming probiotic strain that survives digestion and colonizes the gut effectively</li><li><strong>FOS (Fructooligosaccharides) 200mg</strong> - Prebiotic fiber that feeds beneficial gut bacteria and enhances probiotic activity</li><li><strong>Inulin</strong> - Soluble fiber from chicory root that promotes healthy bowel movements and digestive comfort</li><li><strong>Brewer's Yeast</strong> - Rich in B-vitamins and natural prebiotics that further support gut health</li></ul>",
            "item_3_heading": "Directions",
            "item_3_source": "custom",
            "item_3_content": "<p>Give daily based on your dog's weight:</p><ul><li><strong>Up to 25 lbs:</strong> 1 chew per day</li><li><strong>25-50 lbs:</strong> 2 chews per day</li><li><strong>50-75 lbs:</strong> 3 chews per day</li><li><strong>75+ lbs:</strong> 4 chews per day</li></ul><p>Can be given as a treat or crumbled over food. Store in a cool, dry place. For best results, give consistently at the same time each day.</p>",
            "item_4_heading": "Full Ingredient List",
            "item_4_source": "custom",
            "item_4_content": "<p>Bacillus coagulans (120 Million CFU), Fructooligosaccharides (FOS) 200mg, Inulin (Chicory Root Extract), Chicken Liver, Sweet Potato, Brewer's Yeast.</p><p><em>Inactive ingredients:</em> Maltodextrin, Glycerin, Stearic Acid, Natural Flavors.</p>",
            "item_5_heading": "Shipping Info",
            "item_5_source": "custom",
            "item_5_content": "<p>Free shipping on all orders. Orders are processed within 1-2 business days and typically arrive within 5-6 business days.</p><ul><li>Tracking details sent by email after dispatch</li><li>Free shipping on every order - no minimum</li></ul>",
            "acc_bg_color": "#ffffff",
