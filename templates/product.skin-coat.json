        "yny_accordion_group_XnwLNx": {
          "type": "yny_accordion_group",
          "settings": {
            "item_1_heading": "Key Benefits",
            "item_1_source": "custom",
            "item_1_content": "<ul><li>Promotes a shiny, healthy coat</li><li>Reduces excessive shedding</li><li>Soothes dry and itchy skin</li><li>Supports skin barrier function</li><li>Rich in essential fatty acids (Omega-3, 6, 9)</li><li>Contains Vitamin E and Biotin for skin and coat health</li></ul>",
            "item_2_heading": "Ingredients",
            "item_2_source": "custom",
            "item_2_content": "<ul><li><strong>Fish Oil</strong> - Rich source of Omega-3 fatty acids (DHA &amp; EPA) for skin moisture and coat shine</li><li><strong>Flaxseed</strong> - Plant-based Omega-6 &amp; Omega-9 fatty acids that strengthen skin barrier</li><li><strong>Vitamin E</strong> - Antioxidant that protects skin cells and promotes a glossy coat</li><li><strong>Biotin</strong> - Strengthens hair follicles and supports healthy fur growth</li><li><strong>Vitamin A</strong> - Supports skin cell regeneration and hydration</li><li><strong>Coconut Oil</strong> - Natural moisturizer with antimicrobial properties</li></ul><p><strong>Full ingredient list:</strong> Fish Oil, Flaxseed (Linum usitatissimum), Sunflower Oil, Vitamin E Supplement, Vitamin A Supplement, Biotin, Brewer's Yeast, Chicken Liver, Sweet Potato, Coconut Oil, Rosemary Extract.</p><p><em>Inactive ingredients:</em> Maltodextrin, Glycerin, Stearic Acid, Natural Flavors.</p>",
            "item_3_heading": "How to Use",
            "item_3_source": "custom",
            "item_3_content": "<p>Give daily based on your dog's weight:</p><ul><li><strong>Up to 25 lbs:</strong> 1 chew per day</li><li><strong>25-50 lbs:</strong> 2 chews per day</li><li><strong>50-75 lbs:</strong> 3 chews per day</li><li><strong>75+ lbs:</strong> 4 chews per day</li></ul><p>Can be given as a treat or crumbled over food. Store in a cool, dry place.</p>",
            "item_4_heading": "Shipping Info",
            "item_4_source": "custom",
            "item_4_content": "<p>Free shipping on all orders. Orders are processed within 1-2 business days and typically arrive within 5-6 business days.</p><ul><li>Tracking details sent by email after dispatch</li><li>Free shipping on every order - no minimum</li><li>Contact support if your order hasn't arrived within 8 business days</li></ul>",
            "item_5_heading": "",
            "item_5_source": "custom",
            "item_5_content": "",
            "acc_bg_color": "#ffffff",
            "acc_border_color": "#ede8e3",
