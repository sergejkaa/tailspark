    "faq_sc": {
      "type": "faq-accordion-section",
      "blocks": {
        "cat_sc1": {
          "type": "category",
          "settings": {
            "heading": "Skin & Coat"
          }
        },
        "faq_sc1": {
          "type": "item",
          "settings": {
            "heading": "How long before I see a difference in my dog's coat?",
            "content": "<p>Every dog is different and individual results may vary. We recommend consistent daily use for at least 4 to 6 weeks to allow the ingredients to build up in your dog's system.</p>"
          }
        },
        "faq_sc2": {
          "type": "item",
          "settings": {
            "heading": "Is this safe for dogs with fish or salmon sensitivities?",
            "content": "<p>Our Skin &amp; Coat formula contains salmon oil. If your dog has a known sensitivity to fish or salmon, please consult your veterinarian before use.</p>"
          }
        },
        "faq_sc3": {
          "type": "item",
          "settings": {
            "heading": "Can I give this alongside other Tailspark supplements?",
            "content": "<p>Yes — our formulas are designed to complement each other. If your dog is already receiving Omega-3 from another source, consult your veterinarian about total daily intake.</p>"
          }
        },
        "faq_sc4": {
          "type": "item",
          "settings": {
            "heading": "What age dogs can take Skin & Coat?",
            "content": "<p>Skin &amp; Coat is suitable for dogs of all ages. If your dog has a specific health condition, consult your veterinarian before use.</p>"
          }
        },
        "faq_sc5": {
          "type": "item",
          "settings": {
            "heading": "Will Skin & Coat help with my dog's itching?",
            "content": "<p>Our formula contains Omega-3 fatty acids, Vitamin E, and Linoleic Acid which help support healthy skin barrier function and overall skin health. For dogs with persistent itching or skin conditions, we recommend consulting your veterinarian.</p>"
          }
        },
        "faq_sc6": {
          "type": "item",
          "settings": {
            "heading": "How long does shipping take?",
            "content": "<p>Standard shipping is free on every order with no minimum. Orders are processed within 1 business day and typically arrive within 3 to 5 business days. You will receive a tracking email once your order ships.</p>"
          }
        },
        "faq_sc7": {
          "type": "item",
          "settings": {
            "heading": "Can I subscribe and save on Skin & Coat?",
            "content": "<p>Yes — our Subscribe &amp; Save program gives you 15% off every delivery plus free standard shipping. You can skip, pause, or cancel anytime from your account with no fees or penalties.</p>"
          }
        }
      },
