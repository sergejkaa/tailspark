{%- liquid
        assign upsell_limit = block.settings.free_shipping_upsell_limit | default: 6
        assign upsell_source_mode = block.settings.free_shipping_upsell_source | default: 'auto'
        assign upsell_products = blank

        if upsell_source_mode == 'products' or upsell_source_mode == 'auto'
          if block.settings.free_shipping_upsell_products != blank
            assign upsell_products = block.settings.free_shipping_upsell_products
          endif
        endif

        if upsell_products == blank and upsell_source_mode != 'products' and block.settings.free_shipping_upsell_collection != blank
          assign upsell_handle = block.settings.free_shipping_upsell_collection.handle | default: block.settings.free_shipping_upsell_collection
          if upsell_handle != blank and collections[upsell_handle] != blank
            assign upsell_products = collections[upsell_handle].products
          elsif block.settings.free_shipping_upsell_collection.products != blank
            assign upsell_products = block.settings.free_shipping_upsell_collection.products
          endif
        endif
      -%}

{%- if upsell_products == blank and request.design_mode -%}
  {%- assign _ph_heading = block.settings.free_shipping_upsell_heading | default: 'Recommended for you' -%}
  {%- assign _ph_color = block.settings.free_shipping_upsell_heading_color | default: '#64748b' -%}
  {%- assign _ph_size = block.settings.free_shipping_upsell_heading_size | default: 13 -%}
  <div style="margin-top:10px;padding-top:8px;border-top:1px solid rgba(15,23,42,0.1);">
    <div style="font-size:{{ _ph_size }}px;font-weight:600;color:{{ _ph_color }};margin-bottom:8px;letter-spacing:0.01em;">{{ _ph_heading }}</div>
    <div style="display:grid;grid-auto-flow:column;grid-auto-columns:100%;overflow:hidden;border-radius:10px;">
      <div style="display:grid;grid-template-columns:56px 1fr 60px;align-items:center;gap:10px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:8px 18px;min-height:88px;opacity:0.7;">
        <div style="width:56px;height:56px;border-radius:8px;background:#e2e8f0;flex-shrink:0;"></div>
        <div>
          <div style="height:11px;background:#e2e8f0;border-radius:4px;width:75%;margin-bottom:7px;"></div>
          <div style="height:9px;background:#e2e8f0;border-radius:4px;width:45%;"></div>
        </div>
        <div style="width:60px;height:32px;border-radius:6px;border:1px solid #cbd5e1;background:#fff;"></div>
      </div>
    </div>
    <p style="font-size:11px;color:#94a3b8;margin:6px 0 0;text-align:center;">&#x2197; Add products or a collection in block settings</p>
  </div>
{%- else -%}
        {%- assign cart_product_ids = cart.items | map: 'product_id' -%}
        {%- assign upsell_products_count = upsell_products.size | default: 0 -%}
        {%- assign enforce_hide_current_product = false -%}
        {%- assign enforce_hide_in_cart = false -%}
        {%- if block.settings.free_shipping_upsell_hide_current_product and upsell_products_count > 1 -%}
          {%- assign enforce_hide_current_product = true -%}
        {%- endif -%}
        {%- if block.settings.free_shipping_upsell_hide_in_cart and upsell_products_count > 1 -%}
          {%- assign enforce_hide_in_cart = true -%}
        {%- endif -%}
        {%- assign current_product_id = product.id -%}
        {%- assign upsell_heading_text = block.settings.free_shipping_upsell_heading | default: 'Recommended for you' -%}
        {%- assign upsell_heading_color = block.settings.free_shipping_upsell_heading_color | default: '#64748b' -%}
        {%- assign upsell_heading_weight = block.settings.free_shipping_upsell_heading_weight | default: '600' -%}
        {%- assign upsell_heading_letter_spacing = block.settings.free_shipping_upsell_heading_letter_spacing | default: 0.2 -%}
        {%- assign upsell_show_image = block.settings.free_shipping_upsell_show_image | default: true -%}
        {%- assign upsell_image_size = block.settings.free_shipping_upsell_image_size | default: 56 -%}
        {%- assign upsell_image_format = block.settings.free_shipping_upsell_image_format | default: 'square' -%}
        {%- assign upsell_image_width = upsell_image_size -%}
        {%- assign upsell_image_height = upsell_image_size -%}
        {%- if upsell_image_format == 'portrait_9_16' -%}
          {%- assign upsell_image_width = upsell_image_size | times: 9 | divided_by: 16 -%}
          {%- assign upsell_image_height = upsell_image_size -%}
          {%- if upsell_image_width < 24 -%}{%- assign upsell_image_width = 24 -%}{%- endif -%}
        {%- endif -%}
        {%- assign upsell_image_request_base = upsell_image_width -%}
        {%- if upsell_image_height > upsell_image_request_base -%}
          {%- assign upsell_image_request_base = upsell_image_height -%}
        {%- endif -%}
        {%- assign upsell_image_request_width = upsell_image_request_base | times: 2 -%}
        {%- assign upsell_image_width_md = upsell_image_width -%}
        {%- assign upsell_image_height_md = upsell_image_height -%}
        {%- if upsell_image_width > upsell_image_height and upsell_image_width > 48 -%}
          {%- assign upsell_image_height_md = upsell_image_height | times: 48 | divided_by: upsell_image_width -%}
          {%- assign upsell_image_width_md = 48 -%}
        {%- elsif upsell_image_height >= upsell_image_width and upsell_image_height > 48 -%}
          {%- assign upsell_image_width_md = upsell_image_width | times: 48 | divided_by: upsell_image_height -%}
          {%- assign upsell_image_height_md = 48 -%}
        {%- endif -%}
        {%- assign upsell_item_bg_color = block.settings.free_shipping_upsell_item_bg_color | default: '#f8fafc' -%}
        {%- assign upsell_block_border_color = block.settings.free_shipping_upsell_block_border_color | default: 'rgba(15, 23, 42, 0.1)' -%}
        {%- assign upsell_item_border_color = block.settings.free_shipping_upsell_item_border_color | default: '#e2e8f0' -%}
        {%- assign upsell_chevron_color = block.settings.free_shipping_upsell_chevron_color | default: 'rgba(15, 23, 42, 0.72)' -%}
        {%- assign upsell_dot_active_color = block.settings.free_shipping_upsell_dot_active_color | default: '#0284c7' -%}
        {%- assign upsell_dot_inactive_color = block.settings.free_shipping_upsell_dot_inactive_color | default: 'rgba(148, 163, 184, 0.45)' -%}
        {%- assign upsell_meta_gap = block.settings.free_shipping_upsell_meta_gap | default: 6 -%}
        {%- assign upsell_heading_size = block.settings.free_shipping_upsell_heading_size | default: 13 -%}
        {%- assign upsell_title_size = block.settings.free_shipping_upsell_title_size | default: 13 -%}
        {%- assign upsell_title_color = block.settings.free_shipping_upsell_title_color | default: '#0f172a' -%}
        {%- assign upsell_title_weight = block.settings.free_shipping_upsell_title_weight | default: '600' -%}
        {%- assign upsell_price_size = block.settings.free_shipping_upsell_price_size | default: 12 -%}
        {%- assign upsell_price_color = block.settings.free_shipping_upsell_price_color | default: '#64748b' -%}
        {%- assign upsell_price_weight = block.settings.free_shipping_upsell_price_weight | default: '500' -%}
        {%- assign upsell_variant_size = block.settings.free_shipping_upsell_variant_size | default: 11 -%}
        {%- assign upsell_variant_text_color = block.settings.free_shipping_upsell_variant_text_color | default: '#0f172a' -%}
        {%- assign upsell_variant_bg_color = block.settings.free_shipping_upsell_variant_bg_color | default: '#ffffff' -%}
        {%- assign upsell_variant_border_color = block.settings.free_shipping_upsell_variant_border_color | default: '#cbd5e1' -%}
        {%- assign upsell_button_size = block.settings.free_shipping_upsell_button_size | default: 12 -%}
        {%- assign upsell_button_text_color = block.settings.free_shipping_upsell_button_text_color | default: '#0f172a' -%}
        {%- assign upsell_button_bg_color = block.settings.free_shipping_upsell_button_bg_color | default: '#ffffff' -%}
        {%- assign upsell_button_border_color = block.settings.free_shipping_upsell_button_border_color | default: '#cbd5e1' -%}
        {%- assign upsell_button_weight = block.settings.free_shipping_upsell_button_weight | default: '600' -%}
        {%- assign upsell_empty_text = block.settings.free_shipping_upsell_empty_text | default: 'Add Product' -%}
        {%- if upsell_heading_text == blank -%}
          {%- assign upsell_heading_text = 'Recommended for you' -%}
        {%- endif -%}
        {%- if upsell_heading_text == 'Add one to unlock free shipping faster' -%}
          {%- assign upsell_heading_text = 'Recommended for you' -%}
        {%- endif -%}
        {%- if upsell_heading_text == 'Add one more item to unlock free shipping' -%}
          {%- assign upsell_heading_text = 'Recommended for you' -%}
        {%- endif -%}
        {%- assign rendered_upsell = 0 -%}
        {%- capture upsell_items_markup -%}
          {%- for upsell_product in upsell_products -%}
            {%- assign candidate_product = upsell_product -%}
            {%- if candidate_product.id == blank and all_products[upsell_product] != blank -%}
              {%- assign candidate_product = all_products[upsell_product] -%}
            {%- endif -%}
            {%- if candidate_product == blank or candidate_product.id == blank -%}{% continue %}{%- endif -%}
            {%- if candidate_product.available == false -%}{% continue %}{%- endif -%}
            {%- if enforce_hide_current_product and current_product_id != blank and candidate_product.id == current_product_id -%}{% continue %}{%- endif -%}
            {%- if enforce_hide_in_cart and cart_product_ids contains candidate_product.id -%}{% continue %}{%- endif -%}
              {%- assign first_variant = candidate_product.selected_or_first_available_variant -%}
              {%- if first_variant == blank -%}{% continue %}{%- endif -%}
              {%- assign first_variant_increment = first_variant.quantity_rule.increment | default: 1 -%}
              {%- assign first_variant_min = first_variant.quantity_rule.min | default: 1 -%}
              {%- assign first_variant_qty = first_variant_increment -%}
              {%- if first_variant_min > first_variant_qty -%}
                {%- assign first_variant_qty = first_variant_min -%}
              {%- endif -%}
              <div class="ppu-upsell__item{% unless upsell_show_image %} ppu-upsell__item--no-image{% endunless %}" role="listitem">
                {%- if upsell_show_image -%}
                  <a class="ppu-upsell__image" href="{{ candidate_product.url }}" draggable="false">
                    {%- if candidate_product.featured_image -%}
                    <img
                      src="{{ candidate_product.featured_image | image_url: width: upsell_image_request_width }}"
                      alt="{{ candidate_product.featured_image.alt | escape }}"
                      loading="lazy"
                      width="{{ upsell_image_width }}"
                      height="{{ upsell_image_height }}"
                      draggable="false"
                      style="object-position: {{ block.settings.free_shipping_upsell_focus_x | default: 50 }}% {{ block.settings.free_shipping_upsell_focus_y | default: 50 }}%;"
                    >
                  {%- else -%}
                    <span class="ppu-upsell__placeholder">+</span>
                  {%- endif -%}
                </a>
                {%- endif -%}
              <div class="ppu-upsell__meta{% unless upsell_show_image %} ppu-upsell__meta--full{% endunless %}">
                <a class="ppu-upsell__title" href="{{ candidate_product.url }}" draggable="false">{{ candidate_product.title }}</a>
                {%- if candidate_product.variants.size > 1 -%}
                  <select class="ppu-upsell__variant" aria-label="Choose variant">
                    {%- for variant in candidate_product.variants -%}
                      <option
                        value="{{ variant.id }}"
                        data-price="{{ variant.price | money | escape }}"
                        data-qty-increment="{{ variant.quantity_rule.increment | default: 1 }}"
                        data-qty-min="{{ variant.quantity_rule.min | default: 1 }}"
                        {% if variant.id == first_variant.id %}selected{% endif %}
                        {% unless variant.available %}disabled{% endunless %}
                      >
                        {{ variant.title }}{% unless variant.available %} - Sold out{% endunless %}
                      </option>
                    {%- endfor -%}
                  </select>
                {%- endif -%}
                <div class="ppu-upsell__price">
                  {%- if candidate_product.price_varies -%}
                    From {{ candidate_product.price_min | money }}
                  {%- else -%}
                    {{ candidate_product.price | money }}
                  {%- endif -%}
                </div>
              </div>
              <button
                type="button"
                class="ppu-upsell__add"
                data-variant-id="{{ first_variant.id }}"
                data-quantity="{{ first_variant_qty }}"
                data-default-label="{{ block.settings.free_shipping_upsell_button | escape }}"
                aria-label="{{ block.settings.free_shipping_upsell_button }} {{ candidate_product.title | escape }}"
                {% unless first_variant.available %}disabled{% endunless %}
              >
                <span class="ppu-upsell__add-icon" aria-hidden="true">+</span>
                <span class="ppu-upsell__add-text">{{ block.settings.free_shipping_upsell_button }}</span>
              </button>
            </div>
            {%- assign rendered_upsell = rendered_upsell | plus: 1 -%}
            {%- if rendered_upsell >= upsell_limit -%}{%- break -%}{%- endif -%}
          {%- endfor -%}
        {%- endcapture -%}

        {%- assign upsell_slides_desktop = block.settings.free_shipping_upsell_slides_desktop | default: 1.1 | plus: 0 -%}
        {%- assign upsell_slides_mobile = block.settings.free_shipping_upsell_slides_mobile | default: 1 | plus: 0 -%}
        {%- if upsell_slides_desktop < 1 -%}{%- assign upsell_slides_desktop = 1 -%}{%- endif -%}
        {%- if upsell_slides_mobile < 1 -%}{%- assign upsell_slides_mobile = 1 -%}{%- endif -%}
        {%- if rendered_upsell == 1 -%}
          {%- assign upsell_slides_desktop = 1 -%}
          {%- assign upsell_slides_mobile = 1 -%}
        {%- endif -%}
        <div
          class="ppu-upsell{% unless upsell_show_image %} ppu-upsell--hide-image{% endunless %}{% if rendered_upsell == 0 %} ppu-upsell--empty{% endif %}"
          style="
            --ppu-image-size: {{ upsell_image_size }}px;
            --ppu-image-width: {{ upsell_image_width }}px;
            --ppu-image-height: {{ upsell_image_height }}px;
            --ppu-image-width-md: {{ upsell_image_width_md }}px;
            --ppu-image-height-md: {{ upsell_image_height_md }}px;
            --ppu-block-border: {{ upsell_block_border_color }};
            --ppu-item-bg: {{ upsell_item_bg_color }};
            --ppu-item-border: {{ upsell_item_border_color }};
            --ppu-chevron-color: {{ upsell_chevron_color }};
            --ppu-dot-active: {{ upsell_dot_active_color }};
            --ppu-dot-inactive: {{ upsell_dot_inactive_color }};
            --ppu-meta-gap: {{ upsell_meta_gap }}px;
            --ppu-heading-size: {{ upsell_heading_size }}px;
            --ppu-heading-weight: {{ upsell_heading_weight }};
            --ppu-heading-letter-spacing: {{ upsell_heading_letter_spacing }}px;
            --ppu-title-size: {{ upsell_title_size }}px;
            --ppu-title-color: {{ upsell_title_color }};
            --ppu-title-weight: {{ upsell_title_weight }};
            --ppu-price-size: {{ upsell_price_size }}px;
            --ppu-price-color: {{ upsell_price_color }};
            --ppu-price-weight: {{ upsell_price_weight }};
            --ppu-variant-size: {{ upsell_variant_size }}px;
            --ppu-variant-color: {{ upsell_variant_text_color }};
            --ppu-variant-bg: {{ upsell_variant_bg_color }};
            --ppu-variant-border: {{ upsell_variant_border_color }};
            --ppu-button-size: {{ upsell_button_size }}px;
            --ppu-button-color: {{ upsell_button_text_color }};
            --ppu-button-bg: {{ upsell_button_bg_color }};
            --ppu-button-border: {{ upsell_button_border_color }};
            --ppu-button-weight: {{ upsell_button_weight }};
          "
        >
          <div class="ppu-upsell__header" style="color: {{ upsell_heading_color }};">{{ upsell_heading_text }}</div>
          <div class="ppu-upsell__viewport">
            {%- if rendered_upsell > 0 -%}
              <div
                class="ppu-upsell__slider"
                role="list"
                aria-label="{{ upsell_heading_text | escape }}"
                data-real-count="{{ rendered_upsell }}"
                style="--ppu-upsell-visible-desktop: {{ upsell_slides_desktop }}; --ppu-upsell-visible-mobile: {{ upsell_slides_mobile }};"
              >
                {{ upsell_items_markup }}
              </div>
              {%- if rendered_upsell > 1 -%}
                {%- assign show_upsell_arrows = false -%}
                {%- if block.settings.free_shipping_upsell_arrows_desktop or block.settings.free_shipping_upsell_arrows_mobile -%}
                  {%- assign show_upsell_arrows = true -%}
                {%- endif -%}
                {%- if show_upsell_arrows -%}
                  <div class="ppu-upsell__controls{% unless block.settings.free_shipping_upsell_arrows_desktop %} ppu-upsell__controls--hide-desktop{% endunless %}{% unless block.settings.free_shipping_upsell_arrows_mobile %} ppu-upsell__controls--hide-mobile{% endunless %}">
                    <button type="button" class="ppu-upsell__arrow ppu-upsell__arrow--prev" data-direction="prev" aria-label="Previous upsell slide">
                      <span aria-hidden="true">&#8249;</span>
                    </button>
                    <button type="button" class="ppu-upsell__arrow ppu-upsell__arrow--next" data-direction="next" aria-label="Next upsell slide">
                      <span aria-hidden="true">&#8250;</span>
                    </button>
                  </div>
                {%- endif -%}
              {%- endif -%}
            {%- else -%}
              <div class="ppu-upsell__empty" role="status" aria-live="polite">
                <span class="ppu-upsell__empty-icon" aria-hidden="true">+</span>
                <span class="ppu-upsell__empty-text">{{ upsell_empty_text }}</span>
              </div>
            {%- endif -%}
          </div>
          {%- if rendered_upsell > 1 -%}
            <div class="ppu-upsell__dots" aria-hidden="true">
              {%- for i in (1..rendered_upsell) -%}
                <button
                  type="button"
                  class="ppu-upsell__dot{% if forloop.first %} is-active{% endif %}"
                  data-index="{{ i }}"
                  aria-label="Go to upsell {{ i }}"
                ></button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      
<style>
    .ppu-upsell {
      margin-top: 10px;
      padding-top: 8px;
      border-top: 1px solid var(--ppu-block-border, rgba(15, 23, 42, 0.1));
      display: grid;
      gap: 8px;
      width: 100%;
      max-width: 100%;
      min-width: 0;
    }

    .ppu-upsell__header {
      font-size: var(--ppu-heading-size, 13px);
      color: #64748b;
      font-weight: var(--ppu-heading-weight, 600);
      letter-spacing: var(--ppu-heading-letter-spacing, 0.2px);
    }

    .ppu-upsell__viewport {
      position: relative;
      width: 100%;
      max-width: 100%;
      min-width: 0;
      overflow: hidden;
      padding: 0 1px 0 0;
      box-sizing: border-box;
    }

    .ppu-upsell__slider {
      --ppu-upsell-gap: 8px;
      --ppu-upsell-visible-mobile: 1;
      --ppu-upsell-visible-desktop: 1.1;
      --ppu-upsell-visible: var(--ppu-upsell-visible-mobile);
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: calc(
        (100% - (var(--ppu-upsell-gap) * (var(--ppu-upsell-visible) - 1)))
        / var(--ppu-upsell-visible)
      );
      column-gap: var(--ppu-upsell-gap);
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      width: 100%;
      max-width: 100%;
      min-width: 0;
      box-sizing: border-box;
      padding-right: 1px;
      scroll-padding-left: 0;
      scroll-padding-right: 1px;
      scrollbar-width: none;
      -ms-overflow-style: none;
      touch-action: pan-x;
      overscroll-behavior-x: contain;
    }

    .ppu-upsell__slider[data-real-count='1'] {
      --ppu-upsell-visible: 1;
      grid-auto-columns: 100%;
    }

    .ppu-upsell__slider::-webkit-scrollbar {
      display: none;
    }

    .ppu-upsell__item {
      scroll-snap-align: start;
      scroll-snap-stop: always;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 10px;
      background: var(--ppu-item-bg, #f8fafc);
      border: 1px solid var(--ppu-item-border, #e2e8f0);
      border-radius: 10px;
      padding: 4px 18px;
      min-height: 88px;
      width: 100%;
      max-width: 100%;
      min-width: 0;
      box-sizing: border-box;
    }

    .ppu-upsell__item--no-image {
      grid-template-columns: 1fr auto;
    }

    .ppu-upsell__image,
    .ppu-upsell__meta,
    .ppu-upsell__add {
      align-self: center;
    }

    .ppu-upsell__image {
      width: var(--ppu-image-width, var(--ppu-image-size, 56px));
      height: var(--ppu-image-height, var(--ppu-image-size, 56px));
      border-radius: 8px;
      overflow: hidden;
      background: #e2e8f0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .ppu-upsell__image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      -webkit-user-drag: none;
    }

    .ppu-upsell__image,
    .ppu-upsell__title {
      -webkit-user-drag: none;
    }

    .ppu-upsell__placeholder {
      color: #94a3b8;
      font-weight: 700;
      font-size: 20px;
    }

    .ppu-upsell__meta {
      display: grid;
      gap: var(--ppu-meta-gap, 6px);
      min-width: 0;
      width: 100%;
      max-width: 90%;
      align-content: center;
    }

    .ppu-upsell__meta--full {
      max-width: 100%;
    }

    .ppu-upsell__empty {
      min-height: 88px;
      border: 1px dashed var(--ppu-item-border, #e2e8f0);
      border-radius: 10px;
      background: var(--ppu-item-bg, #f8fafc);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 18px;
      color: var(--ppu-price-color, #64748b);
      font-size: var(--ppu-price-size, 12px);
      font-weight: 600;
      text-align: center;
      box-sizing: border-box;
    }

    .ppu-upsell__empty-icon {
      width: 22px;
      height: 22px;
      border-radius: 999px;
      border: 1px solid currentColor;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 14px;
      line-height: 1;
    }

    .ppu-upsell__empty-text {
      line-height: 1.3;
    }

    .ppu-upsell__variant {
      width: 100%;
      min-height: 28px;
      margin-top: 2px;
      border-radius: 8px;
      border: 1px solid var(--ppu-variant-border, #cbd5e1);
      background: var(--ppu-variant-bg, #ffffff);
      color: var(--ppu-variant-color, #0f172a);
      font-size: var(--ppu-variant-size, 11px);
      line-height: 1.2;
      padding: 4px 8px;
      outline: none;
      transition: border-color 140ms ease, background 140ms ease;
    }

    .ppu-upsell__variant:focus,
    .ppu-upsell__variant:focus-visible {
      border-color: #94a3b8;
      background: #f8fafc;
