{%- comment -%}
  Product weight/count/flavor pills with clean icons (weight, bone, leaf).
  Values resolved by product handle. Usage: {% render 'product-weight-badge' %}
{%- endcomment -%}
{%- liquid
  case product.handle
    when 'tailspark-hip-joint'
      assign p_oz = '8.47 OZ (240g)'
      assign p_chews = '60 Soft Chews'
      assign p_flavor = 'Natural duck flavor'
    when 'tailspark-skin-coat'
      assign p_oz = '4.94 OZ (140g)'
      assign p_chews = '70 Soft Chews'
      assign p_flavor = 'Natural vegetable flavor'
    when 'tailspark-multivitamin'
      assign p_oz = '7.41 OZ (210g)'
      assign p_chews = '60 Soft Chews'
      assign p_flavor = 'Natural vegetable flavor'
    when 'tailspark-probiotic'
      assign p_oz = '4.75 OZ (135g)'
      assign p_chews = '90 Soft Chews'
      assign p_flavor = 'Natural duck flavor'
  endcase
-%}
<div class="ts-wbadges" style="display:flex;flex-wrap:wrap;gap:8px;margin:4px 0;">
  <div class="ts-wbadge" style="display:inline-flex;align-items:center;gap:7px;padding:6px 14px 6px 10px;border-radius:50px;background:#FFF5EF;font-size:13px;font-weight:600;color:#333;border:1px solid #FFD4B8;">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FF6700" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0"><circle cx="12" cy="5" r="3"/><path d="M6.5 8a2 2 0 0 0-1.9 1.46L2.1 18.5A2 2 0 0 0 4 21h16a2 2 0 0 0 1.93-2.54L19.4 9.5A2 2 0 0 0 17.48 8Z"/></svg>
    {{ p_oz }}
  </div>
  <div class="ts-wbadge" style="display:inline-flex;align-items:center;gap:7px;padding:6px 14px 6px 10px;border-radius:50px;background:#FFF5EF;font-size:13px;font-weight:600;color:#333;border:1px solid #FFD4B8;">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FF6700" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.07-2.14-.22-4.05 2-4.5.5 0 1 .5 1 1a2.5 2.5 0 0 0 2.5 2.5c1.38 0 2-.5 3-1 2.14-1.07 4.05-.22 4.5 2 0 .5-.5 1-1 1a2.5 2.5 0 0 0-2.5 2.5c0 1.38.5 2 1 3 1.07 2.14.22 4.05-2 4.5-.5 0-1-.5-1-1a2.5 2.5 0 0 0-2.5-2.5c-1.38 0-2 .5-3 1-2.14 1.07-4.05.22-4.5-2 0-.5.5-1 1-1z"/></svg>
    {{ p_chews }}
  </div>
  <div class="ts-wbadge" style="display:inline-flex;align-items:center;gap:7px;padding:6px 14px 6px 10px;border-radius:50px;background:#FFF5EF;font-size:13px;font-weight:600;color:#333;border:1px solid #FFD4B8;">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#FF6700" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>
    {{ p_flavor }}
  </div>
</div>
