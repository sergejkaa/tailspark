{%- comment -%}
  Product weight/count/flavor pills — TEXT ONLY (no icons, per client).
  Values resolved by product handle. Usage: {% render 'product-weight-badge' %}
{%- endcomment -%}
{%- liquid
  case product.handle
    when 'tailspark-hip-joint'
      assign p_oz = '8.47 OZ (240g)'
      assign p_chews = '60 Soft Chews'
      assign p_flavor = 'Natural duck flavor'
    when 'tailspark-skin-coat'
      assign p_oz = '4.94 OZ (140g)'
      assign p_chews = '70 Soft Chews'
      assign p_flavor = 'Natural vegetable flavor'
    when 'tailspark-multivitamin'
      assign p_oz = '7.41 OZ (210g)'
      assign p_chews = '60 Soft Chews'
      assign p_flavor = 'Natural vegetable flavor'
    when 'tailspark-probiotic'
      assign p_oz = '4.75 OZ (135g)'
      assign p_chews = '90 Soft Chews'
      assign p_flavor = 'Natural duck flavor'
  endcase
-%}
<div class="ts-wbadges" style="display:flex;flex-wrap:wrap;gap:8px;margin:4px 0;">
  <div class="ts-wbadge" style="display:inline-flex;align-items:center;padding:6px 16px;border-radius:50px;background:#FFF5EF;font-size:13px;font-weight:600;color:#333;border:1px solid #FFD4B8;">{{ p_oz }}</div>
  <div class="ts-wbadge" style="display:inline-flex;align-items:center;padding:6px 16px;border-radius:50px;background:#FFF5EF;font-size:13px;font-weight:600;color:#333;border:1px solid #FFD4B8;">{{ p_chews }}</div>
  <div class="ts-wbadge" style="display:inline-flex;align-items:center;padding:6px 16px;border-radius:50px;background:#FFF5EF;font-size:13px;font-weight:600;color:#333;border:1px solid #FFD4B8;">{{ p_flavor }}</div>
</div>
