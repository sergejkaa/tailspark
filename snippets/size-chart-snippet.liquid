{%- liquid
  assign chart_uid = section.id

  if block != blank
    assign chart_uid = section.id | append: '-' | append: block.id
    assign size_chart_mode = block.settings.size_chart_mode | default: 'image'
    assign trigger_style = block.settings.size_chart_trigger_style | default: 'link'
    assign trigger_text = block.settings.size_chart_trigger_text | default: 'Size chart'
    assign dialog_heading = block.settings.size_chart_heading | default: trigger_text
    assign size_chart_description = block.settings.size_chart_description
    assign size_chart_image = block.settings.size_chart_image
    assign table_headers_raw = block.settings.size_chart_table_headers
    assign table_rows_raw = block.settings.size_chart_table_rows
    assign size_chart_footer = block.settings.size_chart_footer
    assign modal_width = block.settings.size_chart_modal_width
    assign trigger_text_color = block.settings.size_chart_trigger_text_color
    assign trigger_bg_color = block.settings.size_chart_trigger_bg_color
    assign trigger_border_color = block.settings.size_chart_trigger_border_color
    assign modal_bg_color = block.settings.size_chart_modal_bg_color
    assign modal_text_color = block.settings.size_chart_modal_text_color
    assign heading_color = block.settings.size_chart_heading_color
    assign table_header_bg_color = block.settings.size_chart_table_header_bg_color
    assign table_header_text_color = block.settings.size_chart_table_header_text_color
    assign table_row_bg_color = block.settings.size_chart_table_row_bg_color
    assign table_alt_row_bg_color = block.settings.size_chart_table_alt_row_bg_color
    assign table_text_color = block.settings.size_chart_table_text_color
    assign table_border_color = block.settings.size_chart_table_border_color
    assign close_bg_color = block.settings.size_chart_close_bg_color
    assign close_text_color = block.settings.size_chart_close_text_color
  else
    assign size_chart_mode = section.settings.size_chart_mode | default: 'image'
    assign trigger_style = section.settings.size_chart_trigger_style | default: 'link'
    assign trigger_text = section.settings.size_chart_trigger_text | default: 'Size chart'
    assign dialog_heading = section.settings.size_chart_heading | default: trigger_text
    assign size_chart_description = section.settings.size_chart_description
    assign size_chart_image = section.settings.size_chart_image
    assign table_headers_raw = section.settings.size_chart_table_headers
    assign table_rows_raw = section.settings.size_chart_table_rows
    assign size_chart_footer = section.settings.size_chart_footer
    assign modal_width = section.settings.size_chart_modal_width
    assign trigger_text_color = section.settings.size_chart_trigger_text_color
    assign trigger_bg_color = section.settings.size_chart_trigger_bg_color
    assign trigger_border_color = section.settings.size_chart_trigger_border_color
    assign modal_bg_color = section.settings.size_chart_modal_bg_color
    assign modal_text_color = section.settings.size_chart_modal_text_color
    assign heading_color = section.settings.size_chart_heading_color
    assign table_header_bg_color = section.settings.size_chart_table_header_bg_color
    assign table_header_text_color = section.settings.size_chart_table_header_text_color
    assign table_row_bg_color = section.settings.size_chart_table_row_bg_color
    assign table_alt_row_bg_color = section.settings.size_chart_table_alt_row_bg_color
    assign table_text_color = section.settings.size_chart_table_text_color
    assign table_border_color = section.settings.size_chart_table_border_color
    assign close_bg_color = section.settings.size_chart_close_bg_color
    assign close_text_color = section.settings.size_chart_close_text_color
  endif

  assign table_headers = table_headers_raw | strip | split: '|'
  assign table_rows = table_rows_raw | newline_to_br | split: '<br />'
  assign image_alt = size_chart_image.alt | default: dialog_heading
  assign has_size_chart_content = false

  if size_chart_mode == 'image' and size_chart_image != blank
    assign has_size_chart_content = true
  elsif size_chart_mode == 'manual' and table_headers_raw != blank and table_rows_raw != blank
    assign has_size_chart_content = true
  elsif request.design_mode
    assign has_size_chart_content = true
  endif

  assign dialog_id = 'SizeChartDialog-' | append: chart_uid
  assign dialog_title_id = dialog_id | append: '-title'
-%}

{%- if has_size_chart_content -%}
  <style>
    .size-chart-{{ chart_uid }} {
      --size-chart-trigger-text: {{ trigger_text_color }};
      --size-chart-trigger-bg: {{ trigger_bg_color }};
      --size-chart-trigger-border: {{ trigger_border_color }};
      --size-chart-modal-bg: {{ modal_bg_color }};
      --size-chart-modal-text: {{ modal_text_color }};
      --size-chart-heading: {{ heading_color }};
      --size-chart-header-bg: {{ table_header_bg_color }};
      --size-chart-header-text: {{ table_header_text_color }};
      --size-chart-row-bg: {{ table_row_bg_color }};
      --size-chart-row-alt-bg: {{ table_alt_row_bg_color }};
      --size-chart-table-text: {{ table_text_color }};
      --size-chart-table-border: {{ table_border_color }};
      --size-chart-close-bg: {{ close_bg_color }};
      --size-chart-close-text: {{ close_text_color }};
      --size-chart-modal-width: min({{ modal_width }}px, calc(100vw - 2.4rem));
      margin-top: 1rem;
    }

    .size-chart-{{ chart_uid }} .size-chart__trigger {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.35rem;
      color: var(--size-chart-trigger-text);
      cursor: pointer;
      font-size: 0.95rem;
      font-weight: 600;
      transition: opacity 0.2s ease, transform 0.2s ease;
    }

    .size-chart-{{ chart_uid }} .size-chart__trigger:hover {
      opacity: 0.82;
      transform: translateY(-1px);
    }

    .size-chart-{{ chart_uid }} .size-chart__trigger--link {
      padding: 0;
      background: transparent;
      border: 0;
      text-decoration: underline;
      text-underline-offset: 0.2em;
    }

    .size-chart-{{ chart_uid }} .size-chart__trigger--button {
      padding: 0.7rem 1.1rem;
      border: 1px solid var(--size-chart-trigger-border);
      border-radius: 999px;
      background: var(--size-chart-trigger-bg);
      text-decoration: none;
    }

    .size-chart-{{ chart_uid }} .size-chart__dialog {
      width: var(--size-chart-modal-width);
      max-width: none;
      margin: auto;
      padding: 0;
      border: 0;
      background: transparent;
      overflow: visible;
    }

    .size-chart-{{ chart_uid }} .size-chart__dialog::backdrop {
      background: rgba(15, 23, 42, 0.58);
    }

    .size-chart-{{ chart_uid }} .size-chart__dialog[open]::backdrop {
      animation: size-chart-backdrop-enter-{{ chart_uid }} 0.28s ease-out;
    }

    .size-chart-{{ chart_uid }} .size-chart__panel {
      position: relative;
      max-height: calc(100vh - 2.4rem);
      overflow-y: auto;
      padding: 1.4rem;
      border-radius: 24px;
      background: var(--size-chart-modal-bg);
      color: var(--size-chart-modal-text);
      box-shadow: 0 24px 60px rgba(15, 23, 42, 0.28);
    }

    .size-chart-{{ chart_uid }} .size-chart__dialog[open] .size-chart__panel {
      animation: size-chart-panel-enter-{{ chart_uid }} 0.42s cubic-bezier(0.22, 1, 0.36, 1);
      transform-origin: center top;
    }

    .size-chart-{{ chart_uid }} .size-chart__close {
      position: sticky;
      top: 0;
      margin-left: auto;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2.5rem;
      height: 2.5rem;
      border: 0;
      border-radius: 999px;
      background: var(--size-chart-close-bg);
      color: var(--size-chart-close-text);
      cursor: pointer;
      font-size: 1rem;
      font-weight: 700;
      line-height: 1;
      z-index: 1;
    }

    .size-chart-{{ chart_uid }} .size-chart__title {
      margin: 0 0 0.9rem;
      color: var(--size-chart-heading);
      font-size: 1.6rem;
      line-height: 1.15;
    }

    .size-chart-{{ chart_uid }} .size-chart__description,
    .size-chart-{{ chart_uid }} .size-chart__footer {
      color: var(--size-chart-modal-text);
    }

    .size-chart-{{ chart_uid }} .size-chart__description {
      margin-bottom: 1rem;
    }

    .size-chart-{{ chart_uid }} .size-chart__footer {
      margin-top: 1rem;
    }

    .size-chart-{{ chart_uid }} .size-chart__image-wrap {
      overflow: hidden;
      border-radius: 18px;
      border: 1px solid var(--size-chart-table-border);
    }

    .size-chart-{{ chart_uid }} .size-chart__image {
      display: block;
      width: 100%;
      height: auto;
    }

    .size-chart-{{ chart_uid }} .size-chart__table-wrap {
      overflow-x: auto;
      border-radius: 18px;
      border: 1px solid var(--size-chart-table-border);
    }

    .size-chart-{{ chart_uid }} .size-chart__table {
      width: 100%;
      min-width: 480px;
      border-collapse: collapse;
      color: var(--size-chart-table-text);
    }

    .size-chart-{{ chart_uid }} .size-chart__table thead th {
      background: var(--size-chart-header-bg);
      color: var(--size-chart-header-text);
      font-weight: 700;
      text-align: left;
    }

    .size-chart-{{ chart_uid }} .size-chart__table th,
    .size-chart-{{ chart_uid }} .size-chart__table td {
      padding: 0.8rem 1rem;
      border: 1px solid var(--size-chart-table-border);
    }

    .size-chart-{{ chart_uid }} .size-chart__table tbody th {
      font-weight: 700;
      text-align: left;
    }

    .size-chart-{{ chart_uid }} .size-chart__table tbody tr:nth-child(odd) td,
    .size-chart-{{ chart_uid }} .size-chart__table tbody tr:nth-child(odd) th {
      background: var(--size-chart-row-bg);
    }

    .size-chart-{{ chart_uid }} .size-chart__table tbody tr:nth-child(even) td,
    .size-chart-{{ chart_uid }} .size-chart__table tbody tr:nth-child(even) th {
      background: var(--size-chart-row-alt-bg);
    }

    .size-chart-{{ chart_uid }} .size-chart__empty {
      padding: 1rem 1.1rem;
      border-radius: 18px;
      background: rgba(148, 163, 184, 0.12);
      color: var(--size-chart-modal-text);
    }

    @media screen and (min-width: 750px) {
      .size-chart-{{ chart_uid }} {
        margin-top: 1.2rem;
      }

      .size-chart-{{ chart_uid }} .size-chart__panel {
        padding: 1.8rem;
      }
    }

    @keyframes size-chart-panel-enter-{{ chart_uid }} {
      from {
        opacity: 0;
        transform: translate3d(0, 24px, 0) scale(0.98);
      }

      to {
        opacity: 1;
        transform: translate3d(0, 0, 0) scale(1);
      }
    }

    @keyframes size-chart-backdrop-enter-{{ chart_uid }} {
      from {
        opacity: 0;
      }

      to {
        opacity: 1;
      }
    }
  </style>

  <div class="size-chart-{{ chart_uid }}"{% if block != blank %} {{ block.shopify_attributes }}{% endif %}>
    <button
      type="button"
      class="size-chart__trigger {% if trigger_style == 'button' %}size-chart__trigger--button{% else %}size-chart__trigger--link{% endif %}"
      data-size-chart-open="{{ dialog_id }}"
      aria-controls="{{ dialog_id }}"
      aria-haspopup="dialog"
    >
      {{ trigger_text | escape }}
    </button>

    <dialog id="{{ dialog_id }}" class="size-chart__dialog">
      <div class="size-chart__panel" role="dialog" aria-modal="true" aria-labelledby="{{ dialog_title_id }}">
        <button
          type="button"
          class="size-chart__close"
          data-size-chart-close="{{ dialog_id }}"
          aria-label="Close size chart"
        >
          x
        </button>

        <h2 id="{{ dialog_title_id }}" class="size-chart__title">{{ dialog_heading | escape }}</h2>

        {%- if size_chart_description != blank -%}
          <div class="size-chart__description rte">{{ size_chart_description }}</div>
        {%- endif -%}

        {%- if size_chart_mode == 'image' and size_chart_image != blank -%}
          <div class="size-chart__image-wrap">
            {{
              size_chart_image
              | image_url: width: 1800
              | image_tag:
                loading: 'lazy',
                widths: '480, 720, 960, 1200, 1600, 1800',
                class: 'size-chart__image',
                alt: image_alt
            }}
          </div>
        {%- elsif size_chart_mode == 'manual' and table_headers_raw != blank and table_rows_raw != blank -%}
          <div class="size-chart__table-wrap">
            <table class="size-chart__table">
              <thead>
                <tr>
                  {%- for header in table_headers -%}
                    <th scope="col">{{ header | strip | escape }}</th>
                  {%- endfor -%}
                </tr>
              </thead>
              <tbody>
                {%- for row in table_rows -%}
                  {%- assign stripped_row = row | strip -%}
                  {%- unless stripped_row == blank -%}
                    {%- assign row_cells = stripped_row | split: '|' -%}
                    <tr>
                      {%- for cell in row_cells -%}
                        {%- if forloop.first -%}
                          <th scope="row">{{ cell | strip | escape }}</th>
                        {%- else -%}
                          <td>{{ cell | strip | escape }}</td>
                        {%- endif -%}
                      {%- endfor -%}
                    </tr>
                  {%- endunless -%}
                {%- endfor -%}
              </tbody>
            </table>
          </div>
        {%- else -%}
          <div class="size-chart__empty">
            Add an image or enter manual table content in the settings.
          </div>
        {%- endif -%}

        {%- if size_chart_footer != blank -%}
          <div class="size-chart__footer rte">{{ size_chart_footer }}</div>
        {%- endif -%}
      </div>
    </dialog>
  </div>

  <script>
    (() => {
      const dialog = document.getElementById('{{ dialog_id }}');
      if (!dialog || dialog.dataset.sizeChartReady === 'true') return;
      dialog.dataset.sizeChartReady = 'true';

      const openButtons = document.querySelectorAll('[data-size-chart-open="{{ dialog_id }}"]');
      const closeButtons = dialog.querySelectorAll('[data-size-chart-close="{{ dialog_id }}"]');

      const openDialog = () => {
        if (typeof dialog.showModal === 'function') {
          dialog.showModal();
        } else {
          dialog.setAttribute('open', 'open');
        }
      };

      const closeDialog = () => {
        if (typeof dialog.close === 'function') {
          dialog.close();
        } else {
          dialog.removeAttribute('open');
        }
      };

      openButtons.forEach((button) => {
        button.addEventListener('click', openDialog);
      });

      closeButtons.forEach((button) => {
        button.addEventListener('click', closeDialog);
      });

      dialog.addEventListener('click', (event) => {
        if (event.target === dialog) {
          closeDialog();
        }
      });
    })();
  </script>
{%- endif -%}
