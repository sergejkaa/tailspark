{%- comment -%}
  TailSpark Subscription Widget
  Usage: {% render 'tailspark-sub-widget', product: product, product_form_id: product_form_id, section_id: section.id %}
{%- endcomment -%}

<script id="ts-selling-plans-data" type="application/json">
  {{ product.selling_plan_groups | json }}
</script>

{%- liquid
  case product.handle
    when 'tailspark-skin-coat'
      assign chews_per_jar = 70
    when 'tailspark-probiotic'
      assign chews_per_jar = 90
    else
      assign chews_per_jar = 60
  endcase
-%}
<div id="ts-sub-widget"
  class="ts-sub-widget"
  data-product-form-id="{{ product_form_id }}"
  data-base-price="{{ product.selected_or_first_available_variant.price }}"
  data-compare-price="{{ product.selected_or_first_available_variant.compare_at_price | default: product.selected_or_first_available_variant.price }}"
  data-chews-per-jar="{{ chews_per_jar }}"
>

  {{- 'tailspark-sub-widget.css' | asset_url | stylesheet_tag -}}

  <!-- Dog size -->
  <div class="ts-box">
    <p class="ts-label">Dog size</p>
    <div class="ts-pills ts-size-pills" role="group" aria-label="Dog size">
      {%- if product.handle == 'tailspark-multivitamin' -%}
        <button type="button" class="ts-pill ts-pill--active" data-size="under-25">Under 25 lbs</button>
        <button type="button" class="ts-pill" data-size="25-75">25 – 75 lbs</button>
        <button type="button" class="ts-pill" data-size="over-75">Over 75 lbs</button>
      {%- else -%}
        <button type="button" class="ts-pill ts-pill--active" data-size="under-15">Under 15 lbs</button>
        <button type="button" class="ts-pill" data-size="15-45">15 – 45 lbs</button>
        <button type="button" class="ts-pill" data-size="45-75">45 – 75 lbs</button>
        <button type="button" class="ts-pill" data-size="over-75">Over 75 lbs</button>
      {%- endif -%}
    </div>
  </div>

  <!-- Quantity -->
  <div class="ts-box">
    <p class="ts-label">Quantity</p>
    <div class="ts-qty-row">
      <div class="ts-qty-stepper">
        <button type="button" class="ts-qty-btn" id="ts-qty-minus">-</button>
        <span id="ts-qty-num">1</span>
        <span class="ts-qty-unit" id="ts-qty-unit" style="font-weight:700">jar</span>
        <button type="button" class="ts-qty-btn" id="ts-qty-plus">+</button>
      </div>
      <div class="ts-rec-box">
        <strong>Recommended: <span id="ts-rec-num">1</span> <span id="ts-rec-unit">jar</span></strong>
        <span><span id="ts-supply-days">60</span>-day supply · <span id="ts-chews-day">1</span> chew/day</span>
      </div>
    </div>
    <div class="ts-warning" id="ts-warning">
      <span class="ts-warning-icon">&#9888;</span>
      <span>At this dose, <span id="ts-warn-jars">1</span> <span id="ts-warn-jars-unit">jar</span> will last ~<span id="ts-warn-supply">60</span> days. Your next delivery arrives in <span id="ts-warn-interval">30</span> days.</span>
    </div>
  </div>

  <!-- Delivery interval -->
  <div class="ts-box">
    <p class="ts-label">Delivery interval</p>
    <div class="ts-pills ts-interval-pills" id="ts-interval-pills" role="group" aria-label="Delivery interval">
      <button type="button" class="ts-pill" data-days="30">30 days</button>
      <button type="button" class="ts-pill" data-days="45">45 days</button>
      <button type="button" class="ts-pill" data-days="60">60 days</button>
      <button type="button" class="ts-pill" data-days="90">90 days</button>
    </div>
  </div>

  <!-- Price + CTAs -->
  <div class="ts-box ts-price-box">
    <div class="ts-price-row">
      <span class="ts-price-sale" id="ts-price-sale"></span>
      <s class="ts-price-compare" id="ts-price-compare"></s>
      <span class="ts-save-badge">Save 15%</span>
    </div>
    <p class="ts-price-per" id="ts-price-per"></p>
    <button type="button" class="ts-cta ts-cta--sub" id="ts-btn-subscribe">
      Subscribe &amp; save 15% · <span id="ts-cta-sub-price"></span>
    </button>
    <button type="button" class="ts-cta ts-cta--otp" id="ts-btn-onetime">
      One-time purchase · <span id="ts-cta-otp-price"></span>
    </button>
    <p class="ts-fine-print">Quantity and interval can be changed anytime in <a href="https://tailspark.com/tools/recurring/get-subscription-access" class="ts-account-link">your account</a></p>
    <div class="ts-trust">
      <span class="ts-trust-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 3v6c0 5-3.5 7.5-8 9-4.5-1.5-8-4-8-9V6l8-3z"/><polyline points="9 12 11 14 15 10"/></svg>
        60 Day Money Back Guarantee
      </span>
      <span class="ts-trust-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
        Pause or cancel anytime
      </span>
      <span class="ts-trust-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v4h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        Free Standard Shipping
      </span>
    </div>
  </div>

</div>

<script src="{{ 'tailspark-sub-widget.js' | asset_url }}" defer></script>
