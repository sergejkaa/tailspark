      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .fsb-upsell__image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .fsb-upsell__placeholder {
      color: #cbd5e1;
      font-weight: 700;
      font-size: 20px;
