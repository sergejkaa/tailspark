    .fsb-upsell__viewport {
      position: relative;
      width: 100%;
      max-width: 100%;
      min-width: 0;
      overflow: hidden;
      padding: 0 1px 0 0;
      box-sizing: border-box;
    }

    .fsb-upsell__slider {
      --fsb-upsell-gap: 8px;
      --fsb-upsell-visible-mobile: 1;
      --fsb-upsell-visible-desktop: 1.1;
      --fsb-upsell-visible: var(--fsb-upsell-visible-mobile);
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: calc(
        (100% - (var(--fsb-upsell-gap) * (var(--fsb-upsell-visible) - 1)))
        / var(--fsb-upsell-visible)
      );
      column-gap: var(--fsb-upsell-gap);
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      width: 100%;
      max-width: 100%;
      min-width: 0;
      box-sizing: border-box;
      padding-right: 1px;
      scroll-padding-left: 0;
      scroll-padding-right: 1px;
      scrollbar-width: none;
      -ms-overflow-style: none;
      touch-action: pan-x;
      overscroll-behavior-x: contain;
    }

    .fsb-upsell__slider[data-real-count='1'] {
      --fsb-upsell-visible: 1;
      grid-auto-columns: 100%;
    }

    .fsb-upsell__slider::-webkit-scrollbar {
      display: none;
    }

    .fsb-upsell__item {
      scroll-snap-align: start;
      scroll-snap-stop: always;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
