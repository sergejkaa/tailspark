      color: var(--fsb-upsell-variant-text, var(--fsb-text, #f8fafc));
      font-size: 10.5px;
      line-height: 1.2;
      padding: 4px 8px;
      outline: none;
      transition: border-color 140ms ease, background 140ms ease;
    }

    .fsb-upsell__variant:focus {
      border-color: rgba(14, 165, 233, 0.65);
      background: var(--fsb-upsell-variant-bg, rgba(15, 23, 42, 0.72));
    }

    .fsb-upsell__variant option {
      color: var(--fsb-upsell-variant-text, #e2e8f0);
      background: var(--fsb-upsell-variant-bg, #0f172a);
    }

    .fsb-upsell__title {
      color: var(--fsb-text, #f8fafc);
      font-size: 12px;
      font-weight: 600;
      text-decoration: none;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .fsb-upsell__title:hover {
      text-decoration: underline;
    }

    .fsb-upsell__price {
      color: var(--fsb-upsell-price-color, #94a3b8);
      font-size: 11px;
      white-space: nowrap;
    }

    .fsb-upsell__add {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 4px;
      min-width: 50px;
      background: rgba(255, 255, 255, 0.04);
      color: var(--fsb-text, #f8fafc);
      border: 1px solid rgba(148, 163, 184, 0.45);
      border-radius: 999px;
      padding: 5px 9px;
      font-size: 11px;
      font-weight: 600;
      cursor: pointer;
      transition: transform 160ms ease, background 160ms ease, border-color 160ms ease, opacity 160ms ease;
      white-space: nowrap;
    }

    .fsb-upsell__add-icon {
      font-size: 13px;
      line-height: 1;
      width: 13px;
      height: 13px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
