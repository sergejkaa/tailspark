{%- liquid
  assign script_only = script_only | default: false
  assign bar_enabled = settings.free_shipping_bar_enabled
  assign goal_amount = settings.free_shipping_goal | default: 50
  assign goal_cents = goal_amount | times: 100
  assign goal_cents = goal_cents | default: 5000

  if goal_cents <= 0
    assign goal_cents = 1
  endif

  assign total_cents = cart.total_price | default: 0
  assign progress = total_cents | times: 100 | divided_by: goal_cents

  if progress > 100
    assign progress = 100
  endif

  assign remaining_cents = goal_cents | minus: total_cents
  if remaining_cents < 0
    assign remaining_cents = 0
  endif

  assign unlocked = false
  if total_cents >= goal_cents
    assign unlocked = true
  endif

  assign fsb_from = settings.free_shipping_bar_gradient_from | default: '#00c6ff'
  assign fsb_to = settings.free_shipping_bar_gradient_to | default: '#0072ff'
  assign fsb_success = settings.free_shipping_bar_success | default: '#10b981'
  assign fsb_progress_glow_color = settings.free_shipping_progress_glow_color | default: '#10b981'
  assign fsb_progress_glow_soft = fsb_progress_glow_color | color_modify: 'alpha', 0.18
  assign fsb_progress_glow_strong = fsb_progress_glow_color | color_modify: 'alpha', 0.32
  assign fsb_background = settings.free_shipping_bar_background | default: '#171b24'
  assign fsb_text_color = settings.free_shipping_bar_text_color | default: '#f8fafc'
  assign fsb_border_color = settings.free_shipping_bar_border_color | default: '#94a3b8'
  assign fsb_border_color_alpha = fsb_border_color | color_modify: 'alpha', 0.28
  assign fsb_shadow_enabled = settings.free_shipping_shadow_enable
  assign fsb_shadow_color = settings.free_shipping_shadow_color | default: '#020617'
  assign fsb_shadow_strength = settings.free_shipping_shadow_strength | default: 52 | plus: 0
  assign fsb_shadow_enabled_numeric = 1
  if fsb_shadow_enabled == blank
    assign fsb_shadow_enabled = true
  endif
  if fsb_shadow_enabled != true
    assign fsb_shadow_enabled_numeric = 0
  endif
  if fsb_shadow_strength < 0
    assign fsb_shadow_strength = 0
  endif
  if fsb_shadow_strength > 100
    assign fsb_shadow_strength = 100
  endif
  assign fsb_shadow_r = fsb_shadow_color | color_extract: 'red'
  assign fsb_shadow_g = fsb_shadow_color | color_extract: 'green'
  assign fsb_shadow_b = fsb_shadow_color | color_extract: 'blue'
  assign fsb_current_from = '#10b981'
  assign fsb_current_to = '#34d399'
  assign upsell_dot_active_color = settings.free_shipping_upsell_dot_color | default: '#0ea5e9'
  assign upsell_card_background = settings.free_shipping_upsell_card_background | default: '#0f172a'
  assign upsell_variant_bg_color = settings.free_shipping_upsell_variant_bg_color | default: '#0f172a'
  assign upsell_variant_text_color = settings.free_shipping_upsell_variant_text_color | default: '#f8fafc'
  assign upsell_card_border_color = settings.free_shipping_upsell_card_border_color | default: '#94a3b8'
  assign upsell_card_border_color_alpha = upsell_card_border_color | color_modify: 'alpha', 0.26
  assign upsell_heading_color = settings.free_shipping_upsell_heading_color | default: '#94a3b8'
  assign upsell_price_color = settings.free_shipping_upsell_price_color | default: '#94a3b8'
  assign upsell_arrow_color = settings.free_shipping_upsell_arrow_color | default: '#e2e8f0'
  assign locked_text = settings.free_shipping_text_locked | default: "You're only %amount% away from free shipping"
  assign unlocked_text = settings.free_shipping_text_unlocked | default: 'Free shipping unlocked'
  assign highlight_color = settings.free_shipping_highlight_color | default: '#0284c7'
  if highlight_color == '#7dd3fc'
    assign highlight_color = '#0284c7'
  endif
-%}

{%- if bar_enabled and script_only != true -%}
  <div class="free-shipping-wrap" aria-live="polite" role="status">
    <div
      class="free-shipping-bar{% if unlocked %} fsb--unlocked{% endif %}"
      style="
        --fsb-gradient-from: {{ fsb_from }};
        --fsb-gradient-to: {{ fsb_to }};
        --fsb-current-from: {{ fsb_current_from }};
        --fsb-current-to: {{ fsb_current_to }};
        --fsb-success: {{ fsb_success }};
        --fsb-progress-glow-soft: {{ fsb_progress_glow_soft }};
        --fsb-progress-glow-strong: {{ fsb_progress_glow_strong }};
        --fsb-bg: {{ fsb_background }};
        --fsb-bg-unlocked: {{ fsb_background }};
        --fsb-text: {{ fsb_text_color }};
        --fsb-border: {{ fsb_border_color_alpha }};
        --fsb-shadow-enabled: {{ fsb_shadow_enabled_numeric }};
        --fsb-shadow-r: {{ fsb_shadow_r }};
        --fsb-shadow-g: {{ fsb_shadow_g }};
        --fsb-shadow-b: {{ fsb_shadow_b }};
        --fsb-shadow-strength: {{ fsb_shadow_strength }};
        --fsb-progress: {{ progress }}%;
        --fsb-progress-value: {{ progress }}%;
        --fsb-highlight: {{ highlight_color }};
        --fsb-upsell-dot-active: {{ upsell_dot_active_color }};
        --fsb-upsell-card-bg: {{ upsell_card_background }};
        --fsb-upsell-variant-bg: {{ upsell_variant_bg_color }};
        --fsb-upsell-variant-text: {{ upsell_variant_text_color }};
        --fsb-upsell-card-border: {{ upsell_card_border_color_alpha }};
        --fsb-upsell-heading-color: {{ upsell_heading_color }};
        --fsb-upsell-price-color: {{ upsell_price_color }};
        --fsb-upsell-arrow-color: {{ upsell_arrow_color }};
      "
      data-progress="{{ progress }}"
      data-remaining-cents="{{ remaining_cents }}"
    >
      <div class="fsb__header">
        <div class="fsb__text">
          <p class="fsb__title{% if unlocked %} fsb__title--unlocked{% endif %}">
            {%- if unlocked -%}
              {{ unlocked_text }}
              <span class="fsb__check" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 12.5l4 4 11-11"/></svg>
              </span>
            {%- else -%}
              {%- capture highlight_html -%}<span class="fsb__highlight" data-target-cents="{{ remaining_cents }}" data-currency="{{ cart.currency.iso_code | default: shop.currency }}">{{ remaining_cents | money_with_currency }}</span>{%- endcapture -%}
              {{ locked_text | replace: '%amount%', highlight_html }}
            {%- endif -%}
          </p>
        </div>
      </div>

      <div class="fsb__track" role="presentation">
        <div class="fsb__track-inner">
          <div
            class="fsb__fill{% if unlocked %} fsb__fill--complete{% endif %}"
            style="width: {{ progress }}%; background: linear-gradient(90deg, #10b981 0%, #34d399 100%); background-color: #10b981;"
          ></div>
        </div>
        {%- unless unlocked -%}
          <span class="fsb__tip" aria-hidden="true">
            <svg width="1em" height="1em" viewBox="0 0 511.99 511.99" xmlns="http://www.w3.org/2000/svg" focusable="false">
              <polygon style="fill:#E6E9ED;" points="310.557,373.18 329.649,202.62 420.975,202.527 463.116,264.588 501.303,283.76 501.115,373.18"/>
              <polygon style="fill:#4FC2E9;" points="457.491,256.291 420.975,202.527 329.649,202.62 323.649,256.291"/>
              <path style="fill:#E6E9ED;" d="M470.382,256.291l-43.75-64.437l-106.529,0.109l-21.468,191.873h213.121l0.234-106.654L470.382,256.291z M490.475,362.508H322.493l16.688-149.231l76.155-0.078l37.405,55.077l3.109,4.594l4.953,2.484l29.812,14.969L490.475,362.508z"/>
              <path style="fill:#FC6E51;" d="M319.977,85.201H21.328C9.547,85.201,0,94.748,0,106.529v255.979c0,11.781,9.547,21.328,21.328,21.328h298.634c11.781,0,21.344-9.547,21.344-21.328v-255.98C341.306,94.747,331.759,85.201,319.977,85.201z"/>
              <rect x="362.645" y="213.244" style="fill:#3BAFDA;" width="21.328" height="43.05"/>
              <rect x="63.748" y="84.966" style="fill:#E9573F;" width="21.328" height="297.09"/>
              <rect x="127.995" y="84.966" style="fill:#E9573F;" width="21.328" height="297.09"/>
              <rect x="192.245" y="84.966" style="fill:#E9573F;" width="21.328" height="297.09"/>
              <rect x="256.495" y="84.966" style="fill:#E9573F;" width="21.328" height="297.09"/>
              <circle style="fill:#434A54;" cx="415.965" cy="373.694" r="53.33"/>
              <circle style="fill:#434A54;" cx="106.655" cy="373.694" r="53.33"/>
              <path style="fill:#F5F7FA;" d="M405.289,373.695c0,5.891,4.781,10.672,10.672,10.672c5.89,0,10.671-4.781,10.671-10.672s-4.781-10.656-10.671-10.656C410.07,363.039,405.289,367.805,405.289,373.695z"/>
              <path style="fill:#F5F7FA;" d="M95.982,373.695c0,5.891,4.781,10.672,10.672,10.672c5.891,0,10.656-4.781,10.656-10.672s-4.765-10.656-10.656-10.656C100.763,363.039,95.982,367.805,95.982,373.695z"/>
              <path style="fill:#ED5564;" d="M511.943,298.51h-21.312c-5.891,0-10.656,4.781-10.656,10.67c0,5.891,4.766,10.656,10.656,10.656h21.265L511.943,298.51z"/>
            </svg>
          </span>
        {%- endunless -%}
        <div class="fsb__glow"></div>
      </div>

      {%- liquid
        assign upsell_limit = settings.free_shipping_upsell_limit | default: 6
        assign upsell_source_mode = settings.free_shipping_upsell_source | default: 'auto'
        assign upsell_products = blank

        if upsell_source_mode == 'products' or upsell_source_mode == 'auto'
          if settings.free_shipping_upsell_products != blank
            assign upsell_products = settings.free_shipping_upsell_products
          endif
        endif

        if upsell_products == blank and upsell_source_mode != 'products' and settings.free_shipping_upsell_collection != blank
          assign upsell_handle = settings.free_shipping_upsell_collection.handle | default: settings.free_shipping_upsell_collection
          if upsell_handle != blank and collections[upsell_handle] != blank
            assign upsell_products = collections[upsell_handle].products
          elsif settings.free_shipping_upsell_collection.products != blank
            assign upsell_products = settings.free_shipping_upsell_collection.products
          endif
        endif
      -%}

      {%- if settings.free_shipping_upsell_enable and upsell_products != blank -%}
        {%- assign cart_product_ids = cart.items | map: 'product_id' -%}
        {%- assign upsell_heading_text = settings.free_shipping_upsell_heading | default: 'Recommended for you' -%}
        {%- if upsell_heading_text == 'Add one to unlock free shipping faster' -%}
          {%- assign upsell_heading_text = 'Recommended for you' -%}
        {%- endif -%}
        {%- if upsell_heading_text == 'Add one more item to unlock free shipping' -%}
          {%- assign upsell_heading_text = 'Recommended for you' -%}
        {%- endif -%}
        {%- assign rendered_upsell = 0 -%}
        {%- capture upsell_items_markup -%}
          {%- for product in upsell_products -%}
            {%- assign candidate_product = product -%}
            {%- if candidate_product.id == blank and all_products[product] != blank -%}
              {%- assign candidate_product = all_products[product] -%}
            {%- endif -%}
            {%- if candidate_product == blank or candidate_product.id == blank -%}{% continue %}{%- endif -%}
            {%- if candidate_product.available == false -%}{% continue %}{%- endif -%}
            {%- if settings.free_shipping_upsell_hide_in_cart and unlocked == false and cart_product_ids contains candidate_product.id -%}{% continue %}{%- endif -%}
              {%- assign first_variant = candidate_product.selected_or_first_available_variant -%}
              {%- if first_variant == blank -%}{% continue %}{%- endif -%}
              {%- assign first_variant_increment = first_variant.quantity_rule.increment | default: 1 -%}
              {%- assign first_variant_min = first_variant.quantity_rule.min | default: 1 -%}
              {%- assign first_variant_qty = first_variant_increment -%}
              {%- if first_variant_min > first_variant_qty -%}
                {%- assign first_variant_qty = first_variant_min -%}
              {%- endif -%}
              <div class="fsb-upsell__item" role="listitem">
                <a class="fsb-upsell__image" href="{{ candidate_product.url }}">
                  {%- if candidate_product.featured_image -%}
                  <img
                    src="{{ candidate_product.featured_image | image_url: width: 120 }}"
                    alt="{{ candidate_product.featured_image.alt | escape }}"
                    loading="lazy"
                    width="54"
                    height="{{ 54 | divided_by: candidate_product.featured_image.aspect_ratio | ceil }}"
                    style="object-position: {{ settings.free_shipping_upsell_focus_x | default: 50 }}% {{ settings.free_shipping_upsell_focus_y | default: 50 }}%;"
                  >
                {%- else -%}
                  <span class="fsb-upsell__placeholder">+</span>
                {%- endif -%}
              </a>
              <div class="fsb-upsell__meta">
                <a class="fsb-upsell__title" href="{{ candidate_product.url }}">{{ candidate_product.title }}</a>
                <div class="fsb-upsell__price">
                  {%- if candidate_product.price_varies -%}
                    From {{ candidate_product.price_min | money }}
                  {%- else -%}
                    {{ candidate_product.price | money }}
                  {%- endif -%}
                </div>
                {%- if candidate_product.variants.size > 1 -%}
                  <select class="fsb-upsell__variant" aria-label="Choose variant">
                    {%- for variant in candidate_product.variants -%}
                      <option
                        value="{{ variant.id }}"
                        data-price="{{ variant.price | money | escape }}"
                        data-qty-increment="{{ variant.quantity_rule.increment | default: 1 }}"
                        data-qty-min="{{ variant.quantity_rule.min | default: 1 }}"
                        {% if variant.id == first_variant.id %}selected{% endif %}
                        {% unless variant.available %}disabled{% endunless %}
                      >
                        {{ variant.title }}{% unless variant.available %} - Sold out{% endunless %}
                      </option>
                    {%- endfor -%}
                  </select>
                {%- endif -%}
              </div>
              <button
                type="button"
                class="fsb-upsell__add"
                data-variant-id="{{ first_variant.id }}"
                data-quantity="{{ first_variant_qty }}"
                data-default-label="{{ settings.free_shipping_upsell_button | escape }}"
                aria-label="{{ settings.free_shipping_upsell_button }} {{ candidate_product.title | escape }}"
                {% unless first_variant.available %}disabled{% endunless %}
              >
                <span class="fsb-upsell__add-icon" aria-hidden="true">+</span>
                <span class="fsb-upsell__add-text">{{ settings.free_shipping_upsell_button }}</span>
              </button>
            </div>
            {%- assign rendered_upsell = rendered_upsell | plus: 1 -%}
            {%- if rendered_upsell >= upsell_limit -%}{%- break -%}{%- endif -%}
          {%- endfor -%}
        {%- endcapture -%}

        {%- if rendered_upsell > 0 -%}
          {%- assign upsell_slides_desktop = settings.free_shipping_upsell_slides_desktop | default: 1.1 | plus: 0 -%}
          {%- assign upsell_slides_mobile = settings.free_shipping_upsell_slides_mobile | default: 1 | plus: 0 -%}
          {%- if upsell_slides_desktop < 1 -%}{%- assign upsell_slides_desktop = 1 -%}{%- endif -%}
          {%- if upsell_slides_mobile < 1 -%}{%- assign upsell_slides_mobile = 1 -%}{%- endif -%}
          {%- if rendered_upsell == 1 -%}
            {%- assign upsell_slides_desktop = 1 -%}
            {%- assign upsell_slides_mobile = 1 -%}
          {%- endif -%}
          <div class="fsb-upsell">
            <div class="fsb-upsell__header">{{ upsell_heading_text }}</div>
            <div class="fsb-upsell__viewport">
              <div
                class="fsb-upsell__slider"
                role="list"
                aria-label="{{ upsell_heading_text | escape }}"
                data-real-count="{{ rendered_upsell }}"
                style="--fsb-upsell-visible-desktop: {{ upsell_slides_desktop }}; --fsb-upsell-visible-mobile: {{ upsell_slides_mobile }};"
              >
                {{ upsell_items_markup }}
              </div>
              {%- if rendered_upsell > 1 -%}
                {%- assign show_upsell_arrows = false -%}
                {%- if settings.free_shipping_upsell_arrows_desktop or settings.free_shipping_upsell_arrows_mobile -%}
                  {%- assign show_upsell_arrows = true -%}
                {%- endif -%}
                {%- if show_upsell_arrows -%}
                  <div class="fsb-upsell__controls{% unless settings.free_shipping_upsell_arrows_desktop %} fsb-upsell__controls--hide-desktop{% endunless %}{% unless settings.free_shipping_upsell_arrows_mobile %} fsb-upsell__controls--hide-mobile{% endunless %}">
                    <button type="button" class="fsb-upsell__arrow fsb-upsell__arrow--prev" data-direction="prev" aria-label="Previous upsell slide">
                      <span aria-hidden="true">&#8249;</span>
                    </button>
                    <button type="button" class="fsb-upsell__arrow fsb-upsell__arrow--next" data-direction="next" aria-label="Next upsell slide">
                      <span aria-hidden="true">&#8250;</span>
                    </button>
                  </div>
                {%- endif -%}
              {%- endif -%}
            </div>
            {%- if rendered_upsell > 1 -%}
              <div class="fsb-upsell__dots" aria-hidden="true">
                {%- for i in (1..rendered_upsell) -%}
                  <button
                    type="button"
                    class="fsb-upsell__dot{% if forloop.first %} is-active{% endif %}"
                    data-index="{{ i }}"
                    aria-label="Go to upsell {{ i }}"
                  ></button>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>

  <style>
    .free-shipping-wrap {
      margin: 2px 0 10px;
      padding: 0 2px;
      position: relative;
      width: 100%;
      max-width: 100%;
      min-width: 0;
      overflow: visible;
      box-sizing: border-box;
    }

    .free-shipping-bar {
      --fsb-height: 6px;
      --fsb-radius: 999px;
      --fsb-border: rgba(148, 163, 184, 0.28);
      padding: 10px 12px;
      background: var(--fsb-bg, #171b24);
      border: 1px solid var(--fsb-border);
      border-radius: 12px;
      box-shadow:
        0
        calc((3px + (var(--fsb-shadow-strength, 52) * 0.07px)) * var(--fsb-shadow-enabled, 1))
        calc((8px + (var(--fsb-shadow-strength, 52) * 0.18px)) * var(--fsb-shadow-enabled, 1))
        calc((-7px - (var(--fsb-shadow-strength, 52) * 0.06px)) * var(--fsb-shadow-enabled, 1))
        rgba(
          var(--fsb-shadow-r, 2),
          var(--fsb-shadow-g, 6),
          var(--fsb-shadow-b, 23),
          calc((0.07 + (var(--fsb-shadow-strength, 52) * 0.0032)) * var(--fsb-shadow-enabled, 1))
        ),
        0 1px 0 rgba(255, 255, 255, 0.05) inset;
      color: var(--fsb-text, #f8fafc);
      overflow: hidden;
      position: relative;
      width: 100%;
      max-width: 100%;
      min-width: 0;
      box-sizing: border-box;
    }

    .free-shipping-bar.fsb--unlocked {
      background: var(--fsb-bg-unlocked, var(--fsb-bg, #171b24));
      border-color: var(--fsb-border);
    }

    .free-shipping-bar .fsb__header {
      display: block;
      align-items: center;
    }

    .free-shipping-bar .fsb__text {
      display: grid;
      gap: 2px;
    }

    .free-shipping-bar .fsb__title {
      margin: 0;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0;
      color: var(--fsb-text, #f8fafc);
      display: flex;
      align-items: center;
      gap: 5px;
      line-height: 1.36;
      white-space: nowrap;
      overflow: visible;
      text-overflow: clip;
    }

    .free-shipping-bar .fsb__check {
      display: none;
      width: 24px;
      height: 24px;
      color: #22c55e;
      background: rgba(16, 185, 129, 0.12);
      border-radius: 50%;
      border: 1px solid rgba(34, 197, 94, 0.4);
      padding: 1px;
      line-height: 1;
      transform-origin: center;
      overflow: visible;
      box-shadow: 0 0 0 1px rgba(34, 197, 94, 0.14);
      flex-shrink: 0;
      margin-left: 2px;
    }

    .free-shipping-bar.fsb--unlocked .fsb__check {
      display: inline-grid;
      place-items: center;
      animation: fsbCheck 1.15s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .free-shipping-bar .fsb__highlight {
      color: var(--fsb-highlight, #0284c7);
      font-weight: 650;
      display: inline-block;
      transition: color 220ms ease, opacity 420ms ease, transform 420ms ease;
      animation: fsbSwap 420ms ease;
      white-space: nowrap;
    }

    .free-shipping-bar .fsb__track {
      position: relative;
      width: 100%;
      height: var(--fsb-height);
      margin-top: 16px;
      overflow: visible;
    }

    .free-shipping-bar .fsb__track-inner {
      position: relative;
      width: 100%;
      height: 100%;
      background: #334155;
      border-radius: var(--fsb-radius);
      overflow: hidden;
      isolation: isolate;
      box-shadow: inset 0 0 0 1px rgba(226, 232, 240, 0.08);
    }

    .free-shipping-bar .fsb__track-inner::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      bottom: 0;
      width: var(--fsb-progress-value, 0%);
      border-radius: inherit;
      background: linear-gradient(90deg, #10b981 0%, #34d399 100%);
      transition: width 950ms cubic-bezier(0.22, 1, 0.36, 1);
      z-index: 2;
      pointer-events: none;
    }

    .free-shipping-bar .fsb__track-inner::after {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      bottom: 0;
      left: calc(var(--fsb-progress-value, 100%) - 1px);
      border-radius: 0 var(--fsb-radius) var(--fsb-radius) 0;
      background:
        linear-gradient(90deg, rgba(148, 163, 184, 0.44), rgba(148, 163, 184, 0.62)),
        repeating-linear-gradient(
          -45deg,
          rgba(255, 255, 255, 0.52) 0 8px,
          rgba(255, 255, 255, 0.14) 8px 16px
        );
      background-size: 100% 100%, auto;
      animation: fsbStripes 1.45s linear infinite;
      opacity: 0.96;
      pointer-events: none;
      z-index: 3;
      transition: left 950ms cubic-bezier(0.22, 1, 0.36, 1);
      will-change: left, background-position;
    }

    .free-shipping-bar .fsb__fill {
      display: none !important;
    }

    .free-shipping-bar .fsb__fill::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: inherit;
      background: linear-gradient(120deg, rgba(255, 255, 255, 0) 20%, rgba(255, 255, 255, 0.32) 50%, rgba(255, 255, 255, 0) 80%);
      background-size: 180% 100%;
      background-position: 170% 0;
      opacity: 0.28;
      animation: fsbSheen 3.2s ease-in-out infinite;
      pointer-events: none;
    }

    .free-shipping-bar .fsb__tip {
      position: absolute;
      left: clamp(9px, var(--fsb-progress-value), calc(100% - 9px));
      top: 50%;
      transform: translate(-50%, -50%);
      font-size: 28.8px;
      line-height: 1;
      filter: drop-shadow(0 1px 2px rgba(15, 23, 42, 0.25));
      z-index: 3;
      pointer-events: none;
      transition: left 950ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .fsb-upsell {
      margin-top: 10px;
      padding-top: 8px;
      border-top: 1px solid rgba(148, 163, 184, 0.24);
      display: grid;
      gap: 8px;
      width: 100%;
      max-width: 100%;
      min-width: 0;
