    .free-shipping-bar .fsb__fill--complete,
    .free-shipping-bar.fsb--unlocked .fsb__fill {
      background: linear-gradient(90deg, #10b981, #34d399) !important;
      width: 100% !important;
      animation: none;
      box-shadow: 0 0 0 1px var(--fsb-progress-glow-soft, rgba(16, 185, 129, 0.18)), 0 0 12px var(--fsb-progress-glow-strong, rgba(16, 185, 129, 0.32));
    }

    .free-shipping-bar.fsb--unlocked .fsb__fill::after {
      animation: none;
      opacity: 0.16;
    }

    .free-shipping-bar.fsb--unlocked .fsb__track-inner::after {
      opacity: 0;
      animation: none;
    }

    .free-shipping-bar .fsb__glow {
      position: absolute;
      inset: -40% -20%;
      background: radial-gradient(circle, rgba(14, 165, 233, 0.1), transparent 55%);
      filter: blur(12px);
      opacity: 0.22;
      pointer-events: none;
      z-index: 1;
    }

    @keyframes fsbCheck {
      0% {
        transform: scale(0.7);
        opacity: 0;
      }
      60% {
        transform: scale(1.12);
        opacity: 1;
      }
      100% {
        transform: scale(1);
        opacity: 1;
      }
    }

    @keyframes fsbSheen {
      0% {
        background-position: 170% 0;
      }
      100% {
        background-position: -90% 0;
      }
    }

    @keyframes fsbFlow {
      0% {
        background-position: 0% 50%;
      }
      50% {
        background-position: 100% 50%;
      }
      100% {
        background-position: 0% 50%;
      }
    }

    @keyframes fsbStripes {
      0% {
        background-position: 0 0, 0 0;
      }
      100% {
        background-position: 0 0, 22.627px 0;
      }
    }

    @keyframes fsbSwap {
      0% {
        opacity: 0;
        transform: translateY(6px);
      }
      100% {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 640px) {
      .free-shipping-bar {
        padding: 8px 10px 10px;
      }

      .free-shipping-bar .fsb__title {
        font-size: 12px;
        gap: 5px;
      }

      .free-shipping-bar .fsb__check {
        width: 18px;
        height: 18px;
      }

      .free-shipping-bar .fsb__highlight {
        font-size: 12px;
      }

      .free-shipping-bar .fsb__tip {
        font-size: 25.2px !important;
      }

      .fsb-upsell__title {
        font-size: 11px;
      }

      .fsb-upsell__price,
      .fsb-upsell__add {
        font-size: 10px;
      }

      .fsb-upsell__variant {
        font-size: 9.5px;
      }

      .fsb-upsell__arrow {
        font-size: 22px;
      }
    }

    @media (min-width: 750px) {
      .fsb-upsell__controls--hide-desktop {
        display: none;
      }

      .fsb-upsell__slider {
        --fsb-upsell-visible: var(--fsb-upsell-visible-desktop);
        cursor: grab;
      }

      .fsb-upsell__slider.is-dragging {
        cursor: grabbing;
        scroll-snap-type: none;
        user-select: none;
      }
    }

    @media (max-width: 749px) {
      .fsb-upsell__controls--hide-mobile {
        display: none;
      }
    }

    .cart-drawer .drawer__contents,
    .cart-drawer .drawer__cart-items-wrapper,
    .cart-drawer .cart-items {
      overflow-x: hidden;
      max-width: 100%;
    }
  </style>
{%- endif -%}

{%- if bar_enabled -%}
  <script>
    (function () {
      if (window.__fsbUpsellBound) return;
      window.__fsbUpsellBound = true;

      function getAllSlides(slider) {
        return Array.prototype.slice.call(slider.querySelectorAll('.fsb-upsell__item'));
      }

      function getRealSlides(slider) {
        return getAllSlides(slider).filter(function (slide) {
          return !slide.classList.contains('is-clone');
        });
      }

      function getActiveRealIndex(slider) {
        var realSlides = getRealSlides(slider);
        if (!realSlides.length) return 0;

        var sliderCenter = slider.scrollLeft + slider.clientWidth / 2;
        var bestIndex = 0;
        var bestDistance = Infinity;

        realSlides.forEach(function (slide, index) {
          var center = slide.offsetLeft + slide.offsetWidth / 2;
          var distance = Math.abs(center - sliderCenter);
          if (distance < bestDistance) {
            bestDistance = distance;
            bestIndex = index;
          }
        });

        return bestIndex;
      }

      function getSavedUpsellIndex() {
        var saved = parseInt(window.__fsbUpsellActiveIndex, 10);
        if (Number.isNaN(saved) || saved < 0) return 0;
        return saved;
      }

      function setSavedUpsellIndex(index) {
        var next = parseInt(index, 10);
        if (Number.isNaN(next) || next < 0) next = 0;
        window.__fsbUpsellActiveIndex = next;
      }

      function moveToRealIndex(slider, index, behavior) {
        var realSlides = getRealSlides(slider);
        if (!realSlides.length) return;

        var normalized = ((index % realSlides.length) + realSlides.length) % realSlides.length;
        slider.scrollTo({
          left: realSlides[normalized].offsetLeft,
          behavior: behavior || 'smooth'
        });
      }

      function normalizeLoopPosition(slider) {
        if (slider.getAttribute('data-loop') !== 'true') return;

        var slides = getAllSlides(slider);
        if (slides.length < 3) return;

        var firstClone = slides[0];
        var firstReal = slides[1];
        var lastReal = slides[slides.length - 2];
        var lastClone = slides[slides.length - 1];
        var x = slider.scrollLeft;
        var shift = firstReal.offsetWidth * 0.5;

        if (x <= firstClone.offsetLeft + shift) {
          slider.scrollLeft = lastReal.offsetLeft;
        } else if (x >= lastClone.offsetLeft - shift) {
          slider.scrollLeft = firstReal.offsetLeft;
        }
      }

      function updateDots(slider) {
        var container = slider.closest('.fsb-upsell');
        var realSlides = getRealSlides(slider);
        var realIndex = getActiveRealIndex(slider);
        setSavedUpsellIndex(realIndex);
        if (!container) return;
        var isLoop = slider.getAttribute('data-loop') === 'true' && realSlides.length > 1;

        var dots = container.querySelectorAll('.fsb-upsell__dot');
        dots.forEach(function (dot, idx) {
          dot.classList.toggle('is-active', idx === realIndex);
        });

        var prevArrow = container.querySelector('.fsb-upsell__arrow--prev');
        var nextArrow = container.querySelector('.fsb-upsell__arrow--next');
        if (prevArrow) prevArrow.disabled = !isLoop && realIndex <= 0;
        if (nextArrow) nextArrow.disabled = !isLoop && realIndex >= Math.max(realSlides.length - 1, 0);
      }

      function waitForSliderLayout(slider, callback) {
        var tries = 0;

        function check() {
          var firstReal = slider.querySelector('.fsb-upsell__item:not(.is-clone)');
          if (firstReal && slider.clientWidth > 20 && firstReal.getBoundingClientRect().width > 20) {
            callback();
            return;
          }

          tries += 1;
          if (tries < 80) {
            setTimeout(check, 40);
          } else {
            callback();
          }
        }

        check();
      }

      function bindUpsellSliders(scope) {
        var root = scope || document;
        var sliders = root.querySelectorAll('.fsb-upsell__slider');

        sliders.forEach(function (slider) {
          if (slider.dataset.fsbBound === 'true') return;
          slider.dataset.fsbBound = 'true';

          var initialItems = getAllSlides(slider);
          if (initialItems.length > 1) {
            var firstClone = initialItems[0].cloneNode(true);
            var lastClone = initialItems[initialItems.length - 1].cloneNode(true);
            firstClone.classList.add('is-clone');
            lastClone.classList.add('is-clone');
            slider.insertBefore(lastClone, slider.firstChild);
            slider.appendChild(firstClone);
            slider.setAttribute('data-loop', 'true');
          } else {
            slider.setAttribute('data-loop', 'false');
          }

          var dragState = {
            active: false,
            pointerId: null,
            startX: 0,
            startScrollLeft: 0
          };
          var scrollSettleTimer = null;

          function scheduleNormalizeAfterScroll() {
            if (slider.getAttribute('data-loop') !== 'true') return;
            if (dragState.active) return;
            if (scrollSettleTimer) {
              clearTimeout(scrollSettleTimer);
            }
            scrollSettleTimer = setTimeout(function () {
              normalizeLoopPosition(slider);
              updateDots(slider);
            }, 90);
          }

          waitForSliderLayout(slider, function () {
            moveToRealIndex(slider, getSavedUpsellIndex(), 'auto');
            normalizeLoopPosition(slider);
            updateDots(slider);
          });

          slider.addEventListener('scroll', function () {
            window.requestAnimationFrame(function () {
              if (!dragState.active) {
                updateDots(slider);
              }
            });
            scheduleNormalizeAfterScroll();
          }, { passive: true });

          var dots = slider.closest('.fsb-upsell') ? slider.closest('.fsb-upsell').querySelectorAll('.fsb-upsell__dot') : [];
          dots.forEach(function (dot) {
            dot.addEventListener('click', function () {
              var targetIndex = parseInt(dot.getAttribute('data-index'), 10) - 1;
              if (Number.isNaN(targetIndex)) return;
              setSavedUpsellIndex(targetIndex);
              moveToRealIndex(slider, targetIndex, 'smooth');
            });
          });

          var container = slider.closest('.fsb-upsell');
          if (container) {
            var arrows = container.querySelectorAll('.fsb-upsell__arrow');
            arrows.forEach(function (arrow) {
              arrow.addEventListener('click', function () {
                var direction = arrow.getAttribute('data-direction') === 'prev' ? -1 : 1;
                var realSlides = getRealSlides(slider);
                var currentIndex = getActiveRealIndex(slider);
                var nextIndex = currentIndex + direction;
                var allSlides = getAllSlides(slider);
                var isLoop = slider.getAttribute('data-loop') === 'true' && realSlides.length > 1;

                if (isLoop && direction > 0 && currentIndex >= realSlides.length - 1 && allSlides.length > 0) {
                  setSavedUpsellIndex(0);
                  slider.scrollTo({
                    left: allSlides[allSlides.length - 1].offsetLeft,
                    behavior: 'smooth'
                  });
                  scheduleNormalizeAfterScroll();
                  return;
                }

                if (isLoop && direction < 0 && currentIndex <= 0 && allSlides.length > 0) {
                  setSavedUpsellIndex(realSlides.length - 1);
                  slider.scrollTo({
                    left: allSlides[0].offsetLeft,
                    behavior: 'smooth'
                  });
                  scheduleNormalizeAfterScroll();
                  return;
                }

                setSavedUpsellIndex(nextIndex);
                moveToRealIndex(slider, nextIndex, 'smooth');
                scheduleNormalizeAfterScroll();
              });
            });
          }

          slider.addEventListener('pointerdown', function (event) {
            if (event.pointerType !== 'mouse' || event.button !== 0) return;
            if (event.target.closest('a, button, select, input, label')) return;

            dragState.active = true;
            dragState.pointerId = event.pointerId;
            dragState.startX = event.clientX;
            dragState.startScrollLeft = slider.scrollLeft;
            slider.classList.add('is-dragging');

            try {
              slider.setPointerCapture(event.pointerId);
            } catch (error) {
              dragState.active = false;
              slider.classList.remove('is-dragging');
            }
          });

          slider.addEventListener('pointermove', function (event) {
            if (!dragState.active || event.pointerId !== dragState.pointerId) return;
            event.preventDefault();
            slider.scrollLeft = dragState.startScrollLeft - (event.clientX - dragState.startX);
          });

          function endDrag(event) {
            if (!dragState.active || event.pointerId !== dragState.pointerId) return;

            dragState.active = false;
            var targetIndex = getActiveRealIndex(slider);
            setSavedUpsellIndex(targetIndex);
            normalizeLoopPosition(slider);
            moveToRealIndex(slider, targetIndex, 'smooth');
            scheduleNormalizeAfterScroll();
            window.setTimeout(function () {
              if (document.body.contains(slider)) {
                slider.classList.remove('is-dragging');
              }
            }, 160);

            if (slider.hasPointerCapture && slider.hasPointerCapture(event.pointerId)) {
              slider.releasePointerCapture(event.pointerId);
            }
          }

          slider.addEventListener('pointerup', endDrag);
          slider.addEventListener('pointercancel', endDrag);

          window.addEventListener('resize', function () {
            normalizeLoopPosition(slider);
            updateDots(slider);
          });
        });
      }

      function formatMoneyWithCurrency(cents, currency) {
        var amount = (cents || 0) / 100;

        try {
          var formatted = new Intl.NumberFormat(undefined, {
            style: 'currency',
            currency: currency,
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
          }).format(amount);
          return formatted + ' ' + currency;
        } catch (error) {
          return '$' + amount.toFixed(2) + ' ' + currency;
        }
      }

      function animateHighlight(scope) {
        var root = scope || document;
        var highlight = root.querySelector('.fsb__highlight[data-target-cents]');
        if (!highlight) return;

        var target = parseInt(highlight.getAttribute('data-target-cents'), 10);
        if (Number.isNaN(target)) return;

        var currency = highlight.getAttribute('data-currency') || 'USD';
        var previous = window.__fsbRemainingCents;

        if (typeof previous !== 'number') {
          window.__fsbRemainingCents = target;
          return;
        }

        if (previous === target) return;

        var startTime;
        var duration = 650;

        function frame(timestamp) {
          if (!startTime) startTime = timestamp;
          var progress = Math.min((timestamp - startTime) / duration, 1);
          var eased = 1 - Math.pow(1 - progress, 3);
          var current = Math.round(previous + (target - previous) * eased);

          highlight.textContent = formatMoneyWithCurrency(current, currency);

          if (progress < 1) {
            window.requestAnimationFrame(frame);
          }
        }

        window.requestAnimationFrame(frame);
        window.__fsbRemainingCents = target;
      }

      function animateProgress(scope) {
        var root = scope || document;
        var bar = root.querySelector('.free-shipping-bar[data-progress]');
        var fill = root.querySelector('.free-shipping-bar .fsb__fill');
        if (!bar) return;

        var target = parseFloat(bar.getAttribute('data-progress'));
        if (Number.isNaN(target)) return;

        var previous = window.__fsbProgressPercent;
        if (typeof previous !== 'number') previous = target;

        if (fill) fill.style.width = previous + '%';
        bar.style.setProperty('--fsb-progress-value', previous + '%');

        window.requestAnimationFrame(function () {
          if (fill) fill.style.width = target + '%';
          bar.style.setProperty('--fsb-progress-value', target + '%');
        });

        window.__fsbProgressPercent = target;
      }

      function updateCartBubbles() {
        return fetch('/cart.js', { headers: { Accept: 'application/json' } })
          .then(function (response) {
            if (!response.ok) return null;
            return response.json();
          })
          .then(function (cartState) {
            if (!cartState || typeof cartState.item_count !== 'number') return;
            var bubbles = document.querySelectorAll('.cart-count-bubble span:first-child');
            bubbles.forEach(function (bubbleText) {
              bubbleText.textContent = cartState.item_count;
            });
          })
          .catch(function () {
            return null;
          });
      }

      function refreshCartDrawerFallback() {
        return fetch('/cart?section_id=cart-drawer')
          .then(function (response) {
            if (!response.ok) throw response;
            return response.text();
          })
          .then(function (html) {
            var parser = new DOMParser();
            var doc = parser.parseFromString(html, 'text/html');
            var incoming = doc.querySelector('#CartDrawer');
            var current = document.querySelector('#CartDrawer');

            if (!incoming || !current) {
              window.location.reload();
              return;
            }

            current.replaceWith(incoming);

            var drawer = document.querySelector('cart-drawer');
            if (drawer && typeof drawer.open === 'function') {
              drawer.open();
            }

            bindUpsellSliders(incoming);
            animateProgress(incoming);
            animateHighlight(incoming);
          });
      }

      function refreshCartDrawerFromState(state) {
        var drawer = document.querySelector('cart-drawer');

        if (drawer && typeof drawer.renderContents === 'function' && state && state.sections) {
          drawer.renderContents(state);
          if (typeof drawer.open === 'function') drawer.open();

          bindUpsellSliders(document);
          animateProgress(document);
          animateHighlight(document);
          return Promise.resolve();
        }

        return refreshCartDrawerFallback();
      }

      function setAddedState(button) {
        if (!button) return;

        var textEl = button.querySelector('.fsb-upsell__add-text');
        var iconEl = button.querySelector('.fsb-upsell__add-icon');
        var defaultText = button.getAttribute('data-default-label') || 'Add';
        var addedIconSvg = '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8.5l3 3 7-7"/></svg>';

        button.classList.add('is-added');
        if (textEl) textEl.textContent = 'Added';
        if (iconEl) iconEl.innerHTML = addedIconSvg;

        setTimeout(function () {
          if (!document.body.contains(button)) return;
          button.classList.remove('is-added');
          if (textEl) textEl.textContent = defaultText;
          if (iconEl) iconEl.textContent = '+';
        }, 1200);
      }

      document.addEventListener('change', function (event) {
        var variantSelect = event.target.closest('.fsb-upsell__variant');
        if (!variantSelect) return;
        event.stopPropagation();
        event.stopImmediatePropagation();

        var parentItem = variantSelect.closest('.fsb-upsell__item');
        var addButton = parentItem ? parentItem.querySelector('.fsb-upsell__add') : null;
        if (!addButton) return;

        var selectedOption = variantSelect.options[variantSelect.selectedIndex];
        var selectedVariantId = variantSelect.value || '';
        var increment = selectedOption ? parseInt(selectedOption.getAttribute('data-qty-increment') || '1', 10) : 1;
        var minQty = selectedOption ? parseInt(selectedOption.getAttribute('data-qty-min') || '1', 10) : 1;
        if (Number.isNaN(increment) || increment < 1) increment = 1;
        if (Number.isNaN(minQty) || minQty < 1) minQty = 1;
        var qty = Math.max(increment, minQty);
        var priceEl = parentItem ? parentItem.querySelector('.fsb-upsell__price') : null;
        var selectedPrice = selectedOption ? selectedOption.getAttribute('data-price') : '';
        if (priceEl && selectedPrice) {
          priceEl.textContent = selectedPrice;
        }
        addButton.setAttribute('data-variant-id', selectedVariantId);
        addButton.setAttribute('data-quantity', String(qty));
        addButton.disabled = !selectedVariantId || !selectedOption || selectedOption.disabled || addButton.classList.contains('is-loading');
      }, true);

      document.addEventListener('click', function (event) {
        var button = event.target.closest('.fsb-upsell__add');
        if (!button || button.disabled) return;

        var sliderForButton = button.closest('.fsb-upsell') ? button.closest('.fsb-upsell').querySelector('.fsb-upsell__slider') : null;
        if (sliderForButton) {
          setSavedUpsellIndex(getActiveRealIndex(sliderForButton));
        }

        event.preventDefault();

        var parentItem = button.closest('.fsb-upsell__item');
        var variantSelect = parentItem ? parentItem.querySelector('.fsb-upsell__variant') : null;
        var variantId = parseInt(button.getAttribute('data-variant-id'), 10);
        if (variantSelect && variantSelect.value) {
          variantId = parseInt(variantSelect.value, 10);
        }
        if (Number.isNaN(variantId)) return;

        var qty = parseInt(button.getAttribute('data-quantity') || '1', 10);
        if (variantSelect && variantSelect.options[variantSelect.selectedIndex]) {
          var selectedOption = variantSelect.options[variantSelect.selectedIndex];
          var incFromOption = parseInt(selectedOption.getAttribute('data-qty-increment') || '1', 10);
          var minFromOption = parseInt(selectedOption.getAttribute('data-qty-min') || '1', 10);
          if (Number.isNaN(incFromOption) || incFromOption < 1) incFromOption = 1;
          if (Number.isNaN(minFromOption) || minFromOption < 1) minFromOption = 1;
          qty = Math.max(qty, incFromOption, minFromOption);
        }
        if (Number.isNaN(qty) || qty < 1) qty = 1;

        button.disabled = true;
        button.classList.add('is-loading');

        var payload = {
          id: variantId,
          quantity: qty
        };

        var drawer = document.querySelector('cart-drawer');
        if (drawer && typeof drawer.getSectionsToRender === 'function') {
          var sectionIds = drawer
            .getSectionsToRender()
            .map(function (section) {
              return section.section || section.id;
            })
            .filter(Boolean);

          if (sectionIds.length) {
            payload.sections = sectionIds;
            payload.sections_url = window.location.pathname;
          }
        }

        fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json'
          },
          body: JSON.stringify(payload)
        })
          .then(function (response) {
            return response.json().then(function (state) {
              if (!response.ok) throw state;
              return state;
            });
          })
          .then(function (state) {
            setAddedState(button);
            return new Promise(function (resolve) {
              setTimeout(function () {
                resolve(state);
              }, 650);
            });
          })
          .then(function (state) {
            return refreshCartDrawerFromState(state);
          })
          .then(function () {
            return updateCartBubbles();
          })
          .catch(function () {
            button.disabled = false;
            button.classList.remove('is-loading');
          })
          .finally(function () {
            if (document.body.contains(button)) {
              button.disabled = false;
              button.classList.remove('is-loading');
            }
          });
      });

      var rebindScheduled = false;

      function rebindFreeShipping(scope) {
        var root = scope || document;
        bindUpsellSliders(root);
        animateProgress(root);
        animateHighlight(root);
      }

      function scheduleRebind(scope) {
        if (rebindScheduled) return;
        rebindScheduled = true;
        window.requestAnimationFrame(function () {
          rebindScheduled = false;
          rebindFreeShipping(scope || document);
        });
      }

      function hasRelevantNode(node) {
        if (!node || node.nodeType !== 1) return false;

        if (
          node.matches &&
          (
            node.matches('#CartDrawer') ||
            node.matches('.free-shipping-bar') ||
            node.matches('.fsb-upsell__slider') ||
            node.matches('cart-drawer') ||
            node.matches('cart-drawer-items')
          )
        ) {
          return true;
        }

        if (node.querySelector) {
          return Boolean(
            node.querySelector(
              '#CartDrawer, .free-shipping-bar, .fsb-upsell__slider, cart-drawer, cart-drawer-items'
            )
          );
        }

        return false;
      }

      function watchCartDrawerMutations() {
        if (window.__fsbMutationObserverBound || !window.MutationObserver || !document.body) return;
        window.__fsbMutationObserverBound = true;

        var observer = new MutationObserver(function (mutations) {
          var shouldRebind = false;

          for (var i = 0; i < mutations.length; i += 1) {
            var mutation = mutations[i];
            if (!mutation.addedNodes || mutation.addedNodes.length === 0) continue;

            for (var j = 0; j < mutation.addedNodes.length; j += 1) {
              if (hasRelevantNode(mutation.addedNodes[j])) {
                shouldRebind = true;
                break;
              }
            }

            if (shouldRebind) break;
          }

          if (shouldRebind) scheduleRebind(document);
        });

        observer.observe(document.body, { childList: true, subtree: true });
      }

      document.addEventListener('shopify:section:load', function (event) {
        scheduleRebind(event.target || document);
      });

      ['cart:refresh', 'cart:updated', 'cart:update', 'cart:change'].forEach(function (eventName) {
        document.addEventListener(eventName, function () {
          scheduleRebind(document);
        });
      });

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function () {
          rebindFreeShipping(document);
          watchCartDrawerMutations();
        });
      } else {
        rebindFreeShipping(document);
        watchCartDrawerMutations();
      }
    })();
  </script>
{%- endif -%}
