    .fsb-upsell__add-icon svg {
      width: 13px;
      height: 13px;
      display: block;
    }

    .fsb-upsell__add:hover {
      transform: translateY(-1px);
      background: rgba(255, 255, 255, 0.12);
      border-color: rgba(148, 163, 184, 0.8);
