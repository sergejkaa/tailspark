{{ 'section-hero-elite.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign has_desktop_image = false
  assign has_mobile_image  = false

  if section.settings.image_desktop != blank
    assign has_desktop_image = true
  endif
  if section.settings.image_mobile != blank
    assign has_mobile_image = true
  endif

  assign has_separate_mobile = false
  if has_mobile_image or section.settings.video_mobile != blank or section.settings.video_url_mobile != blank
    assign has_separate_mobile = true
  endif

  assign scroll_block = nil
  for block in section.blocks
    if block.type == 'scroll_indicator'
      assign scroll_block = block
    endif
  endfor
-%}

{%- style -%}
  #HeroElite-{{ section.id }} {
    --hero-content-padding: {{ section.settings.content_padding }}px;
    --hero-content-max-width: {{ section.settings.content_max_width }}px;
    --hero-content-gap: {{ section.settings.content_gap }}px;
    --hero-content-gap-mobile: {{ section.settings.content_gap_mobile | default: 16 }}px;
    --hero-anim-duration: {{ section.settings.animation_duration }}ms;
    --hero-height-mobile: {{ section.settings.height_mobile }}vh;
    --hero-height-desktop: {{ section.settings.height_desktop }}vh;
  }
  {%- if scroll_block != nil -%}
  {%- assign sc_d = scroll_block.settings.scroll_size_desktop | default: 44 -%}
  {%- assign sc_m = scroll_block.settings.scroll_size_mobile  | default: 40 -%}
  #HeroElite-{{ section.id }} {
    --hero-scroll-size-desktop: {{ sc_d }}px;
    --hero-scroll-size-mobile: {{ sc_m }}px;
  }
  {%- endif -%}
{%- endstyle -%}

{%- comment -%} ── Compute overlay inline background ── {%- endcomment -%}
{%- liquid
  assign overlay_gradient    = section.settings.overlay_gradient | default: 'none'
  assign overlay_opacity_val = section.settings.overlay_opacity | default: 35 | times: 0.01
  assign overlay_color_val   = section.settings.overlay_color | default: '#000000'
  assign ov_hi = overlay_opacity_val | times: 1.0
  assign ov_md = overlay_opacity_val | times: 0.55
  assign ov_lo = overlay_opacity_val | times: 0.12
-%}

{%- capture overlay_bg -%}
  {%- if overlay_gradient == 'none' -%}
    background:{{ overlay_color_val }};opacity:{{ overlay_opacity_val }};
  {%- elsif overlay_gradient == 'bottom' -%}
    background:linear-gradient(to top, rgba(0,0,0,{{ ov_hi }}) 0%, rgba(0,0,0,{{ ov_md }}) 35%, rgba(0,0,0,{{ ov_lo }}) 65%, transparent 100%);
  {%- elsif overlay_gradient == 'top' -%}
    background:linear-gradient(to bottom, rgba(0,0,0,{{ ov_hi }}) 0%, rgba(0,0,0,{{ ov_md }}) 35%, transparent 100%);
  {%- elsif overlay_gradient == 'center' -%}
    background:radial-gradient(ellipse at center, transparent 25%, rgba(0,0,0,{{ ov_hi | times: 0.85 }}) 100%);
  {%- elsif overlay_gradient == 'left' -%}
    background:linear-gradient(to right, rgba(0,0,0,{{ ov_hi }}) 0%, rgba(0,0,0,{{ ov_md | times: 0.6 }}) 45%, transparent 100%);
  {%- elsif overlay_gradient == 'right' -%}
    background:linear-gradient(to left, rgba(0,0,0,{{ ov_hi }}) 0%, rgba(0,0,0,{{ ov_md | times: 0.6 }}) 45%, transparent 100%);
  {%- endif -%}
{%- endcapture -%}

<section
  id="HeroElite-{{ section.id }}"
  class="hero-elite
    hero-elite--pos-{{ section.settings.content_position }}
    hero-elite--mobile-pos-{{ section.settings.mobile_content_position }}
    hero-elite--align-{{ section.settings.content_alignment }}
    hero-elite--mobile-align-{{ section.settings.mobile_content_alignment }}
    hero-elite--anim-{{ section.settings.animation_style }}
    {% if section.settings.show_text_box %} hero-elite--has-box{% endif %}
    {% if section.settings.rounded_bottom %} hero-elite--rounded-bottom{% endif %}
    {% if section.settings.show_text_below_on_mobile %} hero-elite--mobile-text-below{% endif %}
    {% if has_separate_mobile == false %} hero-elite--no-separate-mobile{% endif %}
    {% if scroll_block != nil %} hero-elite--has-scroll{% endif %}"
  aria-label="{{ section.settings.accessibility_info | default: shop.name | escape }}"
>

  {%- comment -%} ── MEDIA + OVERLAY ── {%- endcomment -%}
  <div class="hero-elite__media-wrap">

    {%- comment -%} Desktop media {%- endcomment -%}
    <div class="hero-elite__media hero-elite__media--desktop hero-elite__media--behavior-{{ section.settings.image_behavior }}">
      {%- if section.settings.video_desktop != blank -%}
        {{
          section.settings.video_desktop
          | video_tag:
            autoplay: section.settings.video_autoplay,
            loop: section.settings.video_loop,
            muted: true,
            playsinline: true,
            class: 'hero-elite__video'
        }}
      {%- elsif section.settings.video_url_desktop != blank -%}
        <video
          class="hero-elite__video"
          src="{{ section.settings.video_url_desktop }}"
          {% if section.settings.video_autoplay %}autoplay{% endif %}
          {% if section.settings.video_loop %}loop{% endif %}
          muted
          playsinline
          {% if has_desktop_image %}poster="{{ section.settings.image_desktop | image_url: width: 1920 }}"{% endif %}
        ></video>
      {%- elsif has_desktop_image -%}
        {{
          section.settings.image_desktop
          | image_url: width: 3840
          | image_tag:
            class: 'hero-elite__img',
            loading: 'eager',
            fetchpriority: 'high',
            sizes: '100vw',
            widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
        }}
      {%- else -%}
        {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg hero-elite__placeholder' }}
      {%- endif -%}
    </div>

    {%- comment -%} Mobile media (only rendered if set separately) {%- endcomment -%}
    {%- if has_separate_mobile -%}
      <div class="hero-elite__media hero-elite__media--mobile hero-elite__media--behavior-{{ section.settings.image_behavior }}">
        {%- if section.settings.video_mobile != blank -%}
          {{
            section.settings.video_mobile
            | video_tag:
              autoplay: section.settings.video_autoplay,
              loop: section.settings.video_loop,
              muted: true,
              playsinline: true,
              class: 'hero-elite__video'
          }}
        {%- elsif section.settings.video_url_mobile != blank -%}
          <video
            class="hero-elite__video"
            src="{{ section.settings.video_url_mobile }}"
            {% if section.settings.video_autoplay %}autoplay{% endif %}
            {% if section.settings.video_loop %}loop{% endif %}
            muted
            playsinline
            {% if has_mobile_image %}poster="{{ section.settings.image_mobile | image_url: width: 750 }}"{% endif %}
          ></video>
        {%- elsif has_mobile_image -%}
          {{
            section.settings.image_mobile
            | image_url: width: 1100
            | image_tag:
              class: 'hero-elite__img',
              loading: 'eager',
              fetchpriority: 'high',
              sizes: '100vw',
              widths: '375, 550, 750, 1100'
          }}
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Overlay — INSIDE media-wrap, on top of images {%- endcomment -%}
    <div class="hero-elite__overlay" style="position:absolute;inset:0;display:block;pointer-events:none;{{ overlay_bg | strip }}"></div>

  </div>

  {%- comment -%} ── CONTENT ── {%- endcomment -%}
  <div class="hero-elite__content-outer page-width">
    <div class="hero-elite__content-box color-{{ section.settings.color_scheme }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'scroll_indicator' -%}{%- continue -%}{%- endif -%}
        {%- liquid
          assign delay = forloop.index | times: 0.14 | plus: 0.05
          assign delay_s = delay | append: 's'
        -%}
        {%- render 'hero-elite-block', block: block, delay_s: delay_s -%}
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} ── SCROLL INDICATOR — fixed bottom center ── {%- endcomment -%}
  {%- if scroll_block != nil -%}
    {%- liquid
      assign sc_delay = section.blocks.size | times: 0.14 | plus: 0.4
      assign sc_delay_s = sc_delay | append: 's'
      assign arrow_color = scroll_block.settings.arrow_color | default: '#ffffff'
      assign sc_icon = scroll_block.settings.scroll_icon_style | default: 'arrow'
      assign sc_anim = scroll_block.settings.scroll_anim_style | default: 'bounce'
    -%}
    <div
      class="hero-elite__scroll-anchor hero-elite__anim"
      data-scroll-icon="{{ sc_icon }}"
      data-scroll-anim="{{ sc_anim }}"
      style="animation-delay: {{ sc_delay_s }}"
      {{ scroll_block.shopify_attributes }}
    >
      <button
        class="hero-elite__scroll-btn"
        style="color: {{ arrow_color }}; border-color: {{ arrow_color }};"
        onclick="window.scrollBy({ top: window.innerHeight * 0.85, behavior: 'smooth' })"
        aria-label="Scroll down"
        type="button"
      >
        {%- case sc_icon -%}
          {%- when 'chevron' -%}
            <svg viewBox="0 0 22 22" fill="none" aria-hidden="true"><path d="M4.5 8.5l6.5 6.5 6.5-6.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {%- when 'double_chevron' -%}
            <svg viewBox="0 0 22 22" fill="none" aria-hidden="true"><path d="M4.5 6.5l6.5 5.5 6.5-5.5M4.5 12l6.5 5.5 6.5-5.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {%- else -%}
            <svg viewBox="0 0 22 22" fill="none" aria-hidden="true"><path d="M11 3v16M3.5 11.5l7.5 7.5 7.5-7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        {%- endcase -%}
      </button>
    </div>
  {%- endif -%}

</section>

<script>
  (function () {
    var hero = document.getElementById('HeroElite-{{ section.id }}');
    if (!hero) return;

    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        hero.classList.add('hero-elite--loaded');
      });
    });

    hero.querySelectorAll('video.hero-elite__video').forEach(function (v) {
      v.play().catch(function () {});
    });

    {%- if section.settings.image_behavior == 'parallax' -%}
    var mediaEls = hero.querySelectorAll(
      '.hero-elite__media--behavior-parallax .hero-elite__img, .hero-elite__media--behavior-parallax .hero-elite__video'
    );
    if (mediaEls.length && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      function heroParallax() {
        var rect = hero.getBoundingClientRect();
        if (rect.top >= window.innerHeight || rect.bottom <= 0) return;
        var progress = (window.innerHeight - rect.top) / (window.innerHeight + rect.height);
        var offset = (progress - 0.5) * 80;
        mediaEls.forEach(function (el) {
          el.style.transform = 'translateY(' + offset + 'px) scale(1.12)';
        });
      }
      window.addEventListener('scroll', heroParallax, { passive: true });
      heroParallax();
    }
    {%- endif -%}
  })();
</script>

{% schema %}
{
  "name": "Hero Elite",
  "tag": "section",
  "class": "section hero-elite-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "📸 Desktop Media"
    },
    {
      "type": "paragraph",
      "content": "2560×1440px recommended."
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop image"
    },
    {
      "type": "video",
      "id": "video_desktop",
      "label": "Desktop video (upload)"
    },
    {
      "type": "text",
      "id": "video_url_desktop",
      "label": "Desktop video — external URL (.mp4)",
      "info": "Upload video takes priority if both are set."
    },
    {
      "type": "header",
      "content": "📱 Mobile Media"
    },
    {
      "type": "paragraph",
      "content": "750×1334px (portrait) recommended. If blank, desktop media is used."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image"
    },
    {
      "type": "video",
      "id": "video_mobile",
      "label": "Mobile video (upload)"
    },
    {
      "type": "text",
      "id": "video_url_mobile",
      "label": "Mobile video — external URL (.mp4)"
    },
    {
      "type": "header",
      "content": "🎬 Video Settings"
    },
    {
      "type": "checkbox",
      "id": "video_autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "header",
      "content": "✨ Image / Video Effect"
    },
    {
      "type": "select",
      "id": "image_behavior",
      "label": "Media effect",
      "options": [
        { "value": "none",     "label": "None" },
        { "value": "zoom-in",  "label": "Slow zoom on load" },
        { "value": "ambient",  "label": "Ambient float" },
        { "value": "parallax", "label": "Parallax scroll" },
        { "value": "fixed",    "label": "Fixed background" }
      ],
      "default": "zoom-in"
    },
    {
      "type": "header",
      "content": "🎨 Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 35
    },
    {
      "type": "select",
      "id": "overlay_gradient",
      "label": "Overlay shape",
      "options": [
        { "value": "none",   "label": "Solid — uniform" },
        { "value": "bottom", "label": "Gradient — darker at bottom" },
        { "value": "top",    "label": "Gradient — darker at top" },
        { "value": "center", "label": "Gradient — vignette edges" },
        { "value": "left",   "label": "Gradient — darker on left" },
        { "value": "right",  "label": "Gradient — darker on right" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "📐 Height"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Height — desktop",
      "default": 85
    },
    {
      "type": "range",
      "id": "height_mobile",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Height — mobile",
      "default": 70
    },
    {
      "type": "header",
      "content": "📍 Content Position & Alignment"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Position (desktop)",
      "options": [
        { "value": "top-left",      "label": "Top — left" },
        { "value": "top-center",    "label": "Top — center" },
        { "value": "top-right",     "label": "Top — right" },
        { "value": "middle-left",   "label": "Middle — left" },
        { "value": "middle-center", "label": "Middle — center" },
        { "value": "middle-right",  "label": "Middle — right" },
        { "value": "bottom-left",   "label": "Bottom — left" },
        { "value": "bottom-center", "label": "Bottom — center" },
        { "value": "bottom-right",  "label": "Bottom — right" }
      ],
      "default": "middle-center"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Text alignment (desktop)",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
