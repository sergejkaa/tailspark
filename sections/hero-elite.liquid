    {
      "type": "range",
      "id": "content_gap_mobile",
      "min": 4,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Gap — mobile",
      "default": 16
    },
    {
      "type": "header",
      "content": "📱 Content Position — Mobile"
    },
    {
      "type": "select",
      "id": "mobile_content_position",
      "label": "Position (mobile)",
      "options": [
        { "value": "top-left",      "label": "Top — left" },
        { "value": "top-center",    "label": "Top — center" },
        { "value": "top-right",     "label": "Top — right" },
        { "value": "middle-left",   "label": "Middle — left" },
        { "value": "middle-center", "label": "Middle — center" },
        { "value": "middle-right",  "label": "Middle — right" },
        { "value": "bottom-left",   "label": "Bottom — left" },
        { "value": "bottom-center", "label": "Bottom — center" },
        { "value": "bottom-right",  "label": "Bottom — right" }
      ],
      "default": "middle-center"
    },
    {
      "type": "select",
      "id": "mobile_content_alignment",
      "label": "Text alignment (mobile)",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "show_text_below_on_mobile",
      "label": "Show text below image on mobile",
      "default": false
    },
    {
      "type": "header",
      "content": "🎨 Color Scheme"
    },
    {
      "type": "checkbox",
      "id": "show_text_box",
      "label": "Show background box behind text",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "🎞 Animations"
    },
    {
      "type": "select",
      "id": "animation_style",
      "label": "Content entrance",
      "options": [
        { "value": "fade-up",    "label": "Fade up (elegant)" },
        { "value": "fade-in",    "label": "Fade in (subtle)" },
        { "value": "fade-left",  "label": "Slide from right" },
        { "value": "fade-right", "label": "Slide from left" },
        { "value": "zoom-in",    "label": "Zoom in" }
      ],
      "default": "fade-up"
    },
    {
      "type": "range",
      "id": "animation_duration",
      "min": 400,
      "max": 1600,
      "step": 100,
      "unit": "ms",
      "label": "Animation speed",
      "default": 900
    },
    {
      "type": "header",
      "content": "⚙️ Other"
    },
    {
      "type": "checkbox",
      "id": "rounded_bottom",
      "label": "Rounded bottom corners",
      "default": false
    },
    {
      "type": "text",
      "id": "accessibility_info",
      "label": "Accessibility label",
      "default": "Hero section"
    }
  ],
  "blocks": [
    {
      "type": "eyebrow",
      "name": "Eyebrow label",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "New Collection"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "info": "Leave empty to use color scheme"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading text",
          "default": "Elegant by Nature"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "Heading size",
          "options": [
            { "value": "h2",   "label": "Small" },
            { "value": "h1",   "label": "Medium" },
            { "value": "h0",   "label": "Large" },
            { "value": "hxl",  "label": "Extra large" },
            { "value": "hxxl", "label": "2XL — display" }
          ],
          "default": "hxl"
        },
        {
          "type": "select",
          "id": "heading_tag",
          "label": "HTML tag (SEO)",
