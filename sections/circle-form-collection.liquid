{%- liquid
  assign hover_scale = section.settings.hover_scale | default: 6
-%}

<section
  id="circle-menu-{{ section.id }}"
  class="circle-menu color-{{ section.settings.color_scheme | default: 'background-1' }}{% if section.settings.full_width %} circle-menu--full{% endif %}"
  style="
    --cm-heading-gap: {{ section.settings.heading_gap | default: 24 }}px;
    --cm-subheading-size: {{ section.settings.subheading_size | default: 18 }}px;
    --cm-mobile-dots-size: {{ section.settings.mobile_dots_size | default: 8 }}px;
    --cm-mobile-dots-color: {{ section.settings.mobile_dots_color | default: '#FFFFFF' }};
    background: {{ section.settings.background | default: 'transparent' }};
    padding-top: {{ section.settings.padding_top | default: 32 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 32 }}px;
  "
>
  <div
    class="circle-menu__inner {% if section.settings.full_width %}circle-menu__inner--full{% endif %}{% if section.settings.enable_page_width or section.settings.full_width == false %} page-width{% endif %}"
    style="max-width: {{ section.settings.max_width | default: 1180 }}px;"
  >
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="circle-menu__header text-{{ section.settings.text_align }}">
        {%- if section.settings.heading != blank -%}
          <h2 class="circle-menu__heading {{ section.settings.heading_size }} circle-menu__reveal" style="--cm-reveal-delay: 70ms;{% if section.settings.heading_color != blank %} color: {{ section.settings.heading_color }};{% endif %}">
            {{ section.settings.heading | escape }}
          </h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="circle-menu__subheading circle-menu__reveal" style="--cm-reveal-delay: 180ms;{% if section.settings.subheading_color != blank %} color: {{ section.settings.subheading_color }};{% endif %}{% if section.settings.max_width_text != blank %} max-width: {{ section.settings.max_width_text }}px;{% endif %}">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="circle-menu__shell">
      <div
        class="circle-menu__list"
        data-circle-menu-list
        style="
          --cm-size: {{ section.settings.circle_size }}px;
          --cm-gap: {{ section.settings.gap_desktop }}px;
          --cm-gap-mobile: {{ section.settings.gap_mobile }}px;
          --cm-border: {{ section.settings.border_width }}px;
          --cm-border-color: {{ section.settings.border_color }};
          --cm-label-size-desktop: {{ section.settings.label_size_desktop | default: 16 }}px;
          --cm-label-size-mobile: {{ section.settings.label_size_mobile | default: 16 }}px;
          --cm-label-weight: {{ section.settings.label_weight }};
          --cm-label-color: {{ section.settings.label_color }};
          --cm-inner-gap: {{ section.settings.item_gap }}px;
          --cm-cell-extra: {{ section.settings.item_padding }}px;
          --cm-shadow: {% if section.settings.show_shadow %}0 12px 28px rgba(0,0,0,0.12){% else %}none{% endif %};
          --cm-hover-raise: {{ section.settings.hover_lift }}px;
          --cm-hover-scale: calc(1 + {{ hover_scale | default: 6 }} / 100);
          --cm-image-bg: {{ section.settings.image_background | default: 'linear-gradient(135deg, #ffffff 0%, #f7f7f7 100%)' }};
          --cm-text-align: {{ section.settings.text_align }};
        "
        aria-label="{{ section.settings.heading | default: 'Collections' | escape }}"
      >
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- assign collection = block.settings.collection -%}
            {%- assign item_title = block.settings.title | default: collection.title | default: 'Collection' -%}
            {%- assign item_url = block.settings.url | default: collection.url | default: '#' -%}
            {%- assign chosen_image = block.settings.custom_image -%}
            {%- if chosen_image == blank and block.settings.use_collection_image and collection and collection.image -%}
              {%- assign chosen_image = collection.image -%}
            {%- elsif chosen_image == blank and block.settings.use_collection_image and collection and collection.products.first and collection.products.first.featured_image -%}
              {%- assign chosen_image = collection.products.first.featured_image -%}
            {%- endif -%}

            <article class="circle-menu__item circle-menu__reveal" style="--cm-reveal-delay: {{ forloop.index0 | times: 95 | plus: 260 }}ms;" {{ block.shopify_attributes }}>
              <a
                class="circle-menu__link"
                href="{{ item_url }}"
                aria-label="{{ item_title | escape }}"
                {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %}
              >
                <span class="circle-menu__media{% if chosen_image == blank %} circle-menu__media--placeholder{% endif %}" style="{% if block.settings.border_color_override != blank %}--cm-border-color: {{ block.settings.border_color_override }};{% endif %}">
                  {%- if chosen_image -%}
                    {{ chosen_image | image_url: width: 480, height: 480, crop: 'center' | image_tag:
                      class: 'circle-menu__img',
                      widths: '220,320,480,640',
                      sizes: '(min-width: 1080px) 220px, (min-width: 768px) 180px, 45vw',
                      alt: item_title,
                      loading: 'lazy'
                    }}
                  {%- else -%}
                    {{ 'collection-1' | placeholder_svg_tag: 'circle-menu__placeholder' }}
                  {%- endif -%}
                </span>
                <span class="circle-menu__label">{{ item_title }}</span>
              </a>
            </article>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..6) -%}
            <article class="circle-menu__item circle-menu__item--empty circle-menu__reveal" style="--cm-reveal-delay: {{ forloop.index0 | times: 95 | plus: 260 }}ms;">
              <div class="circle-menu__link" role="presentation">
                <span class="circle-menu__media circle-menu__media--placeholder">
                  {{ 'collection-' | append: i | placeholder_svg_tag: 'circle-menu__placeholder' }}
                </span>
                <span class="circle-menu__label">Collection {{ i }}</span>
              </div>
            </article>
          {%- endfor -%}
        {%- endif -%}
      </div>

      {%- if section.settings.show_mobile_dots -%}
        <div class="circle-menu__mobile-dots" data-circle-menu-dots aria-label="{{ 'general.accessibility.slider' | t | default: 'Slider pagination' }}">
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #circle-menu-{{ section.id }} {
    --cm-base-font: var(--font-heading-family, var(--font-body-family, 'Helvetica Neue', 'Helvetica', 'Arial', sans-serif));
  }

  #circle-menu-{{ section.id }} .circle-menu__inner {
    margin: 0 auto;
  }

  #circle-menu-{{ section.id }} .circle-menu__header {
    display: grid;
    gap: 0.5rem;
    margin-bottom: var(--cm-heading-gap, 24px);
    text-align: var(--cm-text-align, center);
  }

  #circle-menu-{{ section.id }} .circle-menu__heading {
    margin: 0;
    letter-spacing: -0.01em;
  }

  #circle-menu-{{ section.id }} .circle-menu__subheading {
    margin: 0 auto;
    font-size: var(--cm-subheading-size, 18px);
    line-height: 1.6;
    color: rgba(23, 23, 23, 0.72);
    text-align: var(--cm-text-align, center);
  }

  #circle-menu-{{ section.id }} .circle-menu__shell {
    position: relative;
  }

  #circle-menu-{{ section.id }} .circle-menu__list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(var(--cm-size), 1fr));
    gap: var(--cm-gap);
    align-items: flex-start;
  }

  #circle-menu-{{ section.id }} .circle-menu__item {
    list-style: none;
    scroll-snap-align: center;
  }

  #circle-menu-{{ section.id }}.cm-animate .circle-menu__reveal {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.72s cubic-bezier(0.2, 0.65, 0.3, 1),
      transform 0.72s cubic-bezier(0.2, 0.65, 0.3, 1);
    transition-delay: var(--cm-reveal-delay, 0ms);
    will-change: opacity, transform;
  }

  #circle-menu-{{ section.id }}.cm-animate.is-visible .circle-menu__reveal {
    opacity: 1;
    transform: translateY(0);
  }

  #circle-menu-{{ section.id }} .circle-menu__link {
    display: grid;
    gap: var(--cm-inner-gap);
    justify-items: center;
    text-decoration: none;
    color: inherit;
    font-family: var(--cm-base-font);
    text-align: center;
  }

  #circle-menu-{{ section.id }} .circle-menu__media {
    position: relative;
    width: var(--cm-size);
    height: var(--cm-size);
    border-radius: 50%;
    overflow: hidden;
    clip-path: circle(50% at 50% 50%);
    border: var(--cm-border) solid var(--cm-border-color);
    background: var(--cm-image-bg);
    box-shadow: var(--cm-shadow);
    display: grid;
    place-items: center;
    transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
  }

  #circle-menu-{{ section.id }} .circle-menu__img {
    position: absolute !important;
    inset: 0 !important;
    width: 100% !important;
    height: 100% !important;
    min-width: 100%;
    min-height: 100%;
    max-width: none !important;
    max-height: none !important;
    border-radius: inherit;
    object-fit: cover !important;
    object-position: center !important;
    display: block !important;
    transform: scale(1.06);
  }

  #circle-menu-{{ section.id }} .circle-menu__placeholder {
    width: 55%;
    height: 55%;
    opacity: 0.28;
  }

  #circle-menu-{{ section.id }} .circle-menu__label {
    font-size: var(--cm-label-size-desktop);
    font-weight: var(--cm-label-weight);
    color: var(--cm-label-color);
    line-height: 1.35;
    max-width: 14ch;
  }

  #circle-menu-{{ section.id }} .circle-menu__link:hover .circle-menu__media,
  #circle-menu-{{ section.id }} .circle-menu__link:focus-visible .circle-menu__media {
    transform: translateY(calc(var(--cm-hover-raise) * -1)) scale(var(--cm-hover-scale));
    box-shadow: 0 16px 32px rgba(0, 0, 0, 0.16);
  }

  #circle-menu-{{ section.id }} .circle-menu__link:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 6px;
  }

  #circle-menu-{{ section.id }} .circle-menu__mobile-dots {
    display: none;
  }

  #circle-menu-{{ section.id }} .circle-menu__mobile-dot {
    display: block;
    width: var(--cm-mobile-dots-size, 8px);
    height: var(--cm-mobile-dots-size, 8px);
    min-width: 0;
    min-height: 0;
    border-radius: 999px;
    border: 0;
    padding: 0;
    margin: 0;
    background: var(--cm-mobile-dots-color, #FFFFFF);
    opacity: 0.4;
    cursor: pointer;
    flex-shrink: 0;
    transition: width 0.25s ease, opacity 0.25s ease;
    -webkit-appearance: none;
    appearance: none;
    box-sizing: content-box;
    line-height: 0;
    font-size: 0;
    overflow: hidden;
  }

  #circle-menu-{{ section.id }} .circle-menu__mobile-dot.is-active {
    width: calc(var(--cm-mobile-dots-size, 8px) * 3);
    opacity: 1;
  }

  #circle-menu-{{ section.id }} .circle-menu__mobile-dot:focus-visible {
    outline: 2px solid var(--cm-mobile-dots-color, #FFFFFF);
    outline-offset: 2px;
  }

  @media (max-width: 1080px) {
    #circle-menu-{{ section.id }}.cm-can-scroll .circle-menu__mobile-dots {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 0.8rem;
      margin-top: 12px;
    }

    #circle-menu-{{ section.id }} .circle-menu__list {
      grid-auto-flow: column;
      grid-auto-columns: var(--cm-size);
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
      gap: var(--cm-gap-mobile);
      padding-bottom: 12px;
      margin: 0 -12px;
      padding-left: 12px;
      padding-right: 12px;
      scrollbar-width: none; /* Firefox */
      -ms-overflow-style: none; /* IE/Edge */
    }
    #circle-menu-{{ section.id }} .circle-menu__list::-webkit-scrollbar {
      width: 0;
      height: 0;
    }

    #circle-menu-{{ section.id }} .circle-menu__item {
      scroll-snap-align: start;
    }
  }

  @media (max-width: 640px) {
    #circle-menu-{{ section.id }} .circle-menu__header {
      text-align: center;
      gap: 0.35rem;
    }

    #circle-menu-{{ section.id }} .circle-menu__label {
      max-width: 14ch;
    }
  }

  @media (max-width: 749px) {
    #circle-menu-{{ section.id }} .circle-menu__label {
      font-size: var(--cm-label-size-mobile);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #circle-menu-{{ section.id }}.cm-animate .circle-menu__reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  (() => {
    const section = document.querySelector('#circle-menu-{{ section.id }}');
    if (!section) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!prefersReducedMotion) {
      section.classList.add('cm-animate');
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              section.classList.add('is-visible');
              obs.disconnect();
            });
          },
          { threshold: 0.18, rootMargin: '0px 0px -20% 0px' }
        );
        observer.observe(section);
      } else {
        section.classList.add('is-visible');
      }
    } else {
      section.classList.add('is-visible');
    }

    const scroller = section.querySelector('[data-circle-menu-list]');
    const dotsContainer = section.querySelector('[data-circle-menu-dots]');
    const mobileQuery = window.matchMedia('(max-width: 1080px)');
    const step = () => scroller ? Math.max(scroller.clientWidth * 0.55, 160) : 220;
    let dots = [];
    const buildDots = (count) => {
      if (!dotsContainer) return;
      dotsContainer.innerHTML = '';
      dots = [];

      for (let index = 0; index < count; index += 1) {
        const dot = document.createElement('button');
        dot.type = 'button';
        dot.className = 'circle-menu__mobile-dot';
        dot.setAttribute('aria-label', `Go to slide ${index + 1}`);
        dot.addEventListener('click', () => {
          if (!scroller) return;
          const maxScrollLeft = Math.max(scroller.scrollWidth - scroller.clientWidth, 0);
          const target = count > 1 ? (maxScrollLeft / (count - 1)) * index : 0;
          scroller.scrollTo({ left: target, behavior: 'smooth' });
        });
        dotsContainer.append(dot);
        dots.push(dot);
      }
    };
    const updateDots = () => {
      if (!scroller) return;

      const maxScrollLeft = Math.max(scroller.scrollWidth - scroller.clientWidth, 0);
      const canScroll = maxScrollLeft > 4;
      const shouldShowDots = Boolean(dotsContainer) && mobileQuery.matches && canScroll;
      section.classList.toggle('cm-can-scroll', shouldShowDots);

      if (!dotsContainer) return;
      if (!shouldShowDots) {
        dotsContainer.innerHTML = '';
        dots = [];
        return;
      }

      const dotCount = Math.max(2, Math.round(maxScrollLeft / step()) + 1);
      if (dots.length !== dotCount) buildDots(dotCount);

      const activeIndex = dotCount > 1
        ? Math.round((scroller.scrollLeft / maxScrollLeft) * (dotCount - 1))
        : 0;

      dots.forEach((dot, index) => {
        const isActive = index === activeIndex;
        dot.classList.toggle('is-active', isActive);
        dot.setAttribute('aria-current', isActive ? 'true' : 'false');
      });
    };

    if (scroller) {
      updateDots();
      scroller.addEventListener('scroll', updateDots, { passive: true });
      window.addEventListener('resize', updateDots);
      if (typeof mobileQuery.addEventListener === 'function') {
        mobileQuery.addEventListener('change', updateDots);
      }
    }
  })();
</script>

{% schema %}
{
  "name": "Circle Collection Menu",
  "tag": "section",
  "class": "section circle-menu-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by vibe"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Pick a collection that matches your moment."
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size (px)",
      "min": 12,
      "max": 40,
      "step": 1,
      "default": 18
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {
          "value": "h3",
          "label": "Small (h3)"
        },
        {
          "value": "h2",
          "label": "Medium (h2)"
        },
        {
          "value": "h1",
          "label": "Large (h1)"
        },
        {
          "value": "h0",
          "label": "Hero (h0)"
        }
      ],
      "default": "h2"
    },
    {
      "type": "range",
      "id": "heading_gap",
      "label": "Heading bottom spacing (px)",
      "min": 0,
      "max": 120,
      "step": 2,
      "default": 24
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#101010"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#3A3A3A"
    },
    {
      "type": "range",
      "id": "max_width_text",
      "label": "Subheading max width (px)",
      "min": 320,
      "max": 900,
      "step": 20,
      "default": 640
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text & menu alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Edge-to-edge background",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_page_width",
      "label": "Page width",
      "default": false
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Content max width (px)",
      "min": 780,
      "max": 1600,
      "step": 20,
      "default": 1180
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "circle_size",
      "label": "Circle diameter (px)",
      "min": 96,
      "max": 260,
      "step": 4,
      "default": 160
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "label": "Gap desktop (px)",
      "min": 8,
      "max": 80,
      "step": 2,
      "default": 22
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Gap mobile (px)",
      "min": 6,
      "max": 40,
      "step": 2,
      "default": 16
    },
    {
      "type": "range",
      "id": "item_padding",
      "label": "Inner padding of item (px)",
      "min": 0,
      "max": 32,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width (px)",
      "min": 0,
      "max": 10,
      "step": 1,
      "default": 2
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#111111"
    },
    {
      "type": "checkbox",
      "id": "show_shadow",
      "label": "Soft shadow behind circles",
      "default": true
    },
    {
      "type": "color",
      "id": "image_background",
      "label": "Image background/fill",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Gap between image and label (px)",
      "min": 0,
      "max": 24,
      "step": 1,
      "default": 6
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "options": [
        {
          "value": "cover",
          "label": "Cover (edge-to-edge)"
        },
        {
          "value": "contain",
          "label": "Contain (show full pack)"
        }
      ],
      "default": "cover"
    },
    {
      "type": "range",
      "id": "label_size_desktop",
      "label": "Label size desktop (px)",
      "min": 10,
      "max": 40,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "label_size_mobile",
      "label": "Label size mobile (px)",
      "min": 10,
      "max": 40,
      "step": 1,
      "default": 16
    },
    {
      "type": "select",
      "id": "label_weight",
      "label": "Label weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "500"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#1A1A1A"
    },
    {
      "type": "range",
      "id": "hover_lift",
      "label": "Hover lift (px)",
      "min": 0,
      "max": 18,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "hover_scale",
      "label": "Hover scale (%)",
      "min": 0,
      "max": 18,
      "step": 1,
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "show_mobile_dots",
      "label": "Show slider dots on mobile",
      "default": true
    },
    {
      "type": "color",
      "id": "mobile_dots_color",
      "label": "Slider dots color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "mobile_dots_size",
      "label": "Slider dots size (px)",
      "min": 4,
      "max": 18,
      "step": 1,
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection item",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
