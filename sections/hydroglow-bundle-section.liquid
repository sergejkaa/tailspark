{%- assign hg_product = all_products['doctor-x-hydroglow-serum-mask'] -%}
{%- assign v1 = hg_product.variants[0] -%}
{%- assign v2 = hg_product.variants[1] -%}
{%- assign v3 = hg_product.variants[2] -%}

{%- style -%}
  .hgbs {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    font-style: normal;
  }
  .hgbs__inner { max-width: 1100px; margin: 0 auto; padding: 0 20px; }

  .hgbs__header { text-align: center; margin-bottom: 28px; }
  .hgbs__brand {
    font-size: 12px; font-weight: 700; letter-spacing: 0.18em;
    text-transform: uppercase; color: rgb(var(--color-foreground)); opacity: 0.5;
    margin: 0 0 10px;
  }
  .hgbs__title {
    font-size: clamp(22px, 4vw, 40px); font-weight: 800; line-height: 1.1;
    color: rgb(var(--color-foreground)); margin: 0 0 14px;
  }
  .hgbs__title .hgbs__accent { color: #1554F0; }
  .hgbs__divider {
    width: 36px; height: 3px; background: #1554F0;
    margin: 0 auto; border-radius: 2px;
  }

  /* Cards grid */
  .hgbs__cards {
    display: flex; gap: 16px; align-items: stretch; padding-top: 20px;
  }

  /* Single card */
  .hgbs__card {
    flex: 1; min-width: 0;
    border: 1.5px solid rgba(var(--color-foreground), 0.12);
    border-radius: 16px;
    padding: 20px 16px 18px;
    display: flex; flex-direction: column;
    text-align: center; position: relative;
    background: rgb(var(--color-background));
    transition: box-shadow 0.2s, border-color 0.2s;
    cursor: pointer;
  }
  .hgbs__card:hover {
    border-color: rgba(var(--color-foreground), 0.22);
  }

  /* Selected state — applied via JS */
  .hgbs__card--selected {
    border-color: #1554F0;
    border-width: 2px;
    box-shadow: 0 4px 24px rgba(21, 84, 240, 0.12);
  }
  .hgbs__card--selected .hgbs__cta {
    background: #1554F0 !important;
    border-color: #1554F0 !important;
    color: #fff !important;
  }
  .hgbs__card--selected .hgbs__num {
    background: rgba(21, 84, 240, 0.1);
    color: #1554F0;
  }

  /* Card badge */
  .hgbs__card-badge {
    position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
    font-size: 10px; font-weight: 800; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 3px 14px; border-radius: 20px;
    white-space: nowrap;
  }
  .hgbs__card-badge--blue { background: #1554F0; color: #fff; }
  .hgbs__card-badge--dark { background: rgb(var(--color-foreground)); color: rgb(var(--color-background)); }

  /* Qty number */
  .hgbs__num {
    width: 56px; height: 56px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 26px; font-weight: 800; margin: 0 auto 6px;
    color: rgb(var(--color-foreground)); background: rgba(var(--color-foreground), 0.05);
    transition: background 0.2s, color 0.2s;
  }
  .hgbs__qty-label {
    font-size: 13px; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; color: rgb(var(--color-foreground)); margin-bottom: 3px;
  }
  .hgbs__subtitle {
    font-size: 12px; color: rgba(var(--color-foreground), 0.55); margin-bottom: 12px;
  }

  /* Price */
  .hgbs__price {
    font-size: 28px; font-weight: 800; color: rgb(var(--color-foreground)); line-height: 1;
    margin-bottom: 4px;
  }
  .hgbs__price-unit { font-size: 15px; font-weight: 600; vertical-align: super; }
  .hgbs__price-old {
    font-size: 13px; color: rgba(var(--color-foreground), 0.38);
    text-decoration: line-through; margin-bottom: 6px;
  }
  .hgbs__savings {
    display: inline-block; background: #1554F0; color: #fff;
    font-size: 11px; font-weight: 700; padding: 3px 10px;
    border-radius: 20px; margin-bottom: 10px; letter-spacing: 0.02em;
  }

  /* Perks */
  .hgbs__perks { display: flex; flex-direction: column; gap: 5px; margin-bottom: 12px; }
  .hgbs__perk {
    display: flex; align-items: center; justify-content: center; gap: 7px;
    font-size: 12px; font-weight: 600; color: rgb(var(--color-foreground));
    text-transform: uppercase; letter-spacing: 0.04em;
  }
  .hgbs__perk svg { flex-shrink: 0; opacity: 0.55; }

  /* Product image */
  .hgbs__img-wrap {
    flex: 1;
    display: flex; align-items: center; justify-content: center;
    min-height: 140px; margin: 8px 0 16px;
  }
  .hgbs__img-wrap img { width: 100%; max-height: 200px; object-fit: contain; }
  .hgbs__img-placeholder {
    width: 100%; height: 140px; background: rgba(var(--color-foreground), 0.04);
    border-radius: 8px; display: flex; align-items: center; justify-content: center;
  }
  .hgbs__img-placeholder svg { width: 48px; opacity: 0.2; }

  /* CTA buttons */
  .hgbs__cta {
    display: block; width: 100%; padding: 11px 14px; border-radius: 10px;
    font-size: 13px; font-weight: 700; cursor: pointer; margin-top: auto;
    transition: opacity 0.15s, transform 0.1s, background 0.2s, border-color 0.2s, color 0.2s;
    border: 2px solid rgba(var(--color-foreground), 0.25);
    background: transparent; color: rgb(var(--color-foreground));
    letter-spacing: 0.02em;
  }
  .hgbs__cta:active { transform: scale(0.98); }
  .hgbs__cta:hover:not([disabled]) { border-color: rgba(var(--color-foreground), 0.5); }
  .hgbs__cta:disabled { opacity: 0.6; cursor: default; }

  /* Trust bar */
  .hgbs__trust {
    display: flex; justify-content: center; align-items: center;
    gap: 32px; margin-top: 20px; flex-wrap: wrap;
  }
  .hgbs__trust-item {
    display: flex; align-items: center; gap: 7px;
    font-size: 12px; font-weight: 500; color: rgba(var(--color-foreground), 0.6);
  }
  .hgbs__trust-item svg { flex-shrink: 0; opacity: 0.65; }

  @media (max-width: 749px) {
    .hgbs__cards {
      overflow-x: auto; scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch; gap: 12px;
      padding-bottom: 8px; padding-top: 18px; scrollbar-width: none;
    }
    .hgbs__cards::-webkit-scrollbar { display: none; }
    .hgbs__card { min-width: 82vw; scroll-snap-align: center; flex-shrink: 0; }
    .hgbs__trust { gap: 16px; margin-top: 16px; }
    .hgbs__trust-item { font-size: 11px; }
  }
{%- endstyle -%}

<div class="hgbs color-{{ section.settings.color_scheme }}" id="hgbs-{{ section.id }}">
  <div class="hgbs__inner">

    <div class="hgbs__header" data-aos="fade-up" data-aos-duration="400" data-aos-offset="180" data-aos-once="true">
      <p class="hgbs__brand">DOCTOR X.</p>
      <h2 class="hgbs__title">
        Alege <span class="hgbs__accent">protocolul</span> potrivit<br>pentru pielea ta
      </h2>
      <div class="hgbs__divider"></div>
    </div>

    <div class="hgbs__cards" id="hgbs-cards-{{ section.id }}">

      {%- comment -%} Card 1 — 1 maska {%- endcomment -%}
      <div class="hgbs__card"
        data-aos="fade-up"
        data-aos-delay="0"
        data-aos-duration="375"
        data-aos-offset="170"
        data-aos-once="true"
        data-variant-id="{{ v1.id }}"
        data-price="{{ v1.price | money_without_currency }}"
      >
        <div class="hgbs__num">1</div>
        <p class="hgbs__qty-label">MASCĂ</p>
        <p class="hgbs__subtitle">Preț de lansare</p>
        <div class="hgbs__price">
          {{ v1.price | money_without_currency }}<span class="hgbs__price-unit"> LEI</span>
        </div>
        <div class="hgbs__img-wrap">
          {%- if section.settings.image_1 != blank -%}
            {{- section.settings.image_1 | image_url: width: 400 | image_tag: loading: 'lazy', alt: '1 mască HydroGlow' -}}
          {%- else -%}
            <div class="hgbs__img-placeholder">{{ 'product-apparel-2' | placeholder_svg_tag }}</div>
          {%- endif -%}
        </div>
        <button type="button" class="hgbs__cta" data-variant-id="{{ v1.id }}">
          Încearcă acum
        </button>
      </div>

      {%- comment -%} Card 2 — 5 masti (popular, pre-selected) {%- endcomment -%}
      <div class="hgbs__card"
        data-aos="fade-up"
        data-aos-delay="120"
        data-aos-duration="375"
        data-aos-offset="170"
        data-aos-once="true"
        data-variant-id="{{ v2.id }}"
        data-price="{{ v2.price | money_without_currency }}"
        data-default="true"
      >
        <div class="hgbs__card-badge hgbs__card-badge--blue">CEL MAI ALES</div>
        <div class="hgbs__num">5</div>
        <p class="hgbs__qty-label">MĂȘȚI</p>
        <p class="hgbs__subtitle">Ritual complet</p>
        <div class="hgbs__price">
          {{ v2.price | money_without_currency }}<span class="hgbs__price-unit"> LEI</span>
        </div>
        <p class="hgbs__price-old">194,95 LEI</p>
        <span class="hgbs__savings">ECONOMISEȘTI 25,95 LEI</span>
        <div class="hgbs__img-wrap">
          {%- if section.settings.image_2 != blank -%}
            {{- section.settings.image_2 | image_url: width: 400 | image_tag: loading: 'lazy', alt: '5 mășți HydroGlow' -}}
          {%- else -%}
            <div class="hgbs__img-placeholder">{{ 'product-apparel-2' | placeholder_svg_tag }}</div>
          {%- endif -%}
        </div>
        <button type="button" class="hgbs__cta" data-variant-id="{{ v2.id }}">
          Profită de reducere
        </button>
      </div>

      {%- comment -%} Card 3 — 10 masti (max value) {%- endcomment -%}
      <div class="hgbs__card"
        data-aos="fade-up"
        data-aos-delay="240"
        data-aos-duration="375"
        data-aos-offset="170"
        data-aos-once="true"
        data-variant-id="{{ v3.id }}"
        data-price="{{ v3.price | money_without_currency }}"
      >
        <div class="hgbs__card-badge hgbs__card-badge--dark">VALOARE MAXIMĂ</div>
        <div class="hgbs__num">10</div>
        <p class="hgbs__qty-label">MĂȘȚI</p>
        <p class="hgbs__subtitle">Experiență completă</p>
        <div class="hgbs__price">
          {{ v3.price | money_without_currency }}<span class="hgbs__price-unit"> LEI</span>
        </div>
        <p class="hgbs__price-old">389,90 LEI</p>
        <div class="hgbs__perks">
          <div class="hgbs__perk">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4a2 2 0 012 2v5a2 2 0 01-2 2h-4M1 12h15"/></svg>
            TRANSPORT GRATUIT
          </div>
          <div class="hgbs__perk">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20 12v10H4V12M22 7H2v5h20V7zM12 22V7M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7zM12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>
            CADOU INCLUS
          </div>
        </div>
        <div class="hgbs__img-wrap">
          {%- if section.settings.image_3 != blank -%}
            {{- section.settings.image_3 | image_url: width: 400 | image_tag: loading: 'lazy', alt: '10 mășți HydroGlow' -}}
          {%- else -%}
            <div class="hgbs__img-placeholder">{{ 'product-apparel-2' | placeholder_svg_tag }}</div>
          {%- endif -%}
        </div>
        <button type="button" class="hgbs__cta" data-variant-id="{{ v3.id }}">
          Profită + cadou
        </button>
      </div>

    </div>

    <div class="hgbs__trust" data-aos="fade-up" data-aos-duration="350" data-aos-offset="130" data-aos-once="true">
      <div class="hgbs__trust-item">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Protocol estetic profesional
      </div>
      <div class="hgbs__trust-item">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 2l2.09 6.26L20 9l-5 4.73L16.18 20 12 16.77 7.82 20 9 13.73 4 9l5.91-.74L12 2z"/></svg>
        Ingrediente active în profunzime
      </div>
      <div class="hgbs__trust-item">
        <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 2C6 8 4 13 4 16a8 8 0 0016 0c0-3-2-8-8-14z"/></svg>
        Rezultate vizibile, fără filtre
      </div>
    </div>

  </div>
</div>

<script>
  (function () {
    var sid = '{{ section.id }}';
    var container = document.getElementById('hgbs-cards-' + sid);
    if (!container) return;

    function selectCard(card) {
      container.querySelectorAll('.hgbs__card').forEach(function (c) {
        c.classList.remove('hgbs__card--selected');
      });
      card.classList.add('hgbs__card--selected');
    }

    function addToCart(variantId, btn) {
      var origText = btn.textContent.trim();
      btn.disabled = true;
      btn.textContent = 'Se adaugă...';

      var body = new FormData();
      body.append('id', variantId);
      body.append('quantity', '1');
      body.append('sections', 'cart-drawer,cart-icon-bubble');
      body.append('sections_url', window.location.pathname);

      fetch('/cart/add', {
        method: 'POST',
        headers: { 'Accept': 'application/javascript' },
        body: body
      })
      .then(function (r) { return r.json(); })
      .then(function (resp) {
        if (resp.status === 422 || resp.status === 404) {
          btn.textContent = resp.description || 'Eroare';
          setTimeout(function () { btn.disabled = false; btn.textContent = origText; }, 2500);
          return;
        }
        btn.textContent = '✓ Adăugat!';

        if (resp.sections && resp.sections['cart-icon-bubble']) {
          var parser = new DOMParser();
          var doc = parser.parseFromString(resp.sections['cart-icon-bubble'], 'text/html');
          var newBubble = doc.querySelector('#cart-icon-bubble');
          var bubble = document.querySelector('#cart-icon-bubble');
          if (newBubble && bubble) bubble.innerHTML = newBubble.innerHTML;
        }

        var cartDrawer = document.querySelector('cart-drawer');
        if (cartDrawer) {
          if (resp.sections && resp.sections['cart-drawer'] && typeof cartDrawer.renderContents === 'function') {
            cartDrawer.renderContents(resp);
          } else if (typeof cartDrawer.open === 'function') {
            cartDrawer.open();
          }
        }

        setTimeout(function () { btn.disabled = false; btn.textContent = origText; }, 2200);
      })
      .catch(function () { btn.disabled = false; btn.textContent = origText; });
    }

    container.querySelectorAll('.hgbs__card').forEach(function (card) {
      card.addEventListener('click', function (e) {
        var btn = e.target.closest('.hgbs__cta');
        if (btn) {
          e.stopPropagation();
          selectCard(card);
          addToCart(btn.getAttribute('data-variant-id'), btn);
        } else {
          selectCard(card);
        }
      });
    });

    // Pre-select default (card 2)
    function init() {
      var def = container.querySelector('.hgbs__card[data-default="true"]')
              || container.querySelector('.hgbs__card');
      if (def) selectCard(def);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
      init();
    }
    document.addEventListener('shopify:section:load', init);
  })();
</script>

{% schema %}
{
  "name": "HydroGlow Bundle",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Imagini produs"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Card 1 — 1 mască"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Card 2 — 5 mășți (CEL MAI ALES)"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Card 3 — 10 mășți (VALOARE MAXIMĂ)"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Padding bottom",
      "default": 40
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "scheme-1", "label": "Scheme 1" },
        { "value": "scheme-2", "label": "Scheme 2" },
        { "value": "scheme-3", "label": "Scheme 3" },
        { "value": "scheme-4", "label": "Scheme 4" }
      ],
      "default": "scheme-1",
      "label": "Color scheme"
    }
  ],
  "presets": [{ "name": "HydroGlow Bundle" }]
}
{% endschema %}
