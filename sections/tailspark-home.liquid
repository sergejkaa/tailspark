{%- liquid
  assign product_handles = 'tailspark-skin-coat,tailspark-multivitamin,tailspark-hip-joint,tailspark-probiotic' | split: ','
  assign product_titles = 'Skin & Coat Advanced Support,Multivitamin Daily Support,Hip & Joint Advanced Support,Probiotic Daily Support' | split: ','
  assign product_tags = 'Softer coat, healthier skin|Complete daily nutrition|More movement, less stiffness|Happy tummy, happy dog' | split: '|'
  assign benefit_pairs = 'Shiny Coat,Sensitive Skin|Daily Wellness,Immune Support|Joint Mobility,Active Lifestyle|Gut Health,Immune Balance' | split: '|'
-%}

<section class="ts-home" aria-label="TailSpark homepage">
  <section class="ts-hero">
    <div class="ts-home__container ts-hero__grid">
      <div class="ts-hero__copy">
        <p class="ts-kicker">Vet Formulated &middot; Made in USA</p>
        <h1>Tail-Wagging Health,<br>Made Simple.</h1>
        <p class="ts-hero__text">Soft chews your dog will love, backed by science and free of junk. Formulated for all breeds and ages.</p>
        <div class="ts-actions">
          <a class="ts-button ts-button--primary" href="{{ routes.collections_url }}/all">Shop Now</a>
          <a class="ts-button ts-button--text" href="{{ routes.root_url }}pages/about">Learn More</a>
        </div>
      </div>

      <div class="ts-hero__visual" aria-label="TailSpark product preview">
        <div class="ts-packshot">
          <img src="{{ 'tailspark-logo-orange.png' | asset_url }}" alt="TailSpark" width="260" height="92" loading="eager">
          <span>Daily wellness soft chews</span>
        </div>
        <div class="ts-chews" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span>
        </div>
      </div>
    </div>
  </section>

  <section class="ts-products">
    <div class="ts-home__container">
      <div class="ts-section-head">
        <p class="ts-kicker">Our Products</p>
        <h2>Soft chews with a real job to do.</h2>
        <p>As tasty as they look, but what's inside is even more impressive: clean daily support for skin, coat, joints, digestion, and everyday wellness.</p>
      </div>

      <div class="ts-product-grid">
        {%- for handle in product_handles -%}
          {%- liquid
            assign product = all_products[handle]
            assign fallback_title = product_titles[forloop.index0]
            assign tagline = product_tags[forloop.index0]
            assign pair = benefit_pairs[forloop.index0] | split: ','
          -%}
          <article class="ts-product-card">
            <a class="ts-product-card__media" href="{% if product != blank %}{{ product.url }}{% else %}{{ routes.collections_url }}/all{% endif %}" aria-label="{% if product != blank %}{{ product.title | escape }}{% else %}{{ fallback_title | escape }}{% endif %}">
              {%- if product != blank and product.featured_image != blank -%}
                {{ product.featured_image | image_url: width: 760 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 25vw, 90vw', widths: '360, 540, 760', alt: product.title }}
              {%- else -%}
                <div class="ts-product-card__placeholder">
                  <img src="{{ 'tailspark-logo-orange.png' | asset_url }}" alt="" width="180" height="64" loading="lazy">
                  <span>Product image coming soon</span>
                </div>
              {%- endif -%}
            </a>
            <div class="ts-product-card__body">
              <h3>{% if product != blank %}{{ product.title }}{% else %}{{ fallback_title }}{% endif %}</h3>
              <p>{{ tagline }}</p>
              <div class="ts-product-card__benefits">
                <span>{% render 'icon-leaf' %}{{ pair[0] }}</span>
                <span>{% render 'icon-checkmark' %}{{ pair[1] }}</span>
              </div>
              <div class="ts-product-card__footer">
                <a class="ts-button ts-button--outline" href="{% if product != blank %}{{ product.url }}{% else %}{{ routes.collections_url }}/all{% endif %}">View Product</a>
                <small>{% if product != blank %}From {{ product.price | money }}{% else %}From $25{% endif %}</small>
              </div>
            </div>
          </article>
        {%- endfor -%}
      </div>
    </div>
  </section>

  <section class="ts-trust">
    <div class="ts-home__container ts-trust__grid">
      <span>Vet Formulated</span>
      <span>For All Breeds</span>
      <span>Made in USA</span>
      <span>No Corn &middot; No Wheat</span>
      <span>100% Satisfaction Guarantee</span>
    </div>
  </section>

  <section class="ts-steps">
    <div class="ts-home__container">
      <div class="ts-section-head ts-section-head--compact">
        <p class="ts-kicker">How It Works</p>
        <h2>Simple as 1, 2, 3.</h2>
      </div>
      <div class="ts-step-grid">
        <article>
          <strong>01</strong>
          <h3>Choose Your Dog's Need</h3>
          <p>Pick the formula that matches your dog's health goal, or grab the Multivitamin for complete daily support.</p>
        </article>
        <article>
          <strong>02</strong>
          <h3>Give One Chew Daily</h3>
          <p>Drop it in the bowl or give it by hand. Dogs love the taste, so there is no hiding in food required.</p>
        </article>
        <article>
          <strong>03</strong>
          <h3>Watch Them Thrive</h3>
          <p>Real ingredients, real results. Most pet parents notice a difference within 4-6 weeks.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="ts-story">
    <div class="ts-home__container ts-story__grid">
      <div class="ts-story__visual">
        <div class="ts-story__badge">Clean ingredients<br>for daily dog wellness</div>
      </div>
      <div>
        <p class="ts-kicker">Why TailSpark</p>
        <h2>Built different. Because your dog deserves it.</h2>
        <p>We started TailSpark because we wanted the best for our own dog, and couldn't find a supplement we actually trusted.</p>
        <ul>
          <li>No corn, no wheat, no artificial flavors or colors.</li>
          <li>Clean, effective ingredients in every single chew.</li>
          <li>Backed by science. Loved by dogs.</li>
        </ul>
        <a class="ts-button ts-button--primary" href="{{ routes.root_url }}pages/about">Our Story</a>
      </div>
    </div>
  </section>

  <section class="ts-reviews">
    <div class="ts-home__container">
      <div class="ts-section-head">
        <p class="ts-kicker">Reviews</p>
        <h2>Dogs love it. Pet parents trust it.</h2>
      </div>
      <div class="ts-review-grid">
        <article>
          <span>&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <p>"Max has been on the Hip & Joint chews for 6 weeks and I can already see a difference in how he moves up the stairs."</p>
          <strong>Sarah M. &middot; Golden Retriever owner</strong>
        </article>
        <article>
          <span>&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <p>"My picky eater loves these. The coat supplement has her looking gorgeous, and she eats it right out of my hand."</p>
          <strong>Jamie K. &middot; Shiba Inu owner</strong>
        </article>
        <article>
          <span>&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <p>"Finally a supplement I can trust. Clean ingredients, no junk, and it actually works for our senior dog."</p>
          <strong>Tom R. &middot; Lab owner</strong>
        </article>
      </div>
    </div>
  </section>

  <section class="ts-faq">
    <div class="ts-home__container ts-faq__grid">
      <div>
        <p class="ts-kicker">FAQ</p>
        <h2>Questions before the first chew?</h2>
      </div>
      <div class="ts-faq__items">
        <details>
          <summary>Are TailSpark supplements safe for all dogs?</summary>
          <p>Yes. All formulas are vet formulated for dogs of all breeds and ages. Always consult your vet if your dog has a medical condition or is on medication.</p>
        </details>
        <details>
          <summary>How long until I see results?</summary>
          <p>Most pet parents notice improvements within 4-6 weeks of daily use. Consistency is key.</p>
        </details>
        <details>
          <summary>Are these chews grain-free?</summary>
          <p>Our chews are free of corn and wheat. Some formulas contain oat flour or rye flour as a base. Full ingredient lists are on each product page.</p>
        </details>
        <details>
          <summary>Can I give multiple supplements together?</summary>
          <p>Yes, our formulas are designed to complement each other. Many pet parents combine the Multivitamin with a targeted formula.</p>
        </details>
      </div>
    </div>
  </section>
</section>

<style>
  .ts-home {
    --ts-orange: #ff6700;
    --ts-cream: #ffffd2;
    --ts-green: #5ba870;
    --ts-charcoal: #333333;
    --ts-blush: #f6e7dc;
    --ts-soft: #fff8ed;
    color: var(--ts-charcoal);
    background: var(--ts-soft);
    font-family: var(--font-body-family), "Poppins", sans-serif;
  }

  .ts-home__container {
    width: min(100% - 32px, 1280px);
    margin-inline: auto;
  }

  .ts-hero {
    min-height: clamp(620px, 82dvh, 840px);
    display: grid;
    align-items: center;
    background:
      radial-gradient(circle at 82% 18%, rgba(91, 168, 112, .18), transparent 28%),
      linear-gradient(135deg, var(--ts-cream), var(--ts-soft));
  }

  .ts-hero__grid,
  .ts-story__grid,
  .ts-faq__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, .86fr);
    gap: clamp(32px, 7vw, 92px);
    align-items: center;
  }

  .ts-kicker {
    margin: 0 0 14px;
    color: var(--ts-orange);
    font: 700 1.2rem/1.2 var(--font-body-family), "Poppins", sans-serif;
    letter-spacing: .04em;
    text-transform: uppercase;
  }

  .ts-home h1,
  .ts-home h2,
  .ts-home h3 {
    margin: 0;
    font-family: var(--font-heading-family), "Switzer", sans-serif;
    color: var(--ts-charcoal);
    text-wrap: balance;
  }

  .ts-home h1 {
    font-size: clamp(4.8rem, 7vw, 8.4rem);
    line-height: .92;
    letter-spacing: 0;
  }

  .ts-home h2 {
    font-size: clamp(3rem, 4.4vw, 5.6rem);
    line-height: 1;
  }

  .ts-home h3 {
    font-size: clamp(1.9rem, 2vw, 2.4rem);
    line-height: 1.08;
  }

  .ts-hero__text,
  .ts-section-head p,
  .ts-story p,
  .ts-step-grid p,
  .ts-review-grid p,
  .ts-faq p {
    font-size: 1.65rem;
    line-height: 1.6;
    color: rgba(51, 51, 51, .78);
  }

  .ts-hero__text {
    max-width: 58rem;
    margin: 24px 0 0;
  }

  .ts-actions,
  .ts-product-card__footer {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  .ts-actions {
    margin-top: 34px;
  }

  .ts-button {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 24px;
    border-radius: 999px;
    font-weight: 700;
    text-decoration: none;
    transition: transform .22s ease, background-color .22s ease, color .22s ease, border-color .22s ease;
  }

  .ts-button:hover {
    transform: translateY(-2px);
  }

  .ts-button:active {
    transform: translateY(0) scale(.98);
  }

  .ts-button--primary {
    background: var(--ts-orange);
    color: #fff;
    box-shadow: 0 12px 30px rgba(255, 103, 0, .22);
  }

  .ts-button--outline {
    border: 1px solid var(--ts-orange);
    color: var(--ts-orange);
    background: transparent;
  }

  .ts-button--text {
    color: var(--ts-charcoal);
    padding-inline: 4px;
  }

  .ts-hero__visual {
    min-height: 440px;
    position: relative;
    display: grid;
    place-items: center;
  }

  .ts-packshot {
    width: min(100%, 430px);
    aspect-ratio: 4 / 4.65;
    border-radius: 36px;
    display: grid;
    place-items: center;
    gap: 18px;
    padding: 42px;
    background: #fff;
    box-shadow: 0 28px 90px rgba(51, 51, 51, .12);
    text-align: center;
    transform: rotate(2deg);
  }

  .ts-packshot span {
    font-weight: 700;
    color: var(--ts-green);
  }

  .ts-chews {
    position: absolute;
    inset: auto 0 8px auto;
    width: 180px;
    height: 120px;
  }

  .ts-chews span,
  .ts-product-card__placeholder:before {
    position: absolute;
    width: 56px;
    height: 38px;
    border-radius: 16px;
    background: linear-gradient(135deg, #8b5326, #4a2a17);
    box-shadow: inset 0 8px 12px rgba(255, 255, 255, .12);
  }

  .ts-chews span:nth-child(1) { right: 88px; bottom: 6px; rotate: -8deg; }
  .ts-chews span:nth-child(2) { right: 42px; bottom: 26px; rotate: 7deg; }
  .ts-chews span:nth-child(3) { right: 6px; bottom: 0; rotate: -3deg; }
  .ts-chews span:nth-child(4) { right: 70px; bottom: 62px; rotate: 14deg; }
  .ts-chews span:nth-child(5) { right: 116px; bottom: 48px; rotate: 4deg; }

  .ts-products,
  .ts-steps,
  .ts-story,
  .ts-reviews,
  .ts-faq {
    padding: clamp(56px, 8vw, 104px) 0;
  }

  .ts-section-head {
    max-width: 820px;
    margin-bottom: 36px;
  }

  .ts-section-head--compact {
    max-width: 620px;
  }

  .ts-product-grid,
  .ts-step-grid,
  .ts-review-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }

  .ts-product-card {
    display: grid;
    grid-template-rows: auto 1fr;
    overflow: hidden;
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 18px 50px rgba(51, 51, 51, .08);
  }

  .ts-product-card__media {
    min-height: 260px;
    display: grid;
    place-items: center;
    background: var(--ts-blush);
    text-decoration: none;
  }

  .ts-product-card__media img {
    max-width: 88%;
    max-height: 260px;
    object-fit: contain;
  }

  .ts-product-card__placeholder {
    min-height: 260px;
    position: relative;
    display: grid;
    place-items: center;
    gap: 18px;
    text-align: center;
    color: rgba(51, 51, 51, .62);
    font-size: 1.25rem;
  }

  .ts-product-card__placeholder:before {
    content: "";
    left: calc(50% - 28px);
    bottom: 38px;
  }

  .ts-product-card__body {
    display: grid;
    gap: 16px;
    padding: 22px;
  }

  .ts-product-card__body p {
    margin: 0;
    color: rgba(51, 51, 51, .68);
    line-height: 1.45;
  }

  .ts-product-card__benefits {
    display: grid;
    gap: 8px;
  }

  .ts-product-card__benefits span {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--ts-green);
  }

  .ts-product-card__benefits svg {
    width: 18px;
    height: 18px;
  }

  .ts-product-card__footer {
    align-self: end;
    justify-content: space-between;
    margin-top: 8px;
  }

  .ts-product-card__footer small {
    color: rgba(51, 51, 51, .62);
    font-weight: 700;
  }

  .ts-trust {
    padding: 20px 0;
    background: var(--ts-orange);
    color: #fff;
  }

  .ts-trust__grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 14px;
    text-align: center;
    font-weight: 800;
  }

  .ts-step-grid,
  .ts-review-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .ts-step-grid article,
  .ts-review-grid article {
    border-radius: 8px;
    padding: 28px;
    background: #fff;
  }

  .ts-step-grid strong {
    display: inline-block;
    margin-bottom: 42px;
    color: var(--ts-green);
    font-size: 3.4rem;
    line-height: 1;
  }

  .ts-story {
    background: var(--ts-cream);
  }

  .ts-story__visual {
    min-height: 480px;
    border-radius: 8px;
    background:
      radial-gradient(circle at 62% 36%, rgba(255, 103, 0, .16), transparent 22%),
      linear-gradient(140deg, #ffffff, var(--ts-blush));
    display: grid;
    place-items: center;
  }

  .ts-story__badge {
    width: min(74%, 360px);
    aspect-ratio: 1;
    border-radius: 50%;
    display: grid;
    place-items: center;
    padding: 36px;
    text-align: center;
    background: var(--ts-green);
    color: #fff;
    font: 800 clamp(2.2rem, 3vw, 3.6rem)/1.05 var(--font-heading-family), "Switzer", sans-serif;
  }

  .ts-story ul {
    display: grid;
    gap: 12px;
    margin: 26px 0 30px;
    padding: 0;
    list-style: none;
  }

  .ts-story li {
    position: relative;
    padding-left: 28px;
    font-weight: 700;
  }

  .ts-story li:before {
    content: "";
    position: absolute;
    left: 0;
    top: .55em;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--ts-orange);
  }

  .ts-review-grid span {
    color: var(--ts-orange);
    letter-spacing: .08em;
  }

  .ts-review-grid strong {
    color: var(--ts-green);
  }

  .ts-faq {
    background: #fff;
  }

  .ts-faq__grid {
    grid-template-columns: .72fr 1fr;
    align-items: start;
  }

  .ts-faq__items {
    display: grid;
    gap: 12px;
  }

  .ts-faq details {
    border-top: 1px solid rgba(51, 51, 51, .16);
    padding: 18px 0;
  }

  .ts-faq summary {
    cursor: pointer;
    font-weight: 800;
    font-size: 1.8rem;
  }

  .ts-faq details:last-child {
    border-bottom: 1px solid rgba(51, 51, 51, .16);
  }

  @media screen and (max-width: 989px) {
    .ts-hero__grid,
    .ts-story__grid,
    .ts-faq__grid {
      grid-template-columns: 1fr;
    }

    .ts-product-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .ts-step-grid,
    .ts-review-grid,
    .ts-trust__grid {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 640px) {
    .ts-home__container {
      width: min(100% - 24px, 1280px);
    }

    .ts-hero {
      min-height: auto;
      padding: 52px 0 62px;
    }

    .ts-hero__visual {
      min-height: 330px;
      order: -1;
    }

    .ts-packshot {
      width: min(88vw, 320px);
      padding: 28px;
      border-radius: 24px;
    }

    .ts-product-grid {
      grid-template-columns: 1fr;
    }

    .ts-actions,
    .ts-product-card__footer {
      align-items: stretch;
      flex-direction: column;
    }

    .ts-button {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "TailSpark homepage",
  "settings": [],
  "presets": [
    {
      "name": "TailSpark homepage"
    }
  ]
}
{% endschema %}
