{%- comment -%}
  sections/video-banner.liquid
  Responsive video banner with separate desktop/mobile sources or YouTube/Vimeo link.
  Blocks for heading, text, and button to maximize admin-side customization.
{%- endcomment -%}

{%- assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0 -%}
{%- assign prefer_external = false -%}
{%- assign has_uploaded = false -%}
{%- assign default_hero_background = 'hero.jpg' | asset_url -%}
{%- assign default_hero_background_mobile = 'hero-mobile.png' | asset_url -%}
{%- if section.settings.external_video != blank and section.settings.video_priority != 'uploads' -%}
  {%- assign prefer_external = true -%}
{%- endif -%}
{%- if section.settings.desktop_video != blank or section.settings.mobile_video != blank -%}
  {%- assign has_uploaded = true -%}
{%- endif -%}
{%- assign content_horizontal_desktop = 'center' -%}
{%- case section.settings.horizontal_align -%}
  {%- when 'left' -%}
    {%- assign content_horizontal_desktop = 'flex-start' -%}
  {%- when 'right' -%}
    {%- assign content_horizontal_desktop = 'flex-end' -%}
{%- endcase -%}
{%- assign content_vertical_desktop = 'center' -%}
{%- case section.settings.vertical_align -%}
  {%- when 'top' -%}
    {%- assign content_vertical_desktop = 'flex-start' -%}
  {%- when 'bottom' -%}
    {%- assign content_vertical_desktop = 'flex-end' -%}
{%- endcase -%}
{%- assign content_horizontal_mobile = 'center' -%}
{%- case section.settings.horizontal_align_mobile -%}
  {%- when 'left' -%}
    {%- assign content_horizontal_mobile = 'flex-start' -%}
  {%- when 'right' -%}
    {%- assign content_horizontal_mobile = 'flex-end' -%}
{%- endcase -%}
{%- assign content_vertical_mobile = 'center' -%}
{%- case section.settings.vertical_align_mobile -%}
  {%- when 'top' -%}
    {%- assign content_vertical_mobile = 'flex-start' -%}
  {%- when 'bottom' -%}
    {%- assign content_vertical_mobile = 'flex-end' -%}
{%- endcase -%}
{%- assign actions_align = 'center' -%}
{%- case section.settings.text_align -%}
  {%- when 'left' -%}
    {%- assign actions_align = 'flex-start' -%}
  {%- when 'right' -%}
    {%- assign actions_align = 'flex-end' -%}
{%- endcase -%}
{%- assign actions_align_mobile = 'center' -%}
{%- case section.settings.text_align_mobile -%}
  {%- when 'left' -%}
    {%- assign actions_align_mobile = 'flex-start' -%}
  {%- when 'right' -%}
    {%- assign actions_align_mobile = 'flex-end' -%}
{%- endcase -%}
{%- assign badge_align = 'center' -%}
{%- case section.settings.text_align -%}
  {%- when 'left' -%}
    {%- assign badge_align = 'start' -%}
  {%- when 'right' -%}
    {%- assign badge_align = 'end' -%}
{%- endcase -%}
{%- assign badge_align_mobile = 'center' -%}
{%- case section.settings.text_align_mobile -%}
  {%- when 'left' -%}
    {%- assign badge_align_mobile = 'start' -%}
  {%- when 'right' -%}
    {%- assign badge_align_mobile = 'end' -%}
{%- endcase -%}
{%- assign button_glow_strength = section.settings.button_glow_strength | default: 50 | plus: 0 -%}
{%- assign button_glow_primary = 38 | times: button_glow_strength | divided_by: 100.0 -%}
{%- assign button_glow_secondary = 24 | times: button_glow_strength | divided_by: 100.0 -%}
{%- assign button_glow_hover = 50 | times: button_glow_strength | divided_by: 100.0 -%}
{%- assign button_glow_active = 34 | times: button_glow_strength | divided_by: 100.0 -%}
{%- assign button_glow_anim_low = 35 | times: button_glow_strength | divided_by: 100.0 -%}
{%- assign button_glow_anim_high = 48 | times: button_glow_strength | divided_by: 100.0 -%}

{%- for block in section.blocks -%}
  {%- if block.type == 'heading' -%}
    {%- assign heading_font_url = '' -%}
    {%- case block.settings.heading_google_font -%}
      {%- when 'inter' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap' -%}
      {%- when 'poppins' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap' -%}
      {%- when 'montserrat' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap' -%}
      {%- when 'roboto' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&display=swap' -%}
      {%- when 'oswald' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&display=swap' -%}
      {%- when 'playfair_display' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&display=swap' -%}
      {%- when 'lato' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&display=swap' -%}
      {%- when 'nunito' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;500;600;700;800&display=swap' -%}
      {%- when 'open_sans' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700;800&display=swap' -%}
      {%- when 'space_grotesk' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap' -%}
      {%- when 'merriweather' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700;900&display=swap' -%}
      {%- when 'manrope' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap' -%}
      {%- when 'raleway' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700;800&display=swap' -%}
      {%- when 'dm_sans' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap' -%}
      {%- when 'rubik' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;500;600;700&display=swap' -%}
      {%- when 'plus_jakarta_sans' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap' -%}
      {%- when 'urbanist' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Urbanist:wght@300;400;500;600;700;800&display=swap' -%}
      {%- when 'cabin' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Cabin:wght@400;500;600;700&display=swap' -%}
      {%- when 'karla' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Karla:wght@300;400;500;600;700;800&display=swap' -%}
      {%- when 'barlow' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500;600;700;800&display=swap' -%}
      {%- when 'work_sans' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Work+Sans:wght@300;400;500;600;700;800&display=swap' -%}
      {%- when 'outfit' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap' -%}
      {%- when 'source_sans_3' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@300;400;500;600;700;800&display=swap' -%}
      {%- when 'pt_sans' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=PT+Sans:wght@400;700&display=swap' -%}
      {%- when 'noto_sans' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Noto+Sans:wght@300;400;500;600;700;800&display=swap' -%}
      {%- when 'bebas_neue' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap' -%}
      {%- when 'anton' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Anton&display=swap' -%}
      {%- when 'fira_sans' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Fira+Sans:wght@300;400;500;600;700;800&display=swap' -%}
      {%- when 'quicksand' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&display=swap' -%}
      {%- when 'lora' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Lora:wght@400;500;600;700&display=swap' -%}
      {%- when 'libre_baskerville' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&display=swap' -%}
      {%- when 'archivo' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Archivo:wght@300;400;500;600;700;800&display=swap' -%}
      {%- when 'jost' -%}
        {%- assign heading_font_url = 'https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700;800&display=swap' -%}
    {%- endcase -%}
    {%- assign heading_custom_font_url = block.settings.heading_google_font_url_custom | strip -%}
    {%- if heading_custom_font_url != blank -%}
      {%- assign heading_font_url = heading_custom_font_url -%}
    {%- endif -%}
    {%- if heading_font_url != blank -%}
      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link rel="stylesheet" href="{{ heading_font_url }}">
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

<section
  class="video-banner color-{{ section.settings.color_scheme }}"
  style="
    --vb-overlay-color: {{ section.settings.overlay_color }};
    --vb-overlay-opacity: {{ overlay_opacity }};
    --vb-section-radius: {{ section.settings.section_corner_radius }}px;
    --vb-content-radius: {{ section.settings.content_surface_radius }}px;
    --vb-padding-y: {{ section.settings.padding_vertical }}px;
    --vb-padding-x: {{ section.settings.padding_horizontal }}px;
    --vb-content-gap-desktop: {{ section.settings.content_gap }}px;
    --vb-content-gap-mobile: {{ section.settings.content_gap_mobile | default: section.settings.content_gap }}px;
    --vb-content-max: {{ section.settings.content_max_width }}px;
    --vb-content-padding: {{ section.settings.content_padding }}px;
    --vb-content-margin-top-desktop: {{ section.settings.content_margin_top | default: 0 }}px;
    --vb-content-margin-right-desktop: {{ section.settings.content_margin_right | default: 0 }}px;
    --vb-content-margin-bottom-desktop: {{ section.settings.content_margin_bottom | default: 0 }}px;
    --vb-content-margin-left-desktop: {{ section.settings.content_margin_left | default: 0 }}px;
    --vb-content-margin-top-mobile: {{ section.settings.content_margin_top_mobile | default: section.settings.content_margin_top | default: 0 }}px;
    --vb-content-margin-right-mobile: {{ section.settings.content_margin_right_mobile | default: section.settings.content_margin_right | default: 0 }}px;
    --vb-content-margin-bottom-mobile: {{ section.settings.content_margin_bottom_mobile | default: section.settings.content_margin_bottom | default: 0 }}px;
    --vb-content-margin-left-mobile: {{ section.settings.content_margin_left_mobile | default: section.settings.content_margin_left | default: 0 }}px;
    --vb-height-mobile: {{ section.settings.height_mobile }}vh;
    --vb-height-desktop: {{ section.settings.height_desktop }}vh;
    --vb-aspect-mobile: {{ section.settings.aspect_mobile }};
    --vb-aspect-desktop: {{ section.settings.aspect_desktop }};
    --vb-content-bg: {{ section.settings.content_background }};
    --vb-content-bg-opacity: {{ section.settings.content_background_opacity }}%;
    --vb-content-horizontal-desktop: {{ content_horizontal_desktop }};
    --vb-content-vertical-desktop: {{ content_vertical_desktop }};
    --vb-content-horizontal-mobile: {{ content_horizontal_mobile }};
    --vb-content-vertical-mobile: {{ content_vertical_mobile }};
    --vb-text-align: {{ section.settings.text_align | default: 'center' }};
    --vb-text-align-mobile: {{ section.settings.text_align_mobile | default: 'center' }};
    --vb-actions-align: {{ actions_align }};
    --vb-actions-align-mobile: {{ actions_align_mobile }};
    --vb-badge-align: {{ badge_align }};
    --vb-badge-align-mobile: {{ badge_align_mobile }};
    --vb-button-bg: {{ section.settings.button_color }};
    --vb-button-bg-alt: {{ section.settings.button_color_2 | default: section.settings.button_color }};
    --vb-button-bg-hover: {{ section.settings.button_hover_color | default: section.settings.button_color }};
    --vb-button-bg-hover-alt: {{ section.settings.button_hover_color_2 | default: section.settings.button_hover_color | default: section.settings.button_color }};
    --vb-button-border: {{ section.settings.button_border_color | default: section.settings.button_color }};
    --vb-button-border-hover: {{ section.settings.button_hover_color | default: section.settings.button_border_color | default: section.settings.button_color }};
    --vb-button-glow: {{ section.settings.button_glow_color | default: section.settings.button_color }};
    --vb-button-glow-primary: {{ button_glow_primary }}%;
    --vb-button-glow-secondary: {{ button_glow_secondary }}%;
    --vb-button-glow-hover: {{ button_glow_hover }}%;
    --vb-button-glow-active: {{ button_glow_active }}%;
    --vb-button-glow-anim-low: {{ button_glow_anim_low }}%;
    --vb-button-glow-anim-high: {{ button_glow_anim_high }}%;
    --vb-button-text: {{ section.settings.button_text_color | default: '#ffffff' }};
    --vb-button-text-hover: {{ section.settings.button_text_hover_color | default: section.settings.button_text_color | default: '#ffffff' }};
  "
>
  <div class="video-banner__frame video-banner__frame--h-{{ section.settings.horizontal_align }} video-banner__frame--v-{{ section.settings.vertical_align }}">
    <div class="video-banner__media">
      {%- if prefer_external -%}
        {%- assign video_id = section.settings.external_video.id -%}
        {%- capture external_url -%}
          {%- if section.settings.external_video.type == 'youtube' -%}
            https://www.youtube.com/embed/{{ video_id }}?playsinline=1{% if section.settings.autoplay %}&autoplay=1{% endif %}{% if section.settings.muted %}&mute=1{% endif %}{% if section.settings.loop %}&loop=1&playlist={{ video_id }}{% endif %}{% if section.settings.show_controls == false %}&controls=0&modestbranding=1&rel=0{% endif %}
          {%- else -%}
            https://player.vimeo.com/video/{{ video_id }}?title=0&byline=0&portrait=0{% if section.settings.autoplay %}&autoplay=1{% endif %}{% if section.settings.muted %}&muted=1{% endif %}{% if section.settings.loop %}&loop=1&autopause=0{% endif %}{% if section.settings.show_controls == false %}&controls=0{% endif %}
          {%- endif -%}
        {%- endcapture -%}
        <div class="video-banner__iframe" role="presentation">
          <iframe
            src="{{ external_url | strip }}"
            title="{{ section.settings.iframe_title | escape }}"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
      {%- elsif has_uploaded -%}
        <video
          class="video-banner__video video-banner__video--desktop"
          {% if section.settings.autoplay %}autoplay{% endif %}
          {% if section.settings.loop %}loop{% endif %}
          {% if section.settings.muted %}muted{% endif %}
          {% if section.settings.show_controls %}controls{% endif %}
          playsinline
          preload="{{ section.settings.preload }}"
          {% if section.settings.poster_image != blank %}poster="{{ section.settings.poster_image | image_url: width: 1800 }}"{% endif %}
        >
          {%- if section.settings.desktop_video != blank -%}
            {%- for source in section.settings.desktop_video.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          {%- endif -%}
        </video>

        <video
          class="video-banner__video video-banner__video--mobile"
          {% if section.settings.autoplay %}autoplay{% endif %}
          {% if section.settings.loop %}loop{% endif %}
          {% if section.settings.muted %}muted{% endif %}
          {% if section.settings.show_controls %}controls{% endif %}
          playsinline
          preload="{{ section.settings.preload }}"
          {% if section.settings.poster_image != blank %}poster="{{ section.settings.poster_image | image_url: width: 1200 }}"{% endif %}
        >
          {%- assign mobile_video = section.settings.mobile_video | default: section.settings.desktop_video -%}
          {%- if mobile_video != blank -%}
            {%- for source in mobile_video.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          {%- endif -%}
        </video>
      {%- elsif section.settings.desktop_background_image != blank or section.settings.mobile_background_image != blank or section.settings.poster_image == blank -%}
        {%- assign desktop_bg = section.settings.desktop_background_image -%}
        {%- assign mobile_bg = section.settings.mobile_background_image | default: section.settings.desktop_background_image -%}
        {%- assign desktop_bg_url = default_hero_background -%}
        {%- assign mobile_bg_url = default_hero_background_mobile -%}
        {%- if desktop_bg != blank -%}
          {%- assign desktop_bg_url = desktop_bg | image_url: width: 2000 -%}
        {%- endif -%}
        {%- if mobile_bg != blank -%}
          {%- assign mobile_bg_url = mobile_bg | image_url: width: 1400 -%}
        {%- endif -%}
        <picture class="video-banner__image" role="presentation">
          <source media="(min-width: 750px)" srcset="{{ desktop_bg_url }}">
          <img src="{{ mobile_bg_url }}" alt="" loading="lazy" decoding="async">
        </picture>
      {%- elsif section.settings.poster_image != blank -%}
        <div
          class="video-banner__poster"
          role="presentation"
          style="background-image: url('{{ section.settings.poster_image | image_url: width: 2000 }}');"
        ></div>
      {%- else -%}
        <div
          class="video-banner__poster"
          role="presentation"
          style="background-image: url('{{ default_hero_background }}');"
        ></div>
      {%- endif -%}
      <span class="video-banner__overlay" aria-hidden="true"></span>
    </div>

    <div class="video-banner__content">
      <div class="video-banner__content-inner{% if section.settings.content_surface %} is-surfaced{% endif %}">
        {%- for block in section.blocks -%}
          {%- assign block_delay = forloop.index0 | times: 130 -%}
          {%- case block.type -%}
            {%- when 'heading' -%}
              {%- assign tag = block.settings.heading_tag -%}
              {%- assign heading_font_family = '' -%}
              {%- assign heading_font_fallback = 'sans-serif' -%}
              {%- case block.settings.heading_google_font -%}
                {%- when 'inter' -%}{%- assign heading_font_family = 'Inter' -%}
                {%- when 'poppins' -%}{%- assign heading_font_family = 'Poppins' -%}
                {%- when 'montserrat' -%}{%- assign heading_font_family = 'Montserrat' -%}
                {%- when 'roboto' -%}{%- assign heading_font_family = 'Roboto' -%}
                {%- when 'oswald' -%}{%- assign heading_font_family = 'Oswald' -%}
                {%- when 'playfair_display' -%}{%- assign heading_font_family = 'Playfair Display' -%}{%- assign heading_font_fallback = 'serif' -%}
                {%- when 'lato' -%}{%- assign heading_font_family = 'Lato' -%}
                {%- when 'nunito' -%}{%- assign heading_font_family = 'Nunito' -%}
                {%- when 'open_sans' -%}{%- assign heading_font_family = 'Open Sans' -%}
                {%- when 'space_grotesk' -%}{%- assign heading_font_family = 'Space Grotesk' -%}
                {%- when 'merriweather' -%}{%- assign heading_font_family = 'Merriweather' -%}{%- assign heading_font_fallback = 'serif' -%}
                {%- when 'manrope' -%}{%- assign heading_font_family = 'Manrope' -%}
                {%- when 'raleway' -%}{%- assign heading_font_family = 'Raleway' -%}
                {%- when 'dm_sans' -%}{%- assign heading_font_family = 'DM Sans' -%}
                {%- when 'rubik' -%}{%- assign heading_font_family = 'Rubik' -%}
                {%- when 'plus_jakarta_sans' -%}{%- assign heading_font_family = 'Plus Jakarta Sans' -%}
                {%- when 'urbanist' -%}{%- assign heading_font_family = 'Urbanist' -%}
                {%- when 'cabin' -%}{%- assign heading_font_family = 'Cabin' -%}
                {%- when 'karla' -%}{%- assign heading_font_family = 'Karla' -%}
                {%- when 'barlow' -%}{%- assign heading_font_family = 'Barlow' -%}
                {%- when 'work_sans' -%}{%- assign heading_font_family = 'Work Sans' -%}
                {%- when 'outfit' -%}{%- assign heading_font_family = 'Outfit' -%}
                {%- when 'source_sans_3' -%}{%- assign heading_font_family = 'Source Sans 3' -%}
                {%- when 'pt_sans' -%}{%- assign heading_font_family = 'PT Sans' -%}
                {%- when 'noto_sans' -%}{%- assign heading_font_family = 'Noto Sans' -%}
                {%- when 'bebas_neue' -%}{%- assign heading_font_family = 'Bebas Neue' -%}
                {%- when 'anton' -%}{%- assign heading_font_family = 'Anton' -%}
                {%- when 'fira_sans' -%}{%- assign heading_font_family = 'Fira Sans' -%}
                {%- when 'quicksand' -%}{%- assign heading_font_family = 'Quicksand' -%}
                {%- when 'lora' -%}{%- assign heading_font_family = 'Lora' -%}{%- assign heading_font_fallback = 'serif' -%}
                {%- when 'libre_baskerville' -%}{%- assign heading_font_family = 'Libre Baskerville' -%}{%- assign heading_font_fallback = 'serif' -%}
                {%- when 'archivo' -%}{%- assign heading_font_family = 'Archivo' -%}
                {%- when 'jost' -%}{%- assign heading_font_family = 'Jost' -%}
              {%- endcase -%}
              {%- assign heading_custom_family = block.settings.heading_google_font_family_custom | strip -%}
              {%- if heading_custom_family != blank -%}
                {%- assign heading_font_family = heading_custom_family -%}
              {%- endif -%}
              <{{ tag }} class="video-banner__heading heading--{{ block.settings.heading_size }}" style="margin-top: {{ block.settings.margin_top | default: 0 }}px; margin-bottom: {{ block.settings.margin_bottom | default: 0 }}px; letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px; font-weight: {{ block.settings.heading_font_weight | default: '700' }} !important;{% if heading_font_family != blank %} font-family: '{{ heading_font_family }}', {{ heading_font_fallback }} !important;{% endif %}" data-aos="fade-up" data-aos-delay="{{ block_delay }}" {{ block.shopify_attributes }}>
                {{ block.settings.heading | escape }}
              </{{ tag }}>
            {%- when 'text' -%}
              <div class="video-banner__text text--{{ block.settings.text_size }}" style="margin-top: {{ block.settings.margin_top | default: 0 }}px; margin-bottom: {{ block.settings.margin_bottom | default: 0 }}px; letter-spacing: {{ block.settings.letter_spacing | default: 0 }}px;" data-aos="fade-up" data-aos-delay="{{ block_delay }}" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>
            {%- when 'button' -%}
              {%- if block.settings.button_label != blank -%}
                <div class="video-banner__actions" style="margin-top: {{ block.settings.margin_top | default: 0 }}px; margin-bottom: {{ block.settings.margin_bottom | default: 0 }}px;" data-aos="fade-up" data-aos-delay="{{ block_delay }}" {{ block.shopify_attributes }}>
                  <a
                    class="video-banner__button btn--{{ block.settings.button_style }}{% if block.settings.button_outline %} is-ghost{% endif %}{% if block.settings.button_full %} is-full{% endif %}"
                    href="{{ block.settings.button_link | default: '#' }}"
                    style="--vb-button-font-weight: {{ block.settings.button_font_weight | default: '700' }};"
                    {% if block.settings.button_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                  >
                    <span>{{ block.settings.button_label }}</span>
                    {% if block.settings.show_arrow %}<span class="video-banner__button-icon" aria-hidden="true">&#8594;</span>{% endif %}
                  </a>
                </div>
              {%- endif -%}
            {%- when 'rating_badge' -%}
              <div class="video-banner__badge-wrap" style="margin-top: {{ block.settings.margin_top | default: 0 }}px; margin-bottom: {{ block.settings.margin_bottom | default: 0 }}px;" data-aos="fade-up" data-aos-delay="{{ block_delay }}">
                {%- render 'glass-rating-badge', block: block -%}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>

<div class="video-banner__scroll-hint vb-scroll-hint--{{ section.id }}" aria-hidden="true">
  <div class="video-banner__scroll-mouse">
    <span class="video-banner__scroll-dot"></span>
  </div>
</div>

<script>
  (function () {
    var hint = document.querySelector('.vb-scroll-hint--{{ section.id }}');
    var section = document.querySelector('#shopify-section-{{ section.id }}');
    if (!hint || !section) return;

    // Pin it to viewport bottom-center
    hint.style.cssText = [
      'position:fixed',
      'bottom:28px',
      'left:50%',
      'transform:translateX(-50%)',
      'z-index:9999',
      'pointer-events:none',
      'opacity:0',
      'transition:opacity 0.5s ease'
    ].join(';');

    function update() {
      var rect = section.getBoundingClientRect();
      var visible = rect.top < window.innerHeight * 0.5 && rect.bottom > window.innerHeight * 0.5;
      hint.style.opacity = visible ? '0.5' : '0';
    }

    // Delay initial show so page paint settles
    setTimeout(function () {
      update();
      window.addEventListener('scroll', update, { passive: true });
    }, 1200);
  })();
</script>

{%- style -%}
  .video-banner {
    padding: var(--vb-padding-y) var(--vb-padding-x);
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
  }

  /* ================================================
     FRAME
  ================================================ */
  .video-banner__frame {
    position: relative;
    display: flex;
    overflow: hidden;
    border-radius: var(--vb-section-radius);
    min-height: var(--vb-height-mobile);
    max-height: 100svh;
    aspect-ratio: var(--vb-aspect-mobile);
    isolation: isolate;
  }

  .video-banner__frame--h-left { justify-content: flex-start; }
  .video-banner__frame--h-center { justify-content: center; }
  .video-banner__frame--h-right { justify-content: flex-end; }
  .video-banner__frame--v-top { align-items: flex-start; }
  .video-banner__frame--v-center { align-items: center; }
  .video-banner__frame--v-bottom { align-items: flex-end; }

  @media (min-width: 750px) {
    .video-banner__frame {
      min-height: var(--vb-height-desktop);
      aspect-ratio: var(--vb-aspect-desktop);
    }
  }

  /* ================================================
     MEDIA LAYER
  ================================================ */
  .video-banner__media {
    position: absolute;
    inset: 0;
  }

  .video-banner__video,
  .video-banner__iframe iframe,
  .video-banner__poster,
  .video-banner__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
    border: none;
    display: block;
    background: #000;
  }

  .video-banner__image {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .video-banner__iframe {
    position: absolute;
    inset: 0;
  }

  .video-banner__video--desktop { display: none; }
  .video-banner__video--mobile  { display: block; }

  @media (min-width: 750px) {
    .video-banner__video--desktop { display: block; }
    .video-banner__video--mobile  { display: none; }
  }

  /* ================================================
     CINEMATIC OVERLAY — vignette + gradient
  ================================================ */
  .video-banner__overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 110% 80% at 50% 50%, transparent 15%, rgba(0, 0, 0, 0.3) 100%),
      linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0.2) 0%,
        transparent 30%,
        transparent 60%,
        rgba(0, 0, 0, 0.55) 100%
      ),
      var(--vb-overlay-color);
    opacity: var(--vb-overlay-opacity);
    pointer-events: none;
  }

  /* ================================================
     CONTENT AREA
  ================================================ */
  .video-banner__content {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: var(--vb-content-vertical-desktop, center);
    justify-content: var(--vb-content-horizontal-desktop, center);
    padding: clamp(20px, 5vw, var(--vb-content-padding));
    text-align: var(--vb-text-align);
    z-index: 2;
  }

  .video-banner__content-inner {
    max-width: min(var(--vb-content-max), 100%);
    display: grid;
    gap: var(--vb-content-gap-desktop);
    margin: var(--vb-content-margin-top-desktop) var(--vb-content-margin-right-desktop) var(--vb-content-margin-bottom-desktop) var(--vb-content-margin-left-desktop);
    animation: vb-reveal 0.9s cubic-bezier(.22,.61,.36,1) 0.1s both;
  }

  .video-banner__content-inner.is-surfaced {
    background: color-mix(in srgb, var(--vb-content-bg) var(--vb-content-bg-opacity), transparent);
    backdrop-filter: blur(16px) saturate(1.3);
    -webkit-backdrop-filter: blur(16px) saturate(1.3);
    border-radius: var(--vb-content-radius);
    padding: clamp(20px, 4vw, var(--vb-content-padding));
    border: 1px solid rgba(255, 255, 255, 0.16);
    box-shadow: 0 8px 48px rgba(0, 0, 0, 0.22);
  }

  /* ================================================
     HEADING
  ================================================ */
  .video-banner__heading {
    margin: 0;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 28px rgba(0, 0, 0, 0.5), 0 1px 5px rgba(0, 0, 0, 0.32);
  }

  .video-banner__heading.heading--xl { font-size: clamp(30px, 5.5vw, 62px); line-height: 1.02; }
  .video-banner__heading.heading--lg { font-size: clamp(26px, 4.8vw, 50px); line-height: 1.05; }
  .video-banner__heading.heading--md { font-size: clamp(21px, 4vw, 36px); line-height: 1.1; }

  /* ================================================
     BODY TEXT
  ================================================ */
  .video-banner__text {
    margin: 0;
    opacity: 0.93;
    text-shadow: 0 1px 14px rgba(0, 0, 0, 0.4);
  }

  .video-banner__text.text--lg { font-size: clamp(16px, 3.2vw, 20px); line-height: 1.55; }
  .video-banner__text.text--md { font-size: clamp(15px, 3vw, 18px); line-height: 1.6; }
  .video-banner__text.text--sm { font-size: clamp(14px, 2.8vw, 16px); line-height: 1.65; }

  .video-banner__text p { margin: 0; }

  /* ================================================
     ACTIONS ROW
  ================================================ */
  .video-banner__actions {
    display: flex;
    width: 100%;
    flex-wrap: wrap;
    justify-content: var(--vb-actions-align);
    gap: 14px;
  }

  /* ================================================
     BADGE
  ================================================ */
  .video-banner__badge-wrap {
    width: fit-content;
    max-width: 100%;
    justify-self: var(--vb-badge-align);
  }

  .video-banner__content-inner > .video-banner__badge-wrap > .rating-badge {
    width: fit-content;
    max-width: 100%;
  }

  /* ================================================
     PREMIUM BUTTON
  ================================================ */
  .video-banner__button {
    position: relative;
    isolation: isolate;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-width: clamp(180px, 26vw, 252px);
    padding: 16px 40px;
    border-radius: 999px;
    font-weight: var(--vb-button-font-weight, 700);
    font-size: clamp(13px, 1.5vw, 15px);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    color: var(--vb-button-text);
    background: linear-gradient(135deg, var(--vb-button-bg) 0%, var(--vb-button-bg-alt) 100%);
    border: 1.5px solid color-mix(in srgb, var(--vb-button-border) 75%, rgba(255, 255, 255, 0.45));
    box-shadow:
      inset 0 2px 0 rgba(255, 255, 255, 0.3),
      inset 0 -1px 0 rgba(0, 0, 0, 0.14),
      0 6px 28px color-mix(in srgb, var(--vb-button-glow) var(--vb-button-glow-primary), transparent),
      0 2px 8px rgba(0, 0, 0, 0.32),
      0 0 0 0px color-mix(in srgb, var(--vb-button-glow) 18%, transparent),
      0 0 0 0px color-mix(in srgb, var(--vb-button-glow) 8%, transparent);
    overflow: hidden;
    transition:
      transform 0.32s cubic-bezier(.22,.61,.36,1),
      box-shadow 0.32s ease,
      background 0.3s ease,
      border-color 0.3s ease,
      color 0.3s ease;
    animation: vb-btn-breathe 3s ease-in-out infinite;
  }

  /* Inner gloss highlight */
  .video-banner__button::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      160deg,
      rgba(255, 255, 255, 0.3) 0%,
      rgba(255, 255, 255, 0) 50%,
      rgba(255, 255, 255, 0.1) 100%
    );
    pointer-events: none;
    z-index: 0;
  }

  /* Shimmer sweep on hover */
  .video-banner__button::after {
    content: "";
    position: absolute;
    top: -120%;
    left: -60%;
    width: 50%;
    height: 340%;
    background: linear-gradient(
      108deg,
      transparent 0%,
      rgba(255, 255, 255, 0.62) 46%,
      transparent 72%
    );
    transform: translateX(-220%) rotate(14deg);
    transition: transform 0.72s ease;
    pointer-events: none;
    z-index: 0;
  }

  .video-banner__button > span {
    position: relative;
    z-index: 1;
  }

  .video-banner__button-icon {
    transition: transform 0.28s cubic-bezier(.22,.61,.36,1);
    font-size: 1.05em;
    display: inline-block;
  }

  /* Primary variant */
  .video-banner__button.btn--primary {
    border-color: color-mix(in srgb, var(--vb-button-border) 75%, rgba(255, 255, 255, 0.45));
  }

  /* Secondary variant */
  .video-banner__button.btn--secondary {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--vb-button-bg) 22%, transparent),
      color-mix(in srgb, var(--vb-button-bg-alt) 32%, transparent)
    );
    border-color: color-mix(in srgb, var(--vb-button-border) 50%, transparent);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      0 6px 22px color-mix(in srgb, var(--vb-button-glow) var(--vb-button-glow-secondary), transparent);
  }

  /* Ghost variant */
  .video-banner__button.is-ghost {
    background: color-mix(in srgb, var(--vb-button-bg) 12%, transparent);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-color: color-mix(in srgb, var(--vb-button-border) 60%, transparent);
  }

  /* Full width mobile */
  .video-banner__button.is-full { width: 100%; max-width: 440px; }

  @media (min-width: 750px) {
    .video-banner__button.is-full { width: auto; max-width: none; }
  }

  /* Breathing halo rings */
  @keyframes vb-btn-breathe {
    0%, 100% {
      box-shadow:
        inset 0 2px 0 rgba(255, 255, 255, 0.3),
        inset 0 -1px 0 rgba(0, 0, 0, 0.14),
        0 6px 28px color-mix(in srgb, var(--vb-button-glow) var(--vb-button-glow-anim-low), transparent),
        0 2px 8px rgba(0, 0, 0, 0.32),
        0 0 0 0px color-mix(in srgb, var(--vb-button-glow) 18%, transparent),
        0 0 0 0px color-mix(in srgb, var(--vb-button-glow) 8%, transparent);
    }
    50% {
      box-shadow:
        inset 0 2px 0 rgba(255, 255, 255, 0.3),
        inset 0 -1px 0 rgba(0, 0, 0, 0.14),
        0 14px 52px color-mix(in srgb, var(--vb-button-glow) var(--vb-button-glow-anim-high), transparent),
        0 2px 8px rgba(0, 0, 0, 0.32),
        0 0 0 9px color-mix(in srgb, var(--vb-button-glow) 16%, transparent),
        0 0 0 20px color-mix(in srgb, var(--vb-button-glow) 6%, transparent);
    }
  }

  /* Hover */
  @media (hover: hover) and (pointer: fine) {
    .video-banner__button:hover {
      transform: translateY(-5px) scale(1.03);
      background: linear-gradient(135deg, var(--vb-button-bg-hover), var(--vb-button-bg-hover-alt));
      border-color: color-mix(in srgb, var(--vb-button-border-hover) 75%, rgba(255, 255, 255, 0.45));
      color: var(--vb-button-text-hover);
      box-shadow:
        inset 0 2px 0 rgba(255, 255, 255, 0.32),
        inset 0 -1px 0 rgba(0, 0, 0, 0.14),
        0 22px 64px color-mix(in srgb, var(--vb-button-glow) var(--vb-button-glow-hover), transparent),
        0 4px 14px rgba(0, 0, 0, 0.38),
        0 0 0 11px color-mix(in srgb, var(--vb-button-glow) 20%, transparent),
        0 0 0 24px color-mix(in srgb, var(--vb-button-glow) 7%, transparent);
      animation-play-state: paused;
    }

    .video-banner__button:hover::after {
      transform: translateX(165%) rotate(14deg);
    }

    .video-banner__button:hover .video-banner__button-icon {
      transform: translateX(5px);
    }
  }

  .video-banner__button:active {
    transform: translateY(-1px) scale(0.99);
    box-shadow:
      inset 0 2px 0 rgba(255, 255, 255, 0.2),
      0 4px 16px color-mix(in srgb, var(--vb-button-glow) var(--vb-button-glow-active), transparent),
      0 2px 6px rgba(0, 0, 0, 0.3);
  }

  /* ================================================
     SCROLL INDICATOR (positioned fixed via JS)
  ================================================ */
  .video-banner__scroll-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
  }

  .video-banner__scroll-mouse {
    width: 22px;
    height: 36px;
    border: 2px solid rgba(255, 255, 255, 0.8);
    border-radius: 12px;
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }

  .video-banner__scroll-dot {
    width: 4px;
    height: 7px;
    background: rgba(255, 255, 255, 0.95);
    border-radius: 2px;
    animation: vb-scroll-drop 1.8s ease-in-out infinite;
  }

  @keyframes vb-scroll-drop {
    0%   { opacity: 1; transform: translateY(0); }
    75%  { opacity: 0; transform: translateY(10px); }
    76%  { opacity: 0; transform: translateY(0); }
    100% { opacity: 0.4; transform: translateY(0); }
  }

  /* ================================================
     RESPONSIVE
  ================================================ */
  @media (max-width: 749px) {
    .video-banner__content {
      align-items: var(--vb-content-vertical-mobile, center);
      justify-content: var(--vb-content-horizontal-mobile, center);
      text-align: var(--vb-text-align-mobile);
      padding: clamp(16px, 5vw, 24px);
    }

    .video-banner__content-inner {
      gap: var(--vb-content-gap-mobile);
      margin: var(--vb-content-margin-top-mobile) var(--vb-content-margin-right-mobile) var(--vb-content-margin-bottom-mobile) var(--vb-content-margin-left-mobile);
    }

    .video-banner__actions { justify-content: var(--vb-actions-align-mobile); }
    .video-banner__badge-wrap { justify-self: var(--vb-badge-align-mobile); }

    .video-banner__button {
      min-width: clamp(148px, 62vw, 210px);
      padding: 14px 28px;
      font-size: 13px;
    }

    .video-banner__button.is-full { width: min(92%, 340px); max-width: 100%; }
  }

  @media (min-width: 900px) {
    .video-banner__content {
      padding: clamp(28px, 5vw, var(--vb-content-padding));
    }
  }

  /* ================================================
     KEYFRAMES
  ================================================ */
  @keyframes vb-reveal {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

{%- endstyle -%}

