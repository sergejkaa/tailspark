{%- style -%}
  .ts-wi {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_mobile }}px 0;
  }
  @media (min-width: 750px) {
    .ts-wi { padding: {{ section.settings.padding_desktop }}px 0; }
  }
  .ts-wi__inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .ts-wi__header {
    margin-bottom: 8px;
  }
  .ts-wi__heading {
    font-size: 28px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 4px;
    line-height: 1.2;
  }
  @media (min-width: 750px) { .ts-wi__heading { font-size: 34px; } }
  .ts-wi__flavor {
    font-size: 13px;
    font-weight: 600;
    color: {{ section.settings.heading_color }};
    opacity: 0.45;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 28px;
  }
  .ts-wi__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 750px) {
    .ts-wi__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0 32px;
    }
  }
  .ts-wi__item {
    display: flex;
    gap: 14px;
    padding: 18px 0;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    align-items: flex-start;
  }
  .ts-wi__item:last-child { border-bottom: none; }
  @media (min-width: 750px) {
    .ts-wi__item:nth-last-child(1):nth-child(odd) { border-bottom: none; }
    .ts-wi__item:nth-last-child(2):nth-child(odd) { border-bottom: none; }
  }
  .ts-wi__num {
    width: 32px;
    height: 32px;
    min-width: 32px;
    border-radius: 50%;
    background: {{ section.settings.accent_color }};
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 2px;
    flex-shrink: 0;
  }
  .ts-wi__text {}
  .ts-wi__title {
    font-size: 15px;
    font-weight: 700;
    color: {{ section.settings.item_title_color }};
    margin: 0 0 4px;
    line-height: 1.3;
  }
  .ts-wi__desc {
    font-size: 13px;
    color: {{ section.settings.item_text_color }};
    line-height: 1.6;
    margin: 0;
    opacity: 0.85;
  }
  .ts-wi__footer {
    margin-top: 28px;
    padding-top: 20px;
    border-top: 1px solid rgba(0,0,0,0.08);
    text-align: center;
  }
  .ts-wi__footer-title {
    font-size: 18px;
    font-weight: 700;
    color: {{ section.settings.item_title_color }};
    margin: 0 0 4px;
  }
  .ts-wi__footer-sub {
    font-size: 13px;
    color: {{ section.settings.item_text_color }};
    opacity: 0.65;
    margin: 0;
  }
{%- endstyle -%}

<section class="ts-wi">
  <div class="ts-wi__inner">
    <div class="ts-wi__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="ts-wi__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.flavor_subtitle != blank -%}
        <p class="ts-wi__flavor">{{ section.settings.flavor_subtitle }}</p>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="ts-wi__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'item' -%}
            <div class="ts-wi__item" {{ block.shopify_attributes }}>
              <div class="ts-wi__num" aria-hidden="true">{{ forloop.index }}</div>
              <div class="ts-wi__text">
                <p class="ts-wi__title">{{ block.settings.title }}</p>
                {%- if block.settings.description != blank -%}
                  <p class="ts-wi__desc">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.flavor_title != blank -%}
      <div class="ts-wi__footer">
        <p class="ts-wi__footer-title">{{ section.settings.flavor_title }}</p>
        {%- if section.settings.flavor_subtitle != blank -%}
          <p class="ts-wi__footer-sub">{{ section.settings.flavor_subtitle }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "What's Inside",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "What's Inside" },
    { "type": "text", "id": "flavor_title", "label": "Flavor title (footer)", "default": "Real. Clean. Effective." },
    { "type": "text", "id": "flavor_subtitle", "label": "Flavor subtitle", "default": "Chicken Liver & Sweet Potato Flavor" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Section background", "default": "#fff8ed" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#ff6700" },
    { "type": "color", "id": "accent_color", "label": "Number badge color", "default": "#ff6700" },
    { "type": "color", "id": "item_title_color", "label": "Ingredient name color", "default": "#1d1d1b" },
    { "type": "color", "id": "item_text_color", "label": "Description text color", "default": "#555555" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_desktop", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding (desktop)", "default": 60 },
    { "type": "range", "id": "padding_mobile", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Padding (mobile)", "default": 40 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Ingredient",
      "settings": [
        { "type": "text", "id": "title", "label": "Ingredient name", "default": "Ingredient Name" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "A short description of what this ingredient does for your dog." }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "What's Inside",
      "blocks": [
        { "type": "item", "settings": { "title": "Ingredient 1", "description": "Description of the first key ingredient." } },
        { "type": "item", "settings": { "title": "Ingredient 2", "description": "Description of the second key ingredient." } },
        { "type": "item", "settings": { "title": "Ingredient 3", "description": "Description of the third key ingredient." } }
      ]
    }
  ]
}
{% endschema %}
