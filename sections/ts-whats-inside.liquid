{%- style -%}
  .ts-wi {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_mobile }}px 0;
  }
  @media (min-width: 750px) {
    .ts-wi { padding: {{ section.settings.padding_desktop }}px 0; }
  }
  .ts-wi__inner {
  }
  .ts-wi__heading {
    font-size: 28px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 24px;
    line-height: 1.2;
    text-align: center;
  }
  @media (min-width: 750px) { .ts-wi__heading { font-size: 36px; } }

  /* Tabs */
  .ts-wi__tabs {
    display: flex;
    border-bottom: 2px solid rgba(0,0,0,0.1);
    margin-bottom: 28px;
  }
  .ts-wi__tab {
    padding: 10px 20px 12px;
    font-size: 14px;
    font-weight: 600;
    color: {{ section.settings.item_text_color }};
    opacity: 0.5;
    cursor: pointer;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    background: none;
    transition: opacity 0.2s, border-color 0.2s, color 0.2s;
    letter-spacing: 0.02em;
  }
  .ts-wi__tab.is-active {
    color: {{ section.settings.heading_color }};
    opacity: 1;
    border-bottom-color: {{ section.settings.heading_color }};
  }
  .ts-wi__tab:hover:not(.is-active) { opacity: 0.75; }

  /* Panels */
  .ts-wi__panel { display: none; }
  .ts-wi__panel.is-active { display: block; }

  /* Ingredient grid */
  .ts-wi__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }
  @media (min-width: 600px) {
    .ts-wi__grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
  }

  /* Ingredient card */
  .ts-wi__card {
    background: {{ section.settings.card_bg }};
    border-radius: 16px;
    padding: 20px;
    display: flex;
    align-items: flex-start;
    gap: 0;
    position: relative;
    overflow: hidden;
    min-height: 110px;
  }
  .ts-wi__card-text {
    flex: 1;
    min-width: 0;
    z-index: 1;
    padding-right: 12px;
  }
  .ts-wi__card-name {
    font-size: 15px;
    font-weight: 700;
    color: {{ section.settings.item_title_color }};
    margin: 0 0 4px;
    line-height: 1.3;
  }
  .ts-wi__card-dosage {
    font-size: 12px;
    color: {{ section.settings.item_text_color }};
    opacity: 0.65;
    margin: 0 0 7px;
    font-weight: 500;
  }
  .ts-wi__card-desc {
    font-size: 13px;
    color: {{ section.settings.item_text_color }};
    line-height: 1.55;
    margin: 0;
    opacity: 0.9;
  }
  .ts-wi__card-img-wrap {
    width: 88px;
    min-width: 88px;
    height: 88px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    align-self: center;
  }
  .ts-wi__card-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .ts-wi__card-placeholder {
    width: 72px;
    height: 72px;
    background: rgba(0,0,0,0.055);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 30px;
  }

  /* Nutritional info panel */
  .ts-wi__nutri-panel {
    background: {{ section.settings.card_bg }};
    border-radius: 16px;
    padding: 24px 28px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
  }
  @media (max-width: 600px) {
    .ts-wi__nutri-panel { grid-template-columns: 1fr; gap: 20px; padding: 20px; }
  }
  .ts-wi__nutri-title {
    font-size: 13px;
    font-weight: 700;
    color: {{ section.settings.item_title_color }};
    margin: 0 0 12px;
    letter-spacing: 0.01em;
  }
  .ts-wi__nutri-row {
    display: flex;
    align-items: flex-end;
    gap: 6px;
    padding: 4px 0;
    border-bottom: 1px dotted rgba(0,0,0,0.13);
  }
  .ts-wi__nutri-row:last-child { border-bottom: none; }
  .ts-wi__nutri-name {
    font-size: 12.5px;
    color: {{ section.settings.item_text_color }};
    white-space: nowrap;
    flex-shrink: 0;
  }
  .ts-wi__nutri-spacer {
    flex: 1;
    min-width: 8px;
  }
  .ts-wi__nutri-amount {
    font-size: 12.5px;
    font-weight: 600;
    color: {{ section.settings.item_text_color }};
    white-space: nowrap;
    flex-shrink: 0;
  }
  .ts-wi__nutri-inactive-text {
    font-size: 12.5px;
    color: {{ section.settings.item_text_color }};
    line-height: 1.65;
    margin: 0;
    opacity: 0.85;
  }

  /* Footer */
  .ts-wi__footer {
    margin-top: 28px;
    padding-top: 20px;
    border-top: 1px solid rgba(0,0,0,0.08);
    text-align: center;
  }
  .ts-wi__footer-title {
    font-size: 18px;
    font-weight: 700;
    color: {{ section.settings.item_title_color }};
    margin: 0 0 4px;
  }
  .ts-wi__footer-sub {
    font-size: 13px;
    color: {{ section.settings.item_text_color }};
    opacity: 0.65;
    margin: 0;
  }
{%- endstyle -%}

{%- assign has_nutrition = false -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'nutrition_item' -%}{%- assign has_nutrition = true -%}{%- endif -%}
{%- endfor -%}

<section class="ts-wi">
  <div class="ts-wi__inner page-width">

    {%- if section.settings.heading != blank -%}
      <h2 class="ts-wi__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="ts-wi__tabs" role="tablist">
      <button class="ts-wi__tab is-active" role="tab" aria-selected="true" data-ts-wi-tab="ingredients">Ingredients</button>
      {%- if has_nutrition -%}
        <button class="ts-wi__tab" role="tab" aria-selected="false" data-ts-wi-tab="nutrition">Nutritional Information</button>
      {%- endif -%}
    </div>

    <div class="ts-wi__panel is-active" data-ts-wi-panel="ingredients">
      {%- if section.blocks.size > 0 -%}
        <div class="ts-wi__grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'item' -%}
              <div class="ts-wi__card" {{ block.shopify_attributes }}>
                <div class="ts-wi__card-text">
                  <p class="ts-wi__card-name">{{ block.settings.title }}</p>
                  {%- if block.settings.dosage != blank -%}
                    <p class="ts-wi__card-dosage">{{ block.settings.dosage }}</p>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <p class="ts-wi__card-desc">{{ block.settings.description }}</p>
                  {%- endif -%}
                </div>
                <div class="ts-wi__card-img-wrap">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 180 | image_tag: class: 'ts-wi__card-img', loading: 'lazy', alt: block.settings.title }}
                  {%- else -%}
                    <div class="ts-wi__card-placeholder" aria-hidden="true">🌿</div>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- if has_nutrition -%}
      <div class="ts-wi__panel" data-ts-wi-panel="nutrition">
        <div class="ts-wi__nutri-panel">
          <div>
            <p class="ts-wi__nutri-title">Active Ingredients (per 1 chew)</p>
            {%- for block in section.blocks -%}
              {%- if block.type == 'nutrition_item' -%}
                <div class="ts-wi__nutri-row" {{ block.shopify_attributes }}>
                  <span class="ts-wi__nutri-name">{{ block.settings.ingredient }}</span>
                  <span class="ts-wi__nutri-spacer"></span>
                  <span class="ts-wi__nutri-amount">{{ block.settings.amount }}</span>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
          {%- if section.settings.inactive_ingredients != blank -%}
            <div>
              <p class="ts-wi__nutri-title">Inactive Ingredients:</p>
              <p class="ts-wi__nutri-inactive-text">{{ section.settings.inactive_ingredients }}</p>
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.flavor_title != blank -%}
      <div class="ts-wi__footer">
        <p class="ts-wi__footer-title">{{ section.settings.flavor_title }}</p>
        {%- if section.settings.flavor_subtitle != blank -%}
          <p class="ts-wi__footer-sub">{{ section.settings.flavor_subtitle }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

<script>
(function() {
  document.querySelectorAll('.ts-wi').forEach(function(sec) {
    var tabs = sec.querySelectorAll('[data-ts-wi-tab]');
    var panels = sec.querySelectorAll('[data-ts-wi-panel]');
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        var target = tab.dataset.tsWiTab;
        tabs.forEach(function(t) { t.classList.remove('is-active'); t.setAttribute('aria-selected', 'false'); });
        panels.forEach(function(p) { p.classList.remove('is-active'); });
        tab.classList.add('is-active');
        tab.setAttribute('aria-selected', 'true');
        var panel = sec.querySelector('[data-ts-wi-panel="' + target + '"]');
        if (panel) panel.classList.add('is-active');
      });
    });
  });
})();
</script>

{% schema %}
{
  "name": "What's Inside",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "What's Inside" },
    { "type": "text", "id": "flavor_title", "label": "Footer title", "default": "Real. Clean. Effective." },
    { "type": "text", "id": "flavor_subtitle", "label": "Footer subtitle", "default": "Chicken Liver & Sweet Potato Flavor" },
    { "type": "textarea", "id": "inactive_ingredients", "label": "Inactive ingredients (for Nutritional tab)" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Section background", "default": "#fff8ed" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#eef2f8" },
    { "type": "color", "id": "heading_color", "label": "Heading / active tab color", "default": "#ff6700" },
    { "type": "color", "id": "item_title_color", "label": "Ingredient name color", "default": "#1d1d1b" },
    { "type": "color", "id": "item_text_color", "label": "Description text color", "default": "#555555" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_desktop", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding (desktop)", "default": 60 },
    { "type": "range", "id": "padding_mobile", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Padding (mobile)", "default": 40 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Ingredient",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Ingredient image" },
        { "type": "text", "id": "title", "label": "Ingredient name", "default": "Ingredient Name" },
        { "type": "text", "id": "dosage", "label": "Dosage (e.g. 375mg)" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "A short description of what this ingredient does for your dog." }
      ]
    },
    {
      "type": "nutrition_item",
      "name": "Nutrition Row",
      "settings": [
        { "type": "text", "id": "ingredient", "label": "Ingredient name", "default": "Ingredient" },
        { "type": "text", "id": "amount", "label": "Amount (e.g. 50mg)", "default": "50mg" }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "What's Inside",
      "blocks": [
        { "type": "item", "settings": { "title": "Ingredient 1", "dosage": "375mg", "description": "Description of the first key ingredient." } },
        { "type": "item", "settings": { "title": "Ingredient 2", "dosage": "200mg", "description": "Description of the second key ingredient." } },
        { "type": "item", "settings": { "title": "Ingredient 3", "dosage": "50mg", "description": "Description of the third key ingredient." } },
        { "type": "item", "settings": { "title": "Ingredient 4", "dosage": "2.5mg", "description": "Description of the fourth key ingredient." } }
      ]
    }
  ]
}
{% endschema %}
