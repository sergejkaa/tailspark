{% schema %}
{
  "name": "Looping Products",
  "settings": [
    {
      "type": "text",
      "id": "marquee_heading",
      "label": "Heading",
      "default": "BESTSELLERS"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h3", "label": "Large" },
        { "value": "h4", "label": "Extra large" },
        { "value": "h5", "label": "Extra extra large" }
      ],
      "default": "h1"
    },
    {
      "type": "checkbox",
      "id": "use_page_width",
      "label": "Constrain to page width (track)",
      "default": true
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        {
          "value": "1-1",
          "label": "1 : 1 (square)"
        },
        {
          "value": "3-4",
          "label": "3 : 4"
        },
        {
          "value": "2-3",
          "label": "2 : 3 (taller)"
        },
        {
          "value": "9-16",
          "label": "9 : 16 (very tall)"
        }
      ],
      "default": "2-3"
    },
    {
      "type": "range",
      "id": "focus_y",
      "label": "Vertical focus (top↔bottom %)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 12
    },
    {
      "type": "color",
      "id": "product_title_color",
      "label": "Product Title Color",
      "default": "#4E4E4E"
    },
    {
      "type": "select",
      "id": "title_size",
      "label": "Product Title Size",
      "options": [
        {
          "value": "1rem",
          "label": "Small"
        },
        {
          "value": "1.18rem",
          "label": "Medium"
        },
        {
          "value": "1.4rem",
          "label": "Large"
        },
        {
          "value": "1.6rem",
          "label": "X-Large"
        },
        {
          "value": "1.85rem",
          "label": "XX-Large"
        }
      ],
      "default": "1.18rem"
    },
    {
      "type": "select",
      "id": "price_size",
      "label": "Price Size",
      "options": [
        {
          "value": "1rem",
          "label": "Small"
        },
        {
          "value": "1.18rem",
          "label": "Medium"
        },
        {
          "value": "1.4rem",
          "label": "Large"
        },
        {
          "value": "1.6rem",
          "label": "X-Large"
        },
        {
          "value": "1.85rem",
          "label": "XX-Large"
        }
      ],
      "default": "1.18rem"
    },
    {
      "type": "select",
      "id": "price_weight",
      "label": "Price Weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price Color",
      "default": "#A8C6E5"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "label": "Scroll Speed (seconds per 1000px)",
      "min": 8,
      "max": 60,
      "step": 1,
      "default": 25
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1"
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Gap Between Products (px)",
      "min": 0,
      "max": 60,
      "step": 2,
      "default": 28
    },
    {
      "type": "checkbox",
      "id": "hide_title",
      "label": "Hide Product Title",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_price",
      "label": "Hide Product Price",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "💜 Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Looping Products",
      "blocks": [
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        }
      ]
    }
  ]
}
{% endschema %}

<style>
/* ===== Base ===== */
.looping-marquee-section{
  width:100%;
  overflow:hidden;
  padding-top: {{ section.settings.padding_top | default: 32 }}px;
  padding-bottom: {{ section.settings.padding_bottom | default: 32 }}px;
}
.looping-marquee-section .title-wrapper-with-link{ margin-top:0 !important; }
.section.looping-marquee-section h2.title.inline-richtext{ margin-top:0 !important; margin-block-start:0 !important; }

/* ===== Track ===== */
.looping-marquee-wrapper{ position:relative; overflow:hidden; white-space:nowrap; width:100%; display:flex; }
.looping-marquee-track{
  --gap: {{ section.settings.item_gap | default: 28 }}px;
  display:flex; width:max-content;
  gap: var(--gap);
  padding-left: var(--gap);
  animation: marquee3d var(--marquee-duration, {{ section.settings.marquee_speed | default: 25 }}s) linear infinite;
  will-change: transform;
}
.looping-marquee-wrapper:hover .looping-marquee-track{ animation-play-state: paused; }

/* ===== Card ===== */
.looping-marquee-item{
  display:flex; flex-direction:column; align-items:center; text-align:center; position:relative;
  width:220px; min-width:220px;
}

/* Ratio classes */
.lm-media{ width:100%; border-radius:14px; overflow:hidden; display:block; background:none; box-shadow:none; }
.lm-media.ratio-1-1{ aspect-ratio: 1 / 1; }
.lm-media.ratio-3-4{ aspect-ratio: 3 / 4; }
.lm-media.ratio-2-3{ aspect-ratio: 2 / 3; }
.lm-media.ratio-9-16{ aspect-ratio: 9 / 16; }

.lm-media img{
  width:100%; height:100%;
  object-fit:cover;
  object-position: 50% {{ section.settings.focus_y | default: 12 }}%;
  transition: transform .22s;
}
.looping-marquee-item:hover .lm-media img{ transform: scale(1.06); }

/* Titles */
.marquee-title{
  display:block;
  margin-top:10px;
  margin-bottom:2px;
  padding:0 6px 0.2em;
  text-decoration:none;
  color: {{ section.settings.product_title_color | default: '#4E4E4E' }};
  font-size: {{ section.settings.title_size | default: '1.18rem' }};
  line-height:1.18;
  white-space:normal;
  overflow:hidden;
  text-overflow:ellipsis;
  display:-webkit-box;
  -webkit-line-clamp:2;
  -webkit-box-orient:vertical;
}

/* Price */
.marquee-price{
  font-size: {{ section.settings.price_size | default: '1.18rem' }};
  color: {{ section.settings.price_color | default: '#A8C6E5' }};
  text-align:center;
  margin-top:2px;
  font-weight: {{ section.settings.price_weight | default: 700 }};
  letter-spacing: .1px;
  font-family: inherit;
}

@keyframes marquee3d{
  from{ transform: translate3d(0,0,0); }
  to{   transform: translate3d(calc(var(--loop-distance, 0px) * -1),0,0); }
}

@media (max-width: 800px){
  .looping-marquee-item{ width:180px; min-width:180px; }
}
</style>

<div class="section looping-marquee-section color-{{ section.settings.color_scheme }} center" data-section-id="{{ section.id }}">
  {% if section.settings.marquee_heading != blank %}
    <div class="page-width">
      <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin">
        <h2 data-aos="fade-left" class="title inline-richtext {{ section.settings.heading_size | default: 'h1' }}">
          {{ section.settings.marquee_heading }}
        </h2>
      </div>
    </div>
  {% endif %}

  <div class="{% if section.settings.use_page_width %}page-width {% endif %}looping-marquee-wrapper">
    <div class="looping-marquee-track">
      {%- for block in section.blocks -%}
        {%- assign p = block.settings.product -%}
        {%- assign prod = nil -%}
        {%- if p != blank -%}
          {%- assign prod = all_products[p] -%}
        {%- endif -%}

        {%- assign ratio_class = section.settings.image_ratio | default: '2-3' -%}

        {%- if prod -%}
          <div data-aos="flip-up" class="looping-marquee-item" {{ block.shopify_attributes }}>
            <a class="lm-media ratio-{{ ratio_class }}" href="{{ prod.url }}">
              <img src="{{ prod.featured_image | img_url: '600x' }}" alt="{{ prod.title | escape }}">
            </a>
            {% unless section.settings.hide_title %}
              <a href="{{ prod.url }}" class="marquee-title">{{ prod.title }}</a>
            {% endunless %}
            {% unless section.settings.hide_price %}
              {% if prod.price > 0 %}
                <div class="marquee-price">{{ prod.price | money }}</div>
              {% endif %}
            {% endunless %}
          </div>
        {%- else -%}
          <!-- Placeholder item when no product selected -->
          <div data-aos="flip-up" class="looping-marquee-item" {{ block.shopify_attributes }}>
            <div class="lm-media ratio-{{ ratio_class }}">
              <img
                src="{{ 'empty-product.webp' | asset_url }}"
                alt="Add your product"
              >
            </div>
            {% unless section.settings.hide_title %}
              <span class="marquee-title">Add your products</span>
            {% endunless %}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
(function() {
  const section = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!section || section.dataset.marqueeInit === '1') return;
  section.dataset.marqueeInit = '1';

  const wrapper = section.querySelector('.looping-marquee-wrapper');
  const track = section.querySelector('.looping-marquee-track');
  if (!wrapper || !track) return;

  // pause on hover
  wrapper.addEventListener('mouseenter', () => track.style.animationPlayState = 'paused');
  wrapper.addEventListener('mouseleave', () => track.style.animationPlayState = 'running');

  const secondsPer1000 = Math.max(0.1, Number('{{ section.settings.marquee_speed | default: 25 }}'));

  const debounce = (fn, ms=150) => { let t; return (...a) => { clearTimeout(t); t=setTimeout(()=>fn(...a), ms); }; };

  const waitForImages = (root) => {
    const imgs = Array.from(root.querySelectorAll('img'));
    const pending = imgs.filter(i => !i.complete || i.naturalWidth === 0);
    if (pending.length === 0) return Promise.resolve();
    return Promise.all(pending.map(img => new Promise(res => {
      img.addEventListener('load', res, {once:true});
      img.addEventListener('error', res, {once:true});
    })));
  };

  const measureGroupWidth = (els, gap) => {
    if (!els.length) return 0;
    const range = document.createRange();
    range.setStartBefore(els[0]);
    range.setEndAfter(els[els.length - 1]);
    const rect = range.getBoundingClientRect();
    return Math.round(rect.width) + Math.round(gap);
  };

  const setAnimation = (distancePx) => {
    const d = Math.max(1, Math.round(distancePx));
    const duration = (d / 1000) * secondsPer1000;
    track.style.animation = 'none'; void track.offsetWidth;
    track.style.setProperty('--loop-distance', d + 'px');
    track.style.setProperty('--marquee-duration', duration + 's');
    track.style.animation = '';
  };

  const buildClones = () => {
    track.querySelectorAll('.is-dup').forEach(n => n.remove());

    const allChildren = Array.from(track.children);
    const originals = allChildren.filter(el => !el.classList.contains('is-dup'));
    if (!originals.length) return {distance:0};

    const gap = parseFloat(getComputedStyle(track).gap || '0');

    const range = document.createRange();
    range.setStartBefore(originals[0]);
    range.setEndAfter(originals[originals.length - 1]);
    const rect = range.getBoundingClientRect();
    const groupWidthRaw = rect.width;

    const neededGroups = Math.max(2, Math.floor(wrapper.clientWidth / groupWidthRaw) + 2);
    for (let i = 0; i < neededGroups - 1; i++) {
      originals.forEach(el => {
        const c = el.cloneNode(true);
        c.classList.add('is-dup');
        c.setAttribute('aria-hidden', 'true');
        track.appendChild(c);
      });
    }

    track.style.paddingLeft = gap + 'px';

    const distance = measureGroupWidth(originals, gap);
    return {distance};
  };

  const init = async () => {
    await waitForImages(track);
    const {distance} = buildClones();
    if (distance > 0) setAnimation(distance);
  };

  init();

  let lastW = wrapper.clientWidth;
  const onResize = debounce(() => {
    const w = wrapper.clientWidth;
    if (Math.abs(w - lastW) > 1) { lastW = w; init(); }
  }, 200);
  const ro = new ResizeObserver(onResize);
  ro.observe(wrapper);

  const media = window.matchMedia('(prefers-reduced-motion: reduce)');
  const applyPRM = () => { track.style.animationPlayState = media.matches ? 'paused' : 'running'; };
  media.addEventListener ? media.addEventListener('change', applyPRM) : media.addListener(applyPRM);
  applyPRM();

  wrapper.addEventListener('focusin', () => track.style.animationPlayState = 'paused');
  wrapper.addEventListener('focusout', () => track.style.animationPlayState = 'running');
})();
</script>
