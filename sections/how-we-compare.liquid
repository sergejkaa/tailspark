{%- liquid
  assign primary_label = section.settings.primary_label | default: 'Our product'
  assign secondary_label = section.settings.secondary_label | default: 'Other brands'
  assign primary_label_plain = primary_label | strip_html
  assign secondary_label_plain = secondary_label | strip_html
  assign show_lottie = false
  assign lottie_container_id = 'compare-lottie-' | append: section.id
  if section.settings.enable_lottie and section.settings.lottie_json_url != blank
    assign show_lottie = true
  endif
  assign lottie_position_setting = section.settings.lottie_position | default: 'heading'
  assign lottie_is_product = false
  assign lottie_is_heading = false
  assign lottie_is_corner = false
  case lottie_position_setting
    when 'product'
      assign lottie_is_product = true
    when 'heading'
      assign lottie_is_heading = true
    when 'corner'
      assign lottie_is_corner = true
    else
      assign lottie_is_product = true
  endcase
  capture compare_check_svg
    echo '<svg viewBox="0 0 24 24" role="presentation" aria-hidden="true" focusable="false"><polyline points="4 12 9 17 20 6"></polyline></svg>'
  endcapture
  capture compare_cross_svg
    echo '<svg viewBox="0 0 24 24" role="presentation" aria-hidden="true" focusable="false"><line x1="5" y1="5" x2="19" y2="19"></line><line x1="19" y1="5" x2="5" y2="19"></line></svg>'
  endcapture
-%}

{% style %}
  #compare-{{ section.id }} {
    --compare-heading-color: {{ section.settings.heading_color }};
    --compare-heading-size: {{ section.settings.heading_size }}px;
    --compare-heading-weight: {{ section.settings.heading_weight }};
    --compare-heading-gap: {{ section.settings.heading_spacing }}px;
    --compare-feature-color: {{ section.settings.feature_color }};
    --compare-feature-size: {{ section.settings.feature_size }}px;
    --compare-feature-size-mobile: {{ section.settings.feature_size_mobile | default: section.settings.feature_size }}px;
    --compare-feature-weight: {{ section.settings.feature_weight }};
    --compare-row-divider: {{ section.settings.row_divider_color }};
    --compare-primary-column-bg: {{ section.settings.primary_column_bg }};
    --compare-primary-column-radius: {{ section.settings.primary_column_radius }}px;
    --compare-row-padding: {{ section.settings.row_padding }}px;
    --compare-row-padding-mobile: {{ section.settings.row_padding_mobile | default: section.settings.row_padding }}px;
    --compare-icon-size: {{ section.settings.icon_size }}px;
    --compare-icon-stroke: {{ section.settings.icon_stroke }};
    --compare-primary-check-color: {{ section.settings.primary_check_color }};
    --compare-primary-cross-color: {{ section.settings.primary_cross_color }};
    --compare-secondary-check-color: {{ section.settings.secondary_check_color }};
    --compare-secondary-cross-color: {{ section.settings.secondary_cross_color }};
    --compare-max-width: {{ section.settings.content_max_width }}px;
    --compare-section-bg: {{ section.settings.section_background }};
    --compare-primary-text-color: {{ section.settings.primary_text_color }};
    --compare-secondary-text-color: {{ section.settings.secondary_text_color }};
    --compare-primary-image-max: {{ section.settings.primary_image_max_width }}px;
    --compare-secondary-image-max: {{ section.settings.secondary_image_max_width }}px;
    --compare-lottie-width: {{ section.settings.lottie_width }}px;
    --compare-lottie-height: {{ section.settings.lottie_height }}px;
    --compare-lottie-top: {{ section.settings.lottie_offset_top }}px;
    --compare-lottie-right: {{ section.settings.lottie_offset_right }}px;
    --compare-lottie-mobile-offset: {{ section.settings.lottie_mobile_offset_top | default: section.settings.lottie_offset_top }}px;
    --compare-section-padding-top: {{ section.settings.padding_top }}px;
    --compare-section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --compare-section-padding-top-mobile: {{ section.settings.padding_top_mobile | default: section.settings.padding_top }}px;
    --compare-section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile | default: section.settings.padding_bottom }}px;
    padding-top: var(--compare-section-padding-top);
    padding-bottom: var(--compare-section-padding-bottom);
    background-color: var(--compare-section-bg);
  }

  #compare-{{ section.id }} .compare-section__inner {
    max-width: min(var(--compare-max-width), var(--page-width, var(--compare-max-width)));
    margin: 0 auto;
    width: min(100%, var(--page-width, var(--compare-max-width)));
    padding: 0 clamp(16px, 5vw, 48px);
    position: relative;
  }

  #compare-{{ section.id }} .compare-heading-row {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: nowrap;
    gap: 12px;
    margin: 0 0 var(--compare-heading-gap);
    text-align: center;
  }

  #compare-{{ section.id }} .compare-heading {
    color: var(--compare-heading-color);
    font-size: var(--compare-heading-size);
    font-weight: var(--compare-heading-weight);
    margin: 0;
    line-height: 1.2;
  }

  #compare-{{ section.id }} .compare-table__wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  #compare-{{ section.id }} .compare-lottie {
    position: absolute;
    top: var(--compare-lottie-top);
    right: var(--compare-lottie-right);
    width: var(--compare-lottie-width);
    height: var(--compare-lottie-height);
    max-width: 100%;
    pointer-events: none;
    z-index: 5;
    opacity: 0;
    display: block;
    transition: opacity 0.35s ease;
  }

  #compare-{{ section.id }} .compare-lottie.is-visible {
    opacity: 1;
  }

  #compare-{{ section.id }} .compare-lottie--inline {
    position: static;
    margin: 0 auto calc(var(--compare-heading-gap) * 0.3);
    width: 100%;
    justify-content: center;
    right: auto;
    left: auto;
    display: flex;
  }

  #compare-{{ section.id }} .compare-lottie--product {
    top: 0;
    left: 50%;
    right: auto;
    transform: translate(calc(-50% + var(--compare-lottie-right)), calc(-100% + var(--compare-lottie-top)));
  }

  #compare-{{ section.id }} .compare-lottie--heading {
    position: static;
    opacity: 1;
    width: var(--compare-lottie-width);
    height: var(--compare-lottie-height);
    display: flex;
    justify-content: center;
    align-items: center;
    transform: none;
    right: auto;
    top: auto;
    transition: opacity 0.35s ease;
    margin-left: 6px;
    flex-shrink: 0;
  }

  #compare-{{ section.id }} .compare-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    table-layout: fixed;
    display: table !important;
  }

  #compare-{{ section.id }} .compare-table thead {
    display: table-header-group !important;
  }

  #compare-{{ section.id }} .compare-table tbody {
    display: table-row-group !important;
  }

  #compare-{{ section.id }} .compare-table tr {
    display: table-row !important;
  }

  #compare-{{ section.id }} .compare-table th,
  #compare-{{ section.id }} .compare-table td {
    display: table-cell !important;
    vertical-align: middle;
  }

  #compare-{{ section.id }} .compare-col--feature { width: 62%; }
  #compare-{{ section.id }} .compare-col--primary { width: 20%; }
  #compare-{{ section.id }} .compare-col--secondary { width: 18%; }

  #compare-{{ section.id }} thead th {
    padding: calc(var(--compare-row-padding) + 8px) clamp(12px, 3vw, 32px);
    border: none;
    text-align: center;
  }

  #compare-{{ section.id }} thead th:first-child {
    text-align: left;
    color: var(--compare-feature-color);
    font-size: calc(var(--compare-feature-size) * 0.9);
    font-weight: var(--compare-feature-weight);
  }

  #compare-{{ section.id }} .compare-table__brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    color: var(--compare-feature-color);
    font-weight: 600;
    text-align: center;
    position: relative;
    overflow: visible;
  }

  #compare-{{ section.id }} .compare-brand-stack {
    position: relative;
    overflow: visible;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #compare-{{ section.id }} .compare-brand-stack--with-lottie {
    padding-top: calc(var(--compare-lottie-height) * 0.35);
  }

  #compare-{{ section.id }} .compare-table__brand img {
    display: block;
    width: auto;
    height: auto;
    margin-left: auto;
    margin-right: auto;
  }
  #compare-{{ section.id }} .compare-table__brand--primary,
  #compare-{{ section.id }} .compare-table__brand--secondary {
    overflow: visible;
    padding-bottom: 0;
  }
  #compare-{{ section.id }} .compare-brand-image {
    display: flex;
    justify-content: center;
  }
  #compare-{{ section.id }} .compare-table__brand--primary img {
    max-width: var(--compare-primary-image-max);
  }
  #compare-{{ section.id }} .compare-table__brand--secondary img {
    max-width: var(--compare-secondary-image-max);
  }

  #compare-{{ section.id }} tbody th {
    text-align: left;
    padding: var(--compare-row-padding) clamp(12px, 3vw, 32px);
    color: var(--compare-feature-color);
    font-size: var(--compare-feature-size);
    font-weight: var(--compare-feature-weight);
    border-bottom: 1px solid var(--compare-row-divider);
  }

  #compare-{{ section.id }} .compare-feature-text {
    display: inline-block;
  }

  #compare-{{ section.id }} tbody td {
    padding: var(--compare-row-padding) clamp(12px, 2vw, 24px);
    text-align: center;
    border-bottom: 1px solid var(--compare-row-divider);
  }

  #compare-{{ section.id }} tbody tr:last-child td,
  #compare-{{ section.id }} tbody tr:last-child th {
    border-bottom: none;
  }

  #compare-{{ section.id }} thead th.compare-table__brand--primary,
  #compare-{{ section.id }} td.compare-table__cell--primary {
    background-color: var(--compare-primary-column-bg);
  }

  #compare-{{ section.id }} thead th.compare-table__brand--primary {
    border-top-left-radius: var(--compare-primary-column-radius);
    border-top-right-radius: var(--compare-primary-column-radius);
  }

  #compare-{{ section.id }} tbody tr:last-child td.compare-table__cell--primary {
    border-bottom-left-radius: var(--compare-primary-column-radius);
    border-bottom-right-radius: var(--compare-primary-column-radius);
  }

  #compare-{{ section.id }} .compare-table__cell--primary {
    color: var(--compare-primary-text-color);
  }

  #compare-{{ section.id }} .compare-table__cell--secondary {
    color: var(--compare-secondary-text-color);
  }

  #compare-{{ section.id }} .compare-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--compare-icon-size);
    height: var(--compare-icon-size);
  }

  #compare-{{ section.id }} .compare-icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: var(--compare-icon-stroke);
  }

  #compare-{{ section.id }} .compare-table__cell--primary .compare-icon--check { color: var(--compare-primary-check-color); }
  #compare-{{ section.id }} .compare-table__cell--primary .compare-icon--cross { color: var(--compare-primary-cross-color); }
  #compare-{{ section.id }} .compare-table__cell--secondary .compare-icon--check { color: var(--compare-secondary-check-color); }
  #compare-{{ section.id }} .compare-table__cell--secondary .compare-icon--cross { color: var(--compare-secondary-cross-color); }

  #compare-{{ section.id }} .compare-icon--cross {
    opacity: 0.9;
  }

  #compare-{{ section.id }} .compare-icon--cross svg {
    transform: scale(0.88);
    transform-origin: center;
  }

  #compare-{{ section.id }} .compare-table__cell--primary .compare-icon--check svg {
    stroke-width: calc(var(--compare-icon-stroke) + 1);
  }

  #compare-{{ section.id }} .compare-icon__text {
    display: inline-block;
    font-weight: 600;
  }

  #compare-{{ section.id }} .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 749px) {
    #compare-{{ section.id }} {
      padding-top: var(--compare-section-padding-top-mobile);
      padding-bottom: var(--compare-section-padding-bottom-mobile);
    }
    #compare-{{ section.id }} .compare-table {
      min-width: 120vw;
      width: 120vw;
      table-layout: fixed;
    }
    #compare-{{ section.id }} .compare-heading {
      font-size: calc(var(--compare-heading-size) - 8px);
    }
    #compare-{{ section.id }} .compare-heading-row {
      gap: 8px;
      margin-bottom: calc(var(--compare-heading-gap) * 0.55);
      flex-wrap: wrap;
    }
    #compare-{{ section.id }} .compare-lottie:not(.compare-lottie--inline) {
      width: calc(var(--compare-lottie-width) * 0.7);
      height: calc(var(--compare-lottie-height) * 0.7);
      top: var(--compare-lottie-mobile-offset);
    }
    #compare-{{ section.id }} .compare-lottie--inline {
      width: 100%;
    }
    #compare-{{ section.id }} .compare-lottie--product {
      transform: translate(calc(-50% + var(--compare-lottie-right)), calc(-100% + var(--compare-lottie-mobile-offset)));
    }
    /* feature+primary = 75% of 120vw = 90vw — fills exactly to section's page-width right edge */
    #compare-{{ section.id }} .compare-col--feature { width: 55%; }
    #compare-{{ section.id }} .compare-col--primary { width: 20%; }
    #compare-{{ section.id }} .compare-col--secondary { width: 25%; }

    #compare-{{ section.id }} thead th,
    #compare-{{ section.id }} tbody th,
    #compare-{{ section.id }} tbody td {
      padding-top: var(--compare-row-padding-mobile);
      padding-bottom: var(--compare-row-padding-mobile);
      padding-right: 16px;
    }

    #compare-{{ section.id }} thead th:first-child,
    #compare-{{ section.id }} tbody th {
      padding-left: 0;
    }

    #compare-{{ section.id }} tbody th {
      font-size: var(--compare-feature-size-mobile);
      line-height: 1.35;
    }

    #compare-{{ section.id }} thead th:first-child {
      font-size: calc(var(--compare-feature-size-mobile) * 0.9);
    }

    #compare-{{ section.id }} .compare-table__brand--primary img {
      max-width: calc(var(--compare-primary-image-max) * 0.65);
    }

    #compare-{{ section.id }} .compare-table__brand--secondary img {
      max-width: calc(var(--compare-secondary-image-max) * 0.65);
    }
  }

  @media (max-width: 520px) {
    #compare-{{ section.id }} .compare-heading {
      font-size: calc(var(--compare-heading-size) - 10px);
    }
    #compare-{{ section.id }} .compare-heading-row {
      gap: 6px;
      margin-bottom: calc(var(--compare-heading-gap) * 0.5);
    }
    #compare-{{ section.id }} .compare-lottie:not(.compare-lottie--inline) {
      width: calc(var(--compare-lottie-width) * 0.6);
      height: calc(var(--compare-lottie-height) * 0.6);
      top: var(--compare-lottie-mobile-offset);
    }
    #compare-{{ section.id }} .compare-lottie--product {
      transform: translate(calc(-50% + var(--compare-lottie-right)), calc(-100% + var(--compare-lottie-mobile-offset)));
    }

    #compare-{{ section.id }} thead th,
    #compare-{{ section.id }} tbody th,
    #compare-{{ section.id }} tbody td {
      padding-left: 8px;
      padding-right: 8px;
    }

    #compare-{{ section.id }} .compare-table__brand--primary img {
      max-width: calc(var(--compare-primary-image-max) * 0.55);
    }

    #compare-{{ section.id }} .compare-table__brand--secondary img {
      max-width: calc(var(--compare-secondary-image-max) * 0.55);
    }
  }
{% endstyle %}

<section id="compare-{{ section.id }}" class="compare-section">
  <div class="compare-section__inner page-width">
    {%- if section.settings.heading_text != blank -%}
      <div class="compare-heading-row" data-aos="fade" data-aos-duration="800" data-aos-offset="250" data-aos-once="true">
        <h2 class="compare-heading">{{ section.settings.heading_text | escape }}</h2>
        {%- if show_lottie and lottie_is_heading -%}
          <div class="compare-lottie compare-lottie--heading" id="{{ lottie_container_id }}" aria-hidden="true"></div>
        {%- endif -%}
      </div>
    {%- endif -%}
    {%- if show_lottie and lottie_is_corner -%}
      <div class="compare-lottie" id="{{ lottie_container_id }}" aria-hidden="true"></div>
    {%- endif -%}

    <div class="compare-table__wrapper">
      <table class="compare-table">
        <colgroup>
          <col class="compare-col compare-col--feature">
          <col class="compare-col compare-col--primary">
          <col class="compare-col compare-col--secondary">
        </colgroup>
        <thead>
          <tr>
            <th scope="col">
              {%- if section.settings.show_feature_label and section.settings.feature_column_label != blank -%}
                {{ section.settings.feature_column_label | escape }}
              {%- endif -%}
            </th>
            <th scope="col" class="compare-table__brand compare-table__brand--primary">
              {%- assign primary_stack_class = 'compare-brand-stack' -%}
              {%- if show_lottie and lottie_is_product -%}
                {%- assign primary_stack_class = primary_stack_class | append: ' compare-brand-stack--with-lottie' -%}
              {%- endif -%}
              <div class="{{ primary_stack_class }}">
                {%- if show_lottie and lottie_is_product -%}
                  <div class="compare-lottie compare-lottie--product" id="{{ lottie_container_id }}" aria-hidden="true"></div>
                {%- endif -%}
                {%- if section.settings.primary_image != blank -%}
                  <div class="compare-brand-image" data-aos="zoom-in" data-aos-delay="100" data-aos-offset="220" data-aos-once="true">
                    {{ section.settings.primary_image | image_url: width: 400 | image_tag: widths: '200,300,400', alt: section.settings.primary_image.alt | default: primary_label_plain, loading: 'lazy', class: 'compare-brand-image__img' }}
                  </div>
                {%- elsif primary_label != blank -%}
                  <span>{{ primary_label | escape }}</span>
                {%- endif -%}
              </div>
            </th>
            <th scope="col" class="compare-table__brand compare-table__brand--secondary">
              <div class="compare-brand-stack">
                {%- if section.settings.secondary_image != blank -%}
                  <div class="compare-brand-image" data-aos="zoom-in" data-aos-delay="200" data-aos-offset="220" data-aos-once="true">
                    {{ section.settings.secondary_image | image_url: width: 400 | image_tag: widths: '200,300,400', alt: section.settings.secondary_image.alt | default: secondary_label_plain, loading: 'lazy', class: 'compare-brand-image__img' }}
                  </div>
                {%- elsif secondary_label != blank -%}
                  <span>{{ secondary_label | escape }}</span>
                {%- endif -%}
              </div>
            </th>
          </tr>
        </thead>
        <tbody>
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- assign feature_text = block.settings.feature_text | default: 'Feature' -%}
              {%- assign feature_plain = feature_text | strip_html -%}
              <tr id="block-{{ block.id }}" {{ block.shopify_attributes }}>
                <th scope="row">
                  <span class="compare-feature-text" data-aos="fade" data-aos-delay="{{ forloop.index0 | times: 80 }}" data-aos-offset="200" data-aos-once="true">
                    {{ feature_text | escape }}
                  </span>
                </th>
                <td class="compare-table__cell compare-table__cell--primary">
                  {%- case block.settings.primary_state -%}
                    {%- when 'text' -%}
                      <span class="compare-icon__text">
                        {%- if block.settings.primary_text != blank -%}
                          {{ block.settings.primary_text | escape }}
                        {%- else -%}
                          &mdash;
                        {%- endif -%}
                      </span>
                    {%- when 'cross' -%}
                      <span class="compare-icon compare-icon--cross compare-icon--primary" aria-hidden="true">
                        {{ compare_cross_svg }}
                      </span>
                      <span class="visually-hidden">{{ primary_label_plain | escape }} does not include {{ feature_plain | escape }}</span>
                    {%- else -%}
                      <span class="compare-icon compare-icon--check compare-icon--primary" aria-hidden="true">
                        {{ compare_check_svg }}
                      </span>
                      <span class="visually-hidden">{{ primary_label_plain | escape }} includes {{ feature_plain | escape }}</span>
                  {%- endcase -%}
                </td>
                <td class="compare-table__cell compare-table__cell--secondary">
                  {%- case block.settings.secondary_state -%}
                    {%- when 'text' -%}
                      <span class="compare-icon__text">
                        {%- if block.settings.secondary_text != blank -%}
                          {{ block.settings.secondary_text | escape }}
                        {%- else -%}
                          &mdash;
                        {%- endif -%}
                      </span>
                    {%- when 'check' -%}
                      <span class="compare-icon compare-icon--check compare-icon--secondary" aria-hidden="true">
                        {{ compare_check_svg }}
                      </span>
                      <span class="visually-hidden">{{ secondary_label_plain | escape }} includes {{ feature_plain | escape }}</span>
                    {%- else -%}
                      <span class="compare-icon compare-icon--cross compare-icon--secondary" aria-hidden="true">
                        {{ compare_cross_svg }}
                      </span>
                      <span class="visually-hidden">{{ secondary_label_plain | escape }} does not include {{ feature_plain | escape }}</span>
                  {%- endcase -%}
                </td>
              </tr>
            {%- endfor -%}
          {%- else -%}
            <tr>
              <th scope="row">Add feature rows to finish this comparison.</th>
              <td colspan="2">&mdash;</td>
            </tr>
          {%- endif -%}
        </tbody>
      </table>
    </div>
  </div>
</section>

{%- if show_lottie -%}
  <script>
    (function() {
      var containerId = '{{ lottie_container_id }}';
      var animationPath = {{ section.settings.lottie_json_url | json }};
      var shouldLoop = {{ section.settings.lottie_loop | json }};
      var shouldAutoplay = {{ section.settings.lottie_autoplay | json }};
      var animationSpeed = {{ section.settings.lottie_speed | json }};

      function ensureLottieScript(callback) {
        if (window.bodymovin) {
          callback();
          return;
        }

        var existingScript = document.getElementById('lottie-web-lib');
        if (existingScript) {
          existingScript.addEventListener('load', callback, { once: true });
          return;
        }

        var script = document.createElement('script');
        script.id = 'lottie-web-lib';
        script.src = 'https://cdnjs.cloudflare.com/ajax/libs/bodymovin/5.12.2/lottie.min.js';
        script.async = true;
        script.onload = callback;
        document.head.appendChild(script);
      }

      function startAnimation() {
        var target = document.getElementById(containerId);
        if (!target || target.dataset.lottieMounted === 'true' || !window.bodymovin) {
          return;
        }
        target.dataset.lottieMounted = 'true';
        target.classList.add('is-visible');
        var animation = window.bodymovin.loadAnimation({
          container: target,
          renderer: 'svg',
          loop: shouldLoop,
          autoplay: shouldAutoplay,
          path: animationPath
        });
        animation.setSpeed(animationSpeed);
      }

      function initLottie() {
        if (window.bodymovin) {
          startAnimation();
        } else {
          ensureLottieScript(startAnimation);
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initLottie);
      } else {
        initLottie();
      }
    })();
  </script>
{%- endif -%}

