{%- style -%}
  .fg-section {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top_mobile }}px 0 {{ section.settings.padding_bottom_mobile }}px;
  }
  @media (min-width: 750px) {
    .fg-section { padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px; }
  }
  .fg-inner {
    max-width: 600px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .fg-header {
    text-align: center;
    margin-bottom: 24px;
  }
  .fg-heading {
    font-size: 28px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 6px;
    line-height: 1.2;
  }
  @media (min-width: 750px) { .fg-heading { font-size: 34px; } }
  .fg-subheading {
    font-size: 14px;
    color: {{ section.settings.text_color }};
    opacity: 0.7;
    margin: 0;
  }
  .fg-list {
    background: {{ section.settings.card_bg }};
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.07);
  }
  .fg-row {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(0,0,0,0.07);
  }
  .fg-row:last-child { border-bottom: none; }
  .fg-icon-circle {
    width: {{ section.settings.icon_size | plus: 16 }}px;
    height: {{ section.settings.icon_size | plus: 16 }}px;
    min-width: {{ section.settings.icon_size | plus: 16 }}px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    background: rgba(255,255,255,0.55);
    flex-shrink: 0;
  }
  .fg-dog-img {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    object-fit: contain;
    display: block;
  }
  .fg-weight {
    flex: 1;
    font-size: 15px;
    font-weight: 500;
    color: {{ section.settings.heading_color }};
    min-width: 80px;
  }
  .fg-dots {
    flex: 2;
    height: 0;
    border-top: 2px dotted {{ section.settings.accent_color }};
    opacity: 0.25;
    min-width: 20px;
  }
  .fg-chews {
    font-size: 16px;
    font-weight: 700;
    color: {{ section.settings.chews_color }};
    white-space: nowrap;
    text-align: right;
    min-width: 70px;
  }
  .fg-note {
    text-align: center;
    margin-top: 16px;
    font-size: 12px;
    color: {{ section.settings.text_color }};
    opacity: 0.55;
    line-height: 1.5;
  }
  @media (max-width: 479px) {
    .fg-row { padding: 14px 16px; gap: 10px; }
    .fg-icon-circle { width: {{ section.settings.icon_size | plus: 8 }}px; height: {{ section.settings.icon_size | plus: 8 }}px; min-width: {{ section.settings.icon_size | plus: 8 }}px; font-size: 22px; }
    .fg-dog-img { width: {{ section.settings.icon_size | minus: 8 }}px; height: {{ section.settings.icon_size | minus: 8 }}px; }
    .fg-weight { font-size: 13px; }
    .fg-chews { font-size: 14px; min-width: 60px; }
  }
{%- endstyle -%}

<section class="fg-section">
  <div class="fg-inner">
    {%- if section.settings.heading != blank -%}
      <div class="fg-header" data-aos="fade-up">
        <h2 class="fg-heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="fg-subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="fg-list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'row' -%}
            {%- assign fg_delay = forloop.index0 | times: 100 | at_most: 300 -%}
            <div class="fg-row" data-aos="fade-up" data-aos-delay="{{ fg_delay }}" {{ block.shopify_attributes }}>
              <div class="fg-icon-circle" aria-hidden="true">
                {%- if block.settings.icon_image_preset != 'none' and block.settings.icon_image_preset != blank -%}
                  {%- assign dog_img = 'ts-dog-dose-' | append: block.settings.icon_image_preset | append: '.png' -%}
                  <img src="{{ dog_img | asset_url }}" class="fg-dog-img" width="{{ section.settings.icon_size }}" height="{{ section.settings.icon_size }}" loading="lazy" alt="{{ block.settings.size_label | escape }}">
                {%- elsif block.settings.icon != blank -%}
                  {{ block.settings.icon }}
                {%- endif -%}
              </div>
              <span class="fg-weight">{{ block.settings.weight_range }}</span>
              <div class="fg-dots" aria-hidden="true"></div>
              <span class="fg-chews">{{ block.settings.chews_count }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.note != blank -%}
      <p class="fg-note" data-aos="fade-up">{{ section.settings.note }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Feeding Guide",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Feeding Guide" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Give daily based on your dog's weight" },
    { "type": "textarea", "id": "note", "label": "Footer note (optional)", "default": "For best results, give chews consistently each day. Always provide fresh water." },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#ffffff" },
    { "type": "color", "id": "card_bg", "label": "List background", "default": "#fff8ed" },
    { "type": "color", "id": "heading_color", "label": "Heading & weight text", "default": "#1d1d1b" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#555555" },
    { "type": "color", "id": "accent_color", "label": "Accent color (dots line)", "default": "#ff6700" },
    { "type": "color", "id": "chews_color", "label": "Chews text color", "default": "#606060" },
    { "type": "header", "content": "Icon" },
    { "type": "range", "id": "icon_size", "min": 24, "max": 72, "step": 4, "unit": "px", "label": "Dog icon size", "default": 48 },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top (desktop)", "default": 56 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom (desktop)", "default": 56 },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Padding top (mobile)", "default": 36 },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Padding bottom (mobile)", "default": 36 }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Dog Size",
      "settings": [
        { "type": "select", "id": "icon_image_preset", "label": "Dog size image", "default": "none", "options": [
            { "value": "none", "label": "None (use emoji below)" },
            { "value": "small", "label": "Small dog" },
            { "value": "medium", "label": "Medium dog" },
            { "value": "large", "label": "Large dog" },
            { "value": "xlarge", "label": "X-Large dog" }
          ] },
        { "type": "text", "id": "icon", "label": "Emoji icon (fallback)", "default": "🐕" },
        { "type": "text", "id": "size_label", "label": "Size label (optional)", "default": "Small" },
        { "type": "text", "id": "weight_range", "label": "Weight range", "default": "Up to 25 lbs" },
        { "type": "text", "id": "chews_count", "label": "Daily chews", "default": "1 chew / day" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Feeding Guide",
      "blocks": [
        { "type": "row", "settings": { "icon": "🐩", "size_label": "Small", "weight_range": "Up to 25 lbs", "chews_count": "1 chew" } },
        { "type": "row", "settings": { "icon": "🐕", "size_label": "Medium", "weight_range": "25 - 50 lbs", "chews_count": "2 chews" } },
        { "type": "row", "settings": { "icon": "🐕‍🦺", "size_label": "Large", "weight_range": "50 - 75 lbs", "chews_count": "3 chews" } },
        { "type": "row", "settings": { "icon": "🦮", "size_label": "X-Large", "weight_range": "Over 75 lbs", "chews_count": "4 chews" } }
      ]
    }
  ]
}
{% endschema %}
