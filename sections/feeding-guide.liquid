{%- style -%}
  .feeding-guide {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media (max-width: 749px) {
    .feeding-guide {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

  .feeding-guide__inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .feeding-guide__header {
    text-align: center;
    margin-bottom: 32px;
  }

  .feeding-guide__heading {
    font-size: 30px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 8px;
    line-height: 1.2;
  }

  .feeding-guide__subheading {
    font-size: 15px;
    color: {{ section.settings.text_color }};
    margin: 0;
    opacity: 0.75;
  }

  .feeding-guide__grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_most: 4 }}, 1fr);
    gap: 16px;
  }

  @media (max-width: 749px) {
    .feeding-guide__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    .feeding-guide__heading { font-size: 24px; }
    .feeding-guide__header { margin-bottom: 24px; }
    .feeding-guide__card { padding: 16px 12px; }
    .feeding-guide__icon { font-size: 32px; }
  }

  .feeding-guide__card {
    background-color: {{ section.settings.card_bg }};
    border-radius: 16px;
    padding: 22px 16px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .feeding-guide__icon {
    font-size: 44px;
    line-height: 1;
  }

  .feeding-guide__size-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: {{ section.settings.accent_color }};
  }

  .feeding-guide__weight {
    font-size: 13px;
    font-weight: 600;
    color: {{ section.settings.heading_color }};
    margin: 0;
  }

  .feeding-guide__chews-wrap {
    background-color: {{ section.settings.accent_color }};
    border-radius: 50px;
    padding: 6px 14px;
    margin-top: 2px;
  }

  .feeding-guide__chews {
    font-size: 13px;
    font-weight: 700;
    color: #ffffff;
    white-space: nowrap;
  }

  .feeding-guide__note {
    text-align: center;
    margin-top: 20px;
    font-size: 13px;
    color: {{ section.settings.text_color }};
    opacity: 0.6;
  }
{%- endstyle -%}

<section class="feeding-guide">
  <div class="feeding-guide__inner">

    {%- if section.settings.heading != blank -%}
      <div class="feeding-guide__header">
        <h2 class="feeding-guide__heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="feeding-guide__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="feeding-guide__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'row' -%}
            <div class="feeding-guide__card" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                <div class="feeding-guide__icon" aria-hidden="true">{{ block.settings.icon }}</div>
              {%- endif -%}
              <span class="feeding-guide__size-label">{{ block.settings.size_label }}</span>
              <p class="feeding-guide__weight">{{ block.settings.weight_range }}</p>
              <div class="feeding-guide__chews-wrap">
                <span class="feeding-guide__chews">{{ block.settings.chews_count }}</span>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.note != blank -%}
      <p class="feeding-guide__note">{{ section.settings.note }}</p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Feeding Guide",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Feeding Guide" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Give daily based on your dog's weight" },
    { "type": "textarea", "id": "note", "label": "Footer note (optional)", "default": "For best results, give chews consistently each day. Always provide fresh water. Consult your vet before adding supplements." },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#ffffff" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#fff8ed" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#1d1d1b" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#555555" },
    { "type": "color", "id": "accent_color", "label": "Accent color (label + chew badge)", "default": "#ff6700" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top (desktop)", "default": 56 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom (desktop)", "default": 56 },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Padding top (mobile)", "default": 36 },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "Padding bottom (mobile)", "default": 36 }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Dog Size",
      "settings": [
        { "type": "text", "id": "icon", "label": "Emoji icon", "default": "🐕" },
        { "type": "text", "id": "size_label", "label": "Size label (e.g. Small)", "default": "Small" },
        { "type": "text", "id": "weight_range", "label": "Weight range", "default": "Up to 25 lbs" },
        { "type": "text", "id": "chews_count", "label": "Daily chews", "default": "1 chew / day" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Feeding Guide",
      "blocks": [
        { "type": "row", "settings": { "icon": "🐩", "size_label": "Small", "weight_range": "Up to 25 lbs", "chews_count": "1 chew / day" } },
        { "type": "row", "settings": { "icon": "🐕", "size_label": "Medium", "weight_range": "25 - 50 lbs", "chews_count": "2 chews / day" } },
        { "type": "row", "settings": { "icon": "🐕‍🦺", "size_label": "Large", "weight_range": "50 - 75 lbs", "chews_count": "3 chews / day" } },
        { "type": "row", "settings": { "icon": "🦮", "size_label": "X-Large", "weight_range": "75+ lbs", "chews_count": "4 chews / day" } }
      ]
    }
  ]
}
{% endschema %}
