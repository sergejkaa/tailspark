{%- assign discount_pct = section.settings.discount_percent -%}
{%- assign remaining = 100 | minus: discount_pct -%}

{%- style -%}
  .subscription-section {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  @media (max-width: 749px) {
    .subscription-section {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

  .subscription-section__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .subscription-section__heading {
    font-size: 42px;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 12px;
    line-height: 1.15;
  }

  .subscription-section__subheading {
    font-size: 17px;
    color: {{ section.settings.text_color }};
    margin: 0;
  }

  .subscription-section__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .subscription-card {
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .subscription-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.1);
  }

  .subscription-card__image {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background-color: rgba(255,255,255,0.5);
  }

  .subscription-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .subscription-card__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48px;
    opacity: 0.3;
  }

  .subscription-card__body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .subscription-card__title {
    font-size: 17px;
    font-weight: 700;
    color: {{ section.settings.card_heading_color }};
    margin: 0;
  }

  .subscription-card__pricing {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .subscription-card__price-original {
    font-size: 13px;
    color: {{ section.settings.card_text_color }};
    text-decoration: line-through;
    opacity: 0.6;
  }

  .subscription-card__price-sub {
    font-size: 16px;
    font-weight: 700;
    color: {{ section.settings.card_heading_color }};
  }

  .subscription-card__badge {
    font-size: 11px;
    font-weight: 700;
    background-color: {{ section.settings.badge_bg }};
    color: {{ section.settings.badge_text }};
    padding: 3px 8px;
    border-radius: 50px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .subscription-card__btn {
    display: block;
    text-align: center;
    padding: 12px 16px;
    border-radius: 50px;
    background-color: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text }};
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
    margin-top: auto;
  }

  .subscription-card__btn:hover {
    background-color: {{ section.settings.button_hover_bg }};
    color: {{ section.settings.button_hover_text }};
  }

  /* Coming Soon state */
  .subscription-card__image { position: relative; }
  .subscription-card__soon-badge {
    position: absolute; top: 10px; left: 10px; z-index: 2;
    background: #1d1d1b; color: #fff8ed; font-size: 10px; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase; padding: 4px 11px; border-radius: 30px;
  }
  .subscription-card--soon .subscription-card__image img { opacity: 0.82; }
  .subscription-card__price-soon { color: #999; font-style: italic; font-size: 14px; }
  .subscription-card__btn--soon { background-color: #1d1d1b !important; color: #fff !important; }
  .subscription-card__btn--soon:hover { background-color: #000 !important; }

  .subscription-card__title-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .subscription-card__title-link:hover .subscription-card__title {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .subscription-section__footnote {
    text-align: center;
    margin-top: 32px;
    font-size: 14px;
    color: {{ section.settings.text_color }};
    opacity: 0.7;
  }

  @media (max-width: 1023px) {
    .subscription-section__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .subscription-section__heading {
      font-size: 32px;
    }
  }

  @media (max-width: 749px) {
    .subscription-section__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .subscription-section__heading {
      font-size: 26px;
    }

    .subscription-section__subheading {
      font-size: 15px;
    }

    .subscription-section__header {
      margin-bottom: 28px;
    }

    .subscription-card__body {
      padding: 14px;
      gap: 8px;
    }

    .subscription-card__title {
      font-size: 14px;
    }

    .subscription-card__price-sub {
      font-size: 14px;
    }

    .subscription-card__btn {
      font-size: 13px;
      padding: 10px 12px;
    }
  }
{%- endstyle -%}

<section class="subscription-section">
  <div class="page-width">

    <div class="subscription-section__header" data-aos="fade-up">
      <h2 class="subscription-section__heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="subscription-section__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="subscription-section__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'product' -%}
          {%- assign prod = block.settings.product -%}
          {%- if prod != blank -%}
            {%- assign discounted_price = prod.price | times: remaining | divided_by: 100 -%}
          {%- endif -%}

          {%- assign card_url = prod.url | default: '/collections/all' -%}
          {%- assign sub_delay = forloop.index0 | times: 100 | at_most: 300 -%}
          {%- assign sub_coming_soon = block.settings.coming_soon -%}
          <div class="subscription-card{% if sub_coming_soon %} subscription-card--soon{% endif %}" data-aos="fade-up" data-aos-delay="{{ sub_delay }}" style="background-color: {{ block.settings.card_bg }};" {{ block.shopify_attributes }}>

            <a href="{{ card_url }}" class="subscription-card__image" aria-label="{{ block.settings.title_override | default: prod.title }}">
              {%- if sub_coming_soon -%}<span class="subscription-card__soon-badge">Coming Soon</span>{%- endif -%}
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 600
                  | image_tag: loading: 'lazy', alt: block.settings.title_override
                }}
              {%- elsif prod != blank and prod.featured_image -%}
                {{
                  prod.featured_image
                  | image_url: width: 600
                  | image_tag: loading: 'lazy', alt: prod.title
                }}
              {%- else -%}
                <div class="subscription-card__image-placeholder">🐾</div>
              {%- endif -%}
            </a>

            <div class="subscription-card__body">
              <a href="{{ card_url }}" class="subscription-card__title-link">
                <h3 class="subscription-card__title">
                  {{- block.settings.title_override | default: prod.title -}}
                </h3>
              </a>

              {%- if sub_coming_soon -%}
                <a href="{{ card_url }}" class="subscription-card__btn subscription-card__btn--soon">
                  Notify Me
                </a>
              {%- else -%}
                <div class="subscription-card__pricing">
                  {%- if prod != blank -%}
                    <span class="subscription-card__price-original">{{ prod.price | money }}</span>
                    <span class="subscription-card__price-sub">{{ discounted_price | money }}</span>
                  {%- endif -%}
                  <span class="subscription-card__badge">Save {{ discount_pct }}%</span>
                </div>

                <a
                  href="{%- if prod != blank -%}{{ prod.url }}{%- else -%}/collections/all{%- endif -%}"
                  class="subscription-card__btn"
                >
                  {{- block.settings.button_label | default: 'Subscribe & Save' -}}
                </a>
              {%- endif -%}
            </div>

          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.footnote != blank -%}
      <p class="subscription-section__footnote">{{ section.settings.footnote }}</p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Subscription Section",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Subscribe & Save 15%"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Never run out. Cancel anytime."
    },
    {
      "type": "text",
      "id": "footnote",
      "label": "Footnote (optional)",
      "default": "Free shipping on every order. Cancel or pause anytime."
    },
    {
      "type": "range",
      "id": "discount_percent",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "%",
      "label": "Subscription discount",
      "default": 15
    },
    {
      "type": "header",
      "content": "Section colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#fff8ed"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1d1d1b"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Subheading / footnote color",
      "default": "#555555"
    },
    {
      "type": "header",
      "content": "Card colors"
    },
    {
      "type": "color",
      "id": "card_heading_color",
      "label": "Card title color",
      "default": "#1d1d1b"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card text color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Badge background",
      "default": "#ff6700"
    },
    {
      "type": "color",
      "id": "badge_text",
      "label": "Badge text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#ff6700"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg",
      "label": "Button hover background",
      "default": "#1d1d1b"
    },
    {
      "type": "color",
      "id": "button_hover_text",
      "label": "Button hover text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top (desktop)",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (desktop)",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top (mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom (mobile)",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "checkbox",
          "id": "coming_soon",
          "label": "Mark as Coming Soon",
          "info": "Shows a Coming Soon badge, hides the price and replaces the button. The card stays clickable. Uncheck when the product launches.",
          "default": false
        },
        {
          "type": "text",
          "id": "title_override",
          "label": "Title override (optional)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image override (optional)"
        },
        {
          "type": "color",
          "id": "card_bg",
          "label": "Card background",
          "default": "#ffffff"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Subscribe & Save"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Subscription Section"
    }
  ]
}
{% endschema %}
