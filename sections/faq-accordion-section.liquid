{%- style -%}
  .faq-section {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  .faq-section__inner {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .faq-section__heading {
    text-align: center;
    margin-bottom: 12px;
    font-size: clamp(2.2rem, 4vw, 3.6rem);
    font-weight: 700;
    color: rgb(var(--color-foreground));
  }
  .faq-section__subheading {
    text-align: center;
    font-size: 1.4rem;
    color: rgba(var(--color-foreground), 0.55);
    margin-bottom: 48px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 600;
  }

  /* Category heading */
  .faq-category {
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.5);
    padding: 6px 0 10px;
    margin: 32px 0 8px;
    border-bottom: 1.5px solid rgba(var(--color-foreground), 0.1);
  }
  .faq-category:first-of-type { margin-top: 0; }

  /* Accordion items — same style as yny-accordion */
  .faq-acc {
    border: 1.5px solid rgba(0,0,0,0.13);
    border-radius: 12px;
    overflow: hidden;
    background: rgb(var(--color-background));
    margin-bottom: 8px;
  }
  .faq-acc__summary {
    cursor: pointer;
    padding: 14px 18px;
    font-weight: 600;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 1.4rem;
    color: rgb(var(--color-foreground));
  }
  .faq-acc__summary::-webkit-details-marker { display: none; }
  .faq-acc__icon {
    position: relative;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-left: 12px;
    opacity: .5;
    transition: transform .32s cubic-bezier(.22, 1, .36, 1), opacity .2s ease;
  }
  .faq-acc__icon::before,
  .faq-acc__icon::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 2px;
    right: 2px;
    height: 1.5px;
    border-radius: 999px;
    background: currentColor;
    transform: translateY(-50%);
    transition: transform .32s cubic-bezier(.22, 1, .36, 1), opacity .2s ease;
  }
  .faq-acc__icon::after {
    transform: translateY(-50%) rotate(90deg);
  }
  details.faq-acc[open] .faq-acc__icon {
    transform: rotate(180deg);
    opacity: .8;
  }
  .faq-acc.is-closing .faq-acc__icon {
    transform: rotate(0deg);
    opacity: .5;
  }
  details.faq-acc[open] .faq-acc__icon::after {
    transform: translateY(-50%) rotate(0deg);
    opacity: 0;
  }
  .faq-acc.is-closing .faq-acc__icon::after {
    transform: translateY(-50%) rotate(90deg);
    opacity: 1;
  }
  .faq-acc__content {
    height: 0;
    overflow: hidden;
    transition: height var(--faq-acc-dur, 0.34s) cubic-bezier(.22, 1, .36, 1);
    will-change: height;
  }
  .faq-acc.is-ready[open] .faq-acc__content { height: auto; }
  .faq-acc__inner {
    padding: 0 18px 16px;
    font-size: 1.4rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.75);
  }
  .faq-acc__inner p { margin: 0; }
  @media (prefers-reduced-motion: reduce) {
    .faq-acc__content, .faq-acc__icon,
    .faq-acc__icon::before, .faq-acc__icon::after { transition: none !important; }
  }
{%- endstyle -%}

<div class="faq-section color-{{ section.settings.color_scheme }}">
  <div class="faq-section__inner">

    {%- if section.settings.heading != blank -%}
      <h1 class="faq-section__heading">{{ section.settings.heading | escape }}</h1>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="faq-section__subheading">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}

    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'category' -%}
          <h2 class="faq-category" {{ block.shopify_attributes }}>{{ block.settings.heading | escape }}</h2>

        {%- when 'item' -%}
          <details class="faq-acc" data-faq-accordion {{ block.shopify_attributes }}>
            <summary class="faq-acc__summary">
              <span>{{ block.settings.heading | escape }}</span>
              <span class="faq-acc__icon" aria-hidden="true"></span>
            </summary>
            <div class="faq-acc__content">
              <div class="faq-acc__inner rte">
                {{ block.settings.content }}
              </div>
            </div>
          </details>
      {%- endcase -%}
    {%- endfor -%}

  </div>
</div>

<script>
  (() => {
    if (window.faqAccordionReady) return;
    window.faqAccordionReady = true;

    const calcDur = (h) => Math.min(600, Math.max(220, Math.round(h * 0.55)));

    const openFaq = (el, content) => {
      const dur = calcDur(content.scrollHeight);
      content.style.setProperty('--faq-acc-dur', dur + 'ms');
      el.open = true;
      el.classList.remove('is-closing');
      el.classList.add('is-animating');
      content.style.height = '0px';
      content.getBoundingClientRect();
      content.style.height = content.scrollHeight + 'px';
      setTimeout(() => {
        if (el.open) content.style.height = 'auto';
        el.classList.remove('is-animating');
      }, dur);
    };

    const closeFaq = (el, content) => {
      const dur = calcDur(content.scrollHeight);
      content.style.setProperty('--faq-acc-dur', dur + 'ms');
      el.classList.add('is-animating', 'is-closing');
      content.style.height = content.scrollHeight + 'px';
      content.getBoundingClientRect();
      content.style.height = '0px';
      setTimeout(() => {
        el.open = false;
        el.classList.remove('is-animating', 'is-closing');
      }, dur);
    };

    const bind = (el) => {
      if (!el || el.dataset.faqBound === 'true') return;
      const summary = el.querySelector('.faq-acc__summary');
      const content = el.querySelector('.faq-acc__content');
      if (!summary || !content) return;
      el.dataset.faqBound = 'true';
      el.classList.add('is-ready');
      content.style.height = el.open ? 'auto' : '0px';
      summary.addEventListener('click', (e) => {
        e.preventDefault();
        if (el.classList.contains('is-animating')) return;
        el.open ? closeFaq(el, content) : openFaq(el, content);
      });
    };

    const init = (root = document) => root.querySelectorAll('[data-faq-accordion]').forEach(bind);

    document.readyState === 'loading'
      ? document.addEventListener('DOMContentLoaded', () => init(), { once: true })
      : init();

    document.addEventListener('shopify:section:load', (e) => init(e.target));
  })();
</script>

