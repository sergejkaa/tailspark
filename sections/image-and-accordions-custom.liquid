{%- liquid
  assign image_alt = section.settings.image.alt | default: section.settings.heading | escape
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .ia-custom {
    --ia-bg: {{ section.settings.background_color }};
    --ia-text: {{ section.settings.text_color }};
    --ia-border: {{ section.settings.border_color }};
    --ia-toggle-bg: {{ section.settings.toggle_background }};
    --ia-toggle-icon: {{ section.settings.toggle_icon_color }};
    background: var(--ia-bg);
    color: var(--ia-text);
    padding: {{ section.settings.padding_top_mobile }}px 1.5rem {{ section.settings.padding_bottom_mobile }}px;
  }

  #shopify-section-{{ section.id }} .ia-custom__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    display: grid;
    gap: 28px;
  }

  #shopify-section-{{ section.id }} .ia-custom__media {
    position: relative;
    border-radius: {{ section.settings.image_radius }}px;
  }

  #shopify-section-{{ section.id }} .ia-custom__media img,
  #shopify-section-{{ section.id }} .ia-custom__media svg {
    width: 100%;
    height: auto;
    display: block;
  }

  #shopify-section-{{ section.id }} .ia-custom__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .ia-custom__heading {
    margin: 0 0 24px;
    color: var(--ia-text);
    font-family: var(--font-heading-family, var(--font-body-family, sans-serif));
    font-style: var(--font-heading-style, normal);
    font-weight: var(--font-heading-weight, 700);
    letter-spacing: var(--font-heading-letter-spacing, normal);
  }

  #shopify-section-{{ section.id }} .ia-custom__items {
    border-top: 1px solid var(--ia-border);
  }

  #shopify-section-{{ section.id }} .ia-custom__item {
    border-bottom: 1px solid var(--ia-border);
  }

  #shopify-section-{{ section.id }} .ia-custom__trigger {
    width: 100%;
    min-height: 58px;
    padding: 16px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    border: 0;
    background: transparent;
    color: var(--ia-text);
    text-align: left;
    cursor: pointer;
    font: inherit;
  }

  #shopify-section-{{ section.id }} .ia-custom__item-title {
    margin: 0;
    font-size: 14px;
    line-height: 1.3;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  #shopify-section-{{ section.id }} .ia-custom__toggle {
    width: 24px;
    height: 24px;
    border-radius: 999px;
    background: var(--ia-toggle-bg);
    color: var(--ia-toggle-icon);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    position: relative;
  }

  #shopify-section-{{ section.id }} .ia-custom__toggle::before,
  #shopify-section-{{ section.id }} .ia-custom__toggle::after {
    content: "";
    position: absolute;
    width: 10px;
    height: 2px;
    border-radius: 99px;
    background: currentColor;
    transition: transform 180ms ease;
  }

  #shopify-section-{{ section.id }} .ia-custom__toggle::after {
    transform: rotate(90deg);
  }

  #shopify-section-{{ section.id }} .ia-custom__trigger[aria-expanded="true"] .ia-custom__toggle::after {
    transform: rotate(0deg);
  }

  #shopify-section-{{ section.id }} .ia-custom__panel {
    overflow: hidden;
    max-height: 0;
    transition: max-height 240ms ease;
  }

  #shopify-section-{{ section.id }} .ia-custom__panel-inner {
    padding: 0 42px 18px 0;
    color: var(--ia-text);
    font-size: 14px;
    line-height: 1.5;
  }

  #shopify-section-{{ section.id }} .ia-custom__panel-inner p {
    margin: 0 0 12px;
  }

  #shopify-section-{{ section.id }} .ia-custom__panel-inner p:last-child {
    margin-bottom: 0;
  }

  #shopify-section-{{ section.id }} .ia-custom__block-button {
    margin-top: 16px;
  }

  #shopify-section-{{ section.id }} .ia-custom__cta {
    margin-top: 24px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .ia-custom__cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-width: 180px;
    margin: 0;
    font-size: 14px;
    color: {{ section.settings.button_text_color }};
    line-height: 100%;
    text-align: center;
    text-transform: uppercase;
    text-decoration: none;
    padding: 14px 28px;
    border-radius: 100px;
    transition: all 1s ease 0s;
    background-color: {{ section.settings.button_background }};
    border: 1px solid {{ section.settings.button_border }};
    cursor: pointer;
    font-weight: 700;
    letter-spacing: 0;
  }

  #shopify-section-{{ section.id }} .ia-custom__cta-button:hover {
    color: {{ section.settings.button_text_hover_color }};
    background-color: {{ section.settings.button_hover_background }};
    border-color: {{ section.settings.button_hover_background }};
    transition: all 0.25s ease 0s;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .ia-custom {
      padding: {{ section.settings.padding_top }}px 4rem {{ section.settings.padding_bottom }}px;
    }

    #shopify-section-{{ section.id }} .ia-custom__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      align-items: center;
      gap: 40px;
    }

    #shopify-section-{{ section.id }} .ia-custom--image-right .ia-custom__media {
      order: 2;
    }

    #shopify-section-{{ section.id }} .ia-custom--image-right .ia-custom__content {
      order: 1;
    }

    #shopify-section-{{ section.id }} .ia-custom__media {
      min-height: unset;
    }

    #shopify-section-{{ section.id }} .ia-custom__heading {
      margin-bottom: 32px;
    }

    #shopify-section-{{ section.id }} .ia-custom__trigger {
      min-height: 68px;
      padding: 20px 0;
    }

    #shopify-section-{{ section.id }} .ia-custom__item-title {
      font-size: 16px;
    }

    #shopify-section-{{ section.id }} .ia-custom__panel-inner {
      font-size: 15px;
      padding-bottom: 22px;
      padding-right: 56px;
    }
  }
{%- endstyle -%}

<section class="ia-custom ia-custom--image-{{ section.settings.image_side }}" data-ia-section="{{ section.id }}">
  <div class="ia-custom__inner">
    <div class="ia-custom__media">
      {%- if section.settings.image_asset != blank -%}
        <img src="{{ section.settings.image_asset | asset_url }}" alt="{{ image_alt }}" loading="lazy">
      {%- elsif section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1800 | image_tag: loading: 'lazy', alt: image_alt }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag }}
      {%- endif -%}
    </div>

    <div class="ia-custom__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="ia-custom__heading inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      <div class="ia-custom__items">
        {%- for block in section.blocks -%}
          <div class="ia-custom__item" {{ block.shopify_attributes }}>
            <button
              class="ia-custom__trigger"
              type="button"
              aria-expanded="{% if forloop.first and section.settings.open_first %}true{% else %}false{% endif %}"
              aria-controls="ia-panel-{{ section.id }}-{{ block.id }}"
            >
              <span class="ia-custom__item-title">{{ block.settings.title }}</span>
              <span class="ia-custom__toggle" aria-hidden="true"></span>
            </button>
            <div
              id="ia-panel-{{ section.id }}-{{ block.id }}"
              class="ia-custom__panel"
              {% unless forloop.first and section.settings.open_first %}hidden{% endunless %}
            >
              <div class="ia-custom__panel-inner">
                {{ block.settings.text }}
                {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
                  <div class="ia-custom__block-button">
                    <a class="custom-button-secondary" href="{{ block.settings.button_link }}">{{ block.settings.button_label }}</a>
                  </div>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
        <div class="ia-custom__cta">
          <a class="ia-custom__cta-button" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function() {
    var root = document.querySelector('[data-ia-section="{{ section.id }}"]');
    if (!root) return;

    function setPanel(button, open) {
      var panel = document.getElementById(button.getAttribute('aria-controls'));
      if (!panel) return;

      button.setAttribute('aria-expanded', open ? 'true' : 'false');
      if (open) {
        panel.hidden = false;
        panel.style.maxHeight = panel.scrollHeight + 'px';
      } else {
        panel.style.maxHeight = '0px';
        window.setTimeout(function() {
          if (button.getAttribute('aria-expanded') === 'false') {
            panel.hidden = true;
          }
        }, 240);
      }
    }

    root.querySelectorAll('.ia-custom__trigger').forEach(function(button) {
      if (button.getAttribute('aria-expanded') === 'true') {
        setPanel(button, true);
      }

      button.addEventListener('click', function() {
        var isOpen = button.getAttribute('aria-expanded') === 'true';
        setPanel(button, !isOpen);
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Image and Accordions",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_asset",
      "label": "Or theme asset filename",
      "info": "If set, overrides the image above. e.g. ts-soft-chews.png"
    },
    {
      "type": "select",
      "id": "image_side",
      "label": "Image position on desktop",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "right"
    },
    {
      "type": "text",
      "id": "image_position",
      "label": "Image focal point",
      "default": "50% 50%"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "High-performance essentials for your skin."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.all.heading_size.label",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        }
      ],
      "default": "h1"
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "Open first accordion by default",
      "default": false
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 1000,
      "max": 1800,
      "step": 50,
      "unit": "px",
      "label": "Max width",
      "default": 1400
    },
    {
      "type": "text",
      "id": "desktop_image_ratio",
      "label": "Desktop image ratio",
      "default": "11 / 12"
    },
    {
      "type": "text",
      "id": "mobile_image_ratio",
      "label": "Mobile image ratio",
      "default": "4 / 5"
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Image radius",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Desktop top padding",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Desktop bottom padding",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Mobile top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Mobile bottom padding",
      "default": 36
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#1B4A3D"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Accordion border",
      "default": "#1B4A3D"
    },
    {
      "type": "color",
      "id": "toggle_background",
      "label": "Toggle background",
      "default": "#1B4A3D"
    },
    {
      "type": "color",
      "id": "toggle_icon_color",
      "label": "Toggle icon",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_border",
      "label": "Button border",
      "default": "#696660"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#696660"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button hover background",
      "default": "#696660"
    },
    {
      "type": "color",
      "id": "button_text_hover_color",
      "label": "Button hover text",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "ACCORDION TITLE"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add accordion content here.</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Inner button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Inner button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image and Accordions",
      "blocks": [
        {
          "type": "accordion",
          "settings": {
            "title": "LITTLE PINEAPPLE REFRESH",
            "text": "<p>A gently exfoliating daily cleanser that removes SPF and makeup while leaving skin clean, soft, and hydrated post-rinse.</p>"
          }
        },
        {
          "type": "accordion",
          "settings": {
            "title": "SPOTWEAR",
            "text": "<p>Hydrocolloid stickers that absorb excess oil and shield spots from stressors when you are on the go.</p>"
          }
        },
        {
          "type": "accordion",
          "settings": {
            "title": "GLAZING MIST",
            "text": "<p>A superfine mist that hydrates, refreshes, and helps skin feel balanced over time.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
