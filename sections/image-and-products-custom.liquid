{%- liquid
  assign section_collection = section.settings.collection
  assign products_limit = section.settings.products_to_show
  assign image_alt = section.settings.image.alt | default: section.settings.heading | escape
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .iap-custom {
    --iap-bg: {{ section.settings.background_color }};
    --iap-text: {{ section.settings.text_color }};
    --iap-card-bg: {{ section.settings.card_background }};
    background: var(--iap-bg);
    color: var(--iap-text);
    padding: {{ section.settings.padding_top_mobile }}px 1.5rem {{ section.settings.padding_bottom_mobile }}px;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .iap-custom__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    display: grid;
    gap: 28px;
  }

  #shopify-section-{{ section.id }} .iap-custom__media {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.image_radius }}px;
    aspect-ratio: {{ section.settings.mobile_image_ratio }};
    background: rgba(0, 0, 0, 0.04);
  }

  #shopify-section-{{ section.id }} .iap-custom__media img,
  #shopify-section-{{ section.id }} .iap-custom__media svg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: {{ section.settings.image_position }};
  }

  #shopify-section-{{ section.id }} .iap-custom__content {
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .iap-custom__heading {
    margin: 0 0 24px;
    color: var(--iap-text);
    font-family: var(--font-heading-family, var(--font-body-family, sans-serif));
    font-style: var(--font-heading-style, normal);
    font-weight: var(--font-heading-weight, 700);
    letter-spacing: var(--font-heading-letter-spacing, normal);
  }

  #shopify-section-{{ section.id }} .iap-custom__products {
    display: flex;
    gap: 16px;
    margin: 0 -1.5rem;
    padding: 0 1.5rem 6px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }

  #shopify-section-{{ section.id }} .iap-custom__products::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .iap-custom__products-wrap {
    position: relative;
  }

  #shopify-section-{{ section.id }} .iap-custom__arrow {
    display: none;
  }

  #shopify-section-{{ section.id }} .iap-product-card {
    position: relative;
    flex: 0 0 min(78vw, 320px);
    aspect-ratio: 9.6 / 13;
    display: block;
    overflow: hidden;
    border-radius: {{ section.settings.card_radius }}px;
    background: var(--iap-card-bg);
    color: inherit;
    text-decoration: none;
    scroll-snap-align: start;
  }

  #shopify-section-{{ section.id }} .iap-product-card::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    border-radius: {{ section.settings.card_radius }}px;
    background-color: rgba(255, 255, 255, 0.1);
  }

  #shopify-section-{{ section.id }} .iap-product-card__image {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    transition: all .7s cubic-bezier(.76, 0, .24, 1);
  }

  #shopify-section-{{ section.id }} .iap-product-card__image--second {
    opacity: 0;
  }

  #shopify-section-{{ section.id }} .iap-product-card__image img,
  #shopify-section-{{ section.id }} .iap-product-card__image svg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .iap-product-card__placeholder {
    width: 100%;
    height: 100%;
    background: #eeeeee;
  }

  #shopify-section-{{ section.id }} .iap-product-card__content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 20px;
    padding: 16px 12px;
  }

  #shopify-section-{{ section.id }} .iap-product-card__content::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 1;
    background: linear-gradient(180deg, rgba({{ section.settings.card_background.red }}, {{ section.settings.card_background.green }}, {{ section.settings.card_background.blue }}, 0) 60%, {{ section.settings.card_background }} 100%);
    transition: opacity .3s cubic-bezier(.76, 0, .24, 1);
    transition-delay: .25s;
  }

  #shopify-section-{{ section.id }} .iap-product-card__heading {
    margin: 0;
    color: {{ section.settings.card_heading_color }};
    font-size: 30px;
    line-height: 1.15;
    font-weight: 700;
    letter-spacing: 0;
    word-break: break-word;
  }

  #shopify-section-{{ section.id }} .iap-product-card--heading-hidden .iap-product-card__content {
    justify-content: flex-end;
  }

  #shopify-section-{{ section.id }} .iap-product-card__bottom-inner {
    transition: all .5s ease .2s;
  }

  #shopify-section-{{ section.id }} .iap-product-card__bottom-top {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
  }

  #shopify-section-{{ section.id }} .iap-product-card__bottom-left {
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .iap-product-card__title {
    margin: 0;
    color: {{ section.settings.title_color }};
    font-size: 14px;
    line-height: 1.35;
    font-weight: 700;
    letter-spacing: 0;
    word-break: break-word;
  }

  #shopify-section-{{ section.id }} .iap-product-card__vendor {
    margin: 8px 0 0;
    color: {{ section.settings.vendor_color }};
    font-size: 14px;
    line-height: 1.3;
    letter-spacing: 0;
  }

  #shopify-section-{{ section.id }} .iap-product-card__price {
    flex-shrink: 0;
    text-align: right;
  }

  #shopify-section-{{ section.id }} .iap-product-card__price p {
    margin: 0;
    color: {{ section.settings.price_color }};
    font-size: 14px;
    line-height: 1.35;
    letter-spacing: 0;
  }

  #shopify-section-{{ section.id }} .iap-product-card__compare-price {
    opacity: .8;
    text-decoration: line-through;
  }

  #shopify-section-{{ section.id }} .iap-product-card__button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    margin: 16px 0 0;
    padding: 12px;
    border: 1px solid {{ section.settings.button_border }};
    border-radius: 100px;
    background: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
    font-size: 13px;
    line-height: 1;
    font-weight: 700;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0;
    transition: all 1s ease 0s;
  }

  #shopify-section-{{ section.id }} .iap-product-card:hover .iap-product-card__button {
    border-color: {{ section.settings.button_hover_background }};
    background: {{ section.settings.button_hover_background }};
    color: {{ section.settings.button_text_hover_color }};
    transition: all .25s ease 0s;
  }

  #shopify-section-{{ section.id }} .iap-custom__cta {
    margin-top: 24px;
    display: flex;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .iap-custom__cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 180px;
    margin: 0;
    padding: 14px 28px;
    border: 1px solid {{ section.settings.button_border }};
    border-radius: 100px;
    background-color: {{ section.settings.button_background }};
    color: {{ section.settings.button_text_color }};
    font-size: 14px;
    line-height: 1;
    font-weight: 700;
    text-align: center;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0;
    transition: all 1s ease 0s;
  }

  #shopify-section-{{ section.id }} .iap-custom__cta-button:hover {
    border-color: {{ section.settings.button_hover_background }};
    background-color: {{ section.settings.button_hover_background }};
    color: {{ section.settings.button_text_hover_color }};
    transition: all .25s ease 0s;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .iap-custom {
      padding: {{ section.settings.padding_top }}px 4rem {{ section.settings.padding_bottom }}px;
    }

    #shopify-section-{{ section.id }} .iap-custom__inner {
      grid-template-columns: minmax(280px, {{ section.settings.desktop_image_width }}%) minmax(0, 1fr);
      align-items: center;
      gap: 40px;
    }

    #shopify-section-{{ section.id }} .iap-custom--image-right .iap-custom__inner {
      grid-template-columns: minmax(0, 1fr) minmax(280px, {{ section.settings.desktop_image_width }}%);
    }

    #shopify-section-{{ section.id }} .iap-custom--image-right .iap-custom__media {
      order: 2;
    }

    #shopify-section-{{ section.id }} .iap-custom--image-right .iap-custom__content {
      order: 1;
    }

    #shopify-section-{{ section.id }} .iap-custom__media {
      aspect-ratio: {{ section.settings.desktop_image_ratio }};
      min-height: {{ section.settings.desktop_image_min_height }}px;
    }

    #shopify-section-{{ section.id }} .iap-custom__heading {
      margin-bottom: 32px;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .iap-custom__products {
      gap: 20px;
      margin: 0 -4rem 0 0;
      padding: 0 4rem 8px 0;
      scroll-behavior: smooth;
    }

    #shopify-section-{{ section.id }} .iap-custom__arrow {
      position: absolute;
      z-index: 4;
      top: 50%;
      transform: translateY(-50%);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 48px;
      height: 48px;
      padding: 0;
      border: 0;
      border-radius: 999px;
      background: #ffffff;
      color: #696660;
      box-shadow: 0 0 10px 0 rgba(0, 0, 0, .15);
      cursor: pointer;
      transition: opacity .2s ease, background-color .2s ease, color .2s ease;
      -webkit-appearance: none;
      appearance: none;
    }

    #shopify-section-{{ section.id }} .iap-custom__arrow:hover {
      background: #696660;
      color: #ffffff;
    }

    #shopify-section-{{ section.id }} .iap-custom__arrow[disabled] {
      opacity: 0;
      pointer-events: none;
    }

    #shopify-section-{{ section.id }} .iap-custom__arrow--prev {
      left: -24px;
    }

    #shopify-section-{{ section.id }} .iap-custom__arrow--next {
      right: -24px;
    }

    #shopify-section-{{ section.id }} .iap-custom__arrow-icon {
      pointer-events: none;
      display: grid;
      place-items: center;
    }

    #shopify-section-{{ section.id }} .iap-custom__arrow-icon::before {
      content: "";
      grid-area: 1 / -1;
      width: 8px;
      height: 8px;
      position: relative;
      left: -1px;
      box-sizing: border-box;
      border-top: 2px solid currentColor;
      border-right: 2px solid currentColor;
      transform: rotate(45deg);
    }

    #shopify-section-{{ section.id }} .iap-custom__arrow--prev .iap-custom__arrow-icon::before {
      left: auto;
      right: -1px;
      border-top: 0;
      border-right: 0;
      border-bottom: 2px solid currentColor;
      border-left: 2px solid currentColor;
    }

    #shopify-section-{{ section.id }} .iap-product-card {
      flex: 0 0 min(360px, calc((100% - 20px) / 2));
      aspect-ratio: 9.6 / 11;
    }

    #shopify-section-{{ section.id }} .iap-product-card__content {
      padding: 24px 14px;
    }

    #shopify-section-{{ section.id }} .iap-product-card__heading {
      font-size: 34px;
    }

    #shopify-section-{{ section.id }} .iap-product-card__title,
    #shopify-section-{{ section.id }} .iap-product-card__vendor,
    #shopify-section-{{ section.id }} .iap-product-card__price p {
      font-size: 15px;
    }
  }

  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .iap-product-card__button {
      position: absolute;
      bottom: -100%;
      left: 50%;
      width: calc(100% - 28px);
      margin-top: 0;
      transform: translateX(-50%);
      transition: all .5s ease 0s;
    }

    #shopify-section-{{ section.id }} .iap-product-card:hover .iap-product-card__button {
      bottom: 24px;
      transition: all .4s ease 0s;
    }

    #shopify-section-{{ section.id }} .iap-product-card:hover .iap-product-card__bottom-inner {
      opacity: 0;
      transition: all .5s ease 0s;
    }

    #shopify-section-{{ section.id }} .iap-product-card:hover .iap-product-card__image--second {
      opacity: 1;
    }

    #shopify-section-{{ section.id }} .iap-product-card:hover .iap-product-card__image--first {
      opacity: 0;
    }

    #shopify-section-{{ section.id }} .iap-product-card:hover .iap-product-card__content::after {
      opacity: 0;
      transition-delay: 0s;
    }
  }
{%- endstyle -%}

<section class="iap-custom iap-custom--image-{{ section.settings.image_side }}">
  <div class="iap-custom__inner">
    <div class="iap-custom__media" data-aos="fade-up">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1800 | image_tag: loading: 'lazy', alt: image_alt }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag }}
      {%- endif -%}
    </div>

    <div class="iap-custom__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="iap-custom__heading inline-richtext {{ section.settings.heading_size }}" data-aos="fade-up">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      <div class="iap-custom__products-wrap" data-iap-slider="{{ section.id }}">
        <button class="iap-custom__arrow iap-custom__arrow--prev" type="button" aria-label="Previous products">
          <span class="iap-custom__arrow-icon" aria-hidden="true"></span>
        </button>
        <button class="iap-custom__arrow iap-custom__arrow--next" type="button" aria-label="Next products">
          <span class="iap-custom__arrow-icon" aria-hidden="true"></span>
        </button>

        <div class="iap-custom__products">
          {%- if section_collection != blank and section_collection.all_products_count > 0 -%}
            {%- for product in section_collection.products limit: products_limit -%}
              {%- liquid
                assign card_heading = product.title | split: ' ' | first | downcase
                if section.settings.card_heading_source == 'vendor'
                  assign card_heading = product.vendor
                elsif section.settings.card_heading_source == 'collection'
                  assign card_heading = section_collection.title
                elsif section.settings.card_heading_source == 'type'
                  assign card_heading = product.type | default: card_heading
                endif
                assign card_heading = card_heading | downcase
                assign hide_card_heading = false
                if section.settings.card_heading_source == 'hide'
                  assign hide_card_heading = true
                endif
                assign second_image = product.media[1].preview_image
                assign featured_alt = product.featured_image.alt | default: product.title
                assign second_alt = second_image.alt | default: product.title
                if product.featured_image == blank
                  assign second_image = blank
                endif
              -%}
              <a href="{{ product.url }}" class="iap-product-card{% if hide_card_heading %} iap-product-card--heading-hidden{% endif %}">
                <div class="iap-product-card__image iap-product-card__image--first">
                  {%- if product.featured_image != blank -%}
                    {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: featured_alt }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'iap-product-card__placeholder' }}
                  {%- endif -%}
                </div>

                {%- if second_image != blank -%}
                  <div class="iap-product-card__image iap-product-card__image--second">
                    {{ second_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: second_alt }}
                  </div>
                {%- endif -%}

                <div class="iap-product-card__content">
                  {%- unless hide_card_heading -%}
                    <p class="iap-product-card__heading">{{ card_heading }}</p>
                  {%- endunless -%}
                  <div class="iap-product-card__bottom">
                    <div class="iap-product-card__bottom-inner">
                      <div class="iap-product-card__bottom-top">
                        <div class="iap-product-card__bottom-left">
                          <p class="iap-product-card__title">{{ product.title }}</p>
                          {%- if section.settings.show_vendor -%}
                            <p class="iap-product-card__vendor">{{ product.vendor }}</p>
                          {%- endif -%}
                        </div>
                        <div class="iap-product-card__price">
                          <p>{{ product.price | money }}</p>
                          {%- if product.compare_at_price > product.price -%}
                            <p class="iap-product-card__compare-price">{{ product.compare_at_price | money }}</p>
                          {%- endif -%}
                        </div>
                      </div>
                    </div>
                    <div class="iap-product-card__button">{{ section.settings.button_label }}</div>
                  </div>
                </div>
              </a>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..4) -%}
              <div class="iap-product-card{% if section.settings.card_heading_source == 'hide' %} iap-product-card--heading-hidden{% endif %}">
                <div class="iap-product-card__image iap-product-card__image--first">
                  {{ 'product-' | append: i | placeholder_svg_tag: 'iap-product-card__placeholder' }}
                </div>
                <div class="iap-product-card__content">
                  {%- unless section.settings.card_heading_source == 'hide' -%}
                    <p class="iap-product-card__heading">product</p>
                  {%- endunless -%}
                  <div class="iap-product-card__bottom">
                    <div class="iap-product-card__bottom-inner">
                      <div class="iap-product-card__bottom-top">
                        <div class="iap-product-card__bottom-left">
                          <p class="iap-product-card__title">Example product</p>
                          {%- if section.settings.show_vendor -%}
                            <p class="iap-product-card__vendor">Vendor name</p>
                          {%- endif -%}
                        </div>
                        <div class="iap-product-card__price"><p>{{ 3200 | money }}</p></div>
                      </div>
                    </div>
                    <div class="iap-product-card__button">{{ section.settings.button_label }}</div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>

      {%- if section.settings.cta_label != blank -%}
        {%- liquid
          assign cta_href = section.settings.cta_link
          if cta_href == blank and section_collection != blank
            assign cta_href = section_collection.url
          endif
        -%}
        {%- if cta_href != blank -%}
          <div class="iap-custom__cta">
            <a class="iap-custom__cta-button" href="{{ cta_href }}">{{ section.settings.cta_label }}</a>
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</section>

<script>
  (function() {
    var sectionId = {{ section.id | json }};

    function initImageProductsSlider() {
      var root = document.querySelector('[data-iap-slider="' + sectionId + '"]');
      if (!root) return;

      var track = root.querySelector('.iap-custom__products');
      var prev = root.querySelector('.iap-custom__arrow--prev');
      var next = root.querySelector('.iap-custom__arrow--next');
      if (!track || !prev || !next || track.dataset.iapReady === 'true') return;

      track.dataset.iapReady = 'true';

      function getStep() {
        var card = track.querySelector('.iap-product-card');
        if (!card) return track.clientWidth;

        var styles = window.getComputedStyle(track);
        var gap = parseFloat(styles.columnGap || styles.gap) || 0;
        return card.getBoundingClientRect().width + gap;
      }

      function updateButtons() {
        var maxScroll = track.scrollWidth - track.clientWidth - 2;
        prev.disabled = track.scrollLeft <= 2;
        next.disabled = track.scrollLeft >= maxScroll;
      }

      prev.addEventListener('click', function() {
        track.scrollBy({ left: -getStep(), behavior: 'smooth' });
      });

      next.addEventListener('click', function() {
        track.scrollBy({ left: getStep(), behavior: 'smooth' });
      });

      track.addEventListener('scroll', updateButtons, { passive: true });
      window.addEventListener('resize', updateButtons);
      updateButtons();
    }

    initImageProductsSlider();

    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail && event.detail.sectionId === sectionId) {
        initImageProductsSlider();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Image and Products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_side",
      "label": "Image position on desktop",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "image_position",
      "label": "Image focal point",
      "default": "50% 50%"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "High-performance essentials for your routine."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.all.heading_size.label",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        }
      ],
      "default": "h1"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": true
    },
    {
      "type": "select",
      "id": "card_heading_source",
      "label": "Large card heading source",
      "options": [
        {
          "value": "hide",
          "label": "Hide"
        },
        {
          "value": "vendor",
          "label": "Vendor"
        },
        {
          "value": "collection",
          "label": "Collection name"
        },
        {
          "value": "type",
          "label": "Product type"
        },
        {
          "value": "first_word",
          "label": "First word of product title"
